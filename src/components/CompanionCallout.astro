---
// Cross-link box that ties an explainer post to its runnable JAX companion.
// `role` is the role of the CURRENT post: 'explainer' links forward to the JAX
// companion; 'companion' links back to the explainer.
interface Pair { role: 'explainer' | 'companion'; slug: string; title: string }
interface Props { pair?: Pair }
const { pair } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const isExplainer = pair?.role === 'explainer';
const eyebrow = isExplainer ? 'Runnable JAX companion' : 'Explainer companion';
const lead = isExplainer
  ? 'Prefer to read the code? This post has a hands-on JAX / Flax NNX implementation.'
  : 'Want the full intuition first? This is the runnable companion to the explainer.';
const cta = isExplainer ? 'Open the JAX companion' : 'Read the explainer';
---
{pair && (
  <a class={`companion-callout ${pair.role}`} href={`${base}/${pair.slug}/`}>
    <span class="cc-icon" aria-hidden="true">{isExplainer ? '⌨' : '📖'}</span>
    <span class="cc-body">
      <span class="cc-eyebrow">{eyebrow}</span>
      <span class="cc-title">{pair.title}</span>
      <span class="cc-lead">{lead}</span>
    </span>
    <span class="cc-cta">{cta} <span aria-hidden="true">→</span></span>
  </a>
)}

<style>
  .companion-callout {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.9rem 1rem;
    margin: 0 0 2rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent) 5%, var(--bg));
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }
  .companion-callout:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 9%, var(--bg));
  }
  .cc-icon {
    font-size: 1.4rem;
    line-height: 1;
    opacity: 0.9;
  }
  .cc-body { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .cc-eyebrow {
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .cc-title {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.3;
    color: var(--fg);
  }
  .cc-lead {
    font-size: 0.84rem;
    line-height: 1.45;
    color: var(--fg-muted);
  }
  .cc-cta {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
    white-space: nowrap;
  }
  .companion-callout:hover .cc-cta { text-decoration: underline; }

  @media (max-width: 600px) {
    .companion-callout { grid-template-columns: auto 1fr; }
    .cc-cta { grid-column: 2; justify-self: start; margin-top: 0.1rem; }
  }
</style>
