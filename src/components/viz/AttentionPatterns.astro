---
interface Props {
  caption?: string;
  size?: number;
  height?: number;
}
const { caption, size = 12, height = 270 } = Astro.props;
---
<figure class="viz attentionpatterns" data-size={size} data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { heatmap, text } from './engine/draw.js';
import { np, nn, withJax, drawJaxLoading } from './engine/jax.js';

// Real attention. Three causal heads over one token sequence, each a different
// REAL Q/K projection — the attention matrices are computed live by jax-js
// (softmax(QKᵀ/√d)), not hand-painted. The three "kernel structures":
//   positional — Q,K read a sinusoidal position code → diagonal decay
//   previous   — W_Q applies the rotary shift pᵢ→pᵢ₋₁ → sub-diagonal
//   induction  — Q reads current-token content, K reads previous-token content
// Animation sweeps the causal query frontier down the rows; τ sharpens softmax.

const buildModel = (N) => {
  const V = 4;                                   // vocabulary (one-hot content → cᵢ·cⱼ = δ)
  const FREQ = [0.9, 0.45, 0.22]; const dp = FREQ.length * 2;
  const D = 2 * V + dp, dh = Math.max(V, dp);
  const tokens = Array.from({ length: N }, (_, i) => i % V);
  const oh = (t) => { const v = new Array(V).fill(0); if (t >= 0) v[t] = 1; return v; };
  const pe = (i) => { const p = []; for (const w of FREQ) p.push(Math.sin(i * w), Math.cos(i * w)); return p; };
  const X = []; for (let i = 0; i < N; i++) X.push([...oh(tokens[i]), ...oh(i > 0 ? tokens[i - 1] : -1), ...pe(i)]);
  const zero = () => Array.from({ length: D }, () => new Array(dh).fill(0));
  const idBlock = (W, start, len, off = 0) => { for (let k = 0; k < len; k++) W[start + k][k + off] = 1; };
  // positional / local
  const posQ = zero(); idBlock(posQ, 2 * V, dp); const posK = zero(); idBlock(posK, 2 * V, dp);
  // previous-token: W_Q rotates the position code back one step (rotary), W_K reads it straight
  const prevK = zero(); idBlock(prevK, 2 * V, dp);
  const prevQ = zero(); FREQ.forEach((w, f) => { const r = 2 * V + 2 * f, c = 2 * f, cs = Math.cos(w), sn = Math.sin(w);
    prevQ[r][c] = cs; prevQ[r + 1][c] = -sn; prevQ[r][c + 1] = sn; prevQ[r + 1][c + 1] = cs; });
  // induction: Q = current content, K = previous-token content
  const indQ = zero(); idBlock(indQ, 0, V); const indK = zero(); idBlock(indK, V, V);
  const mask = Array.from({ length: N }, (_, i) => Array.from({ length: N }, (_, j) => (j <= i ? 0 : -1e9)));
  return { N, dh, tokens, X, mask, heads: [
    { name: 'positional', WQ: posQ, WK: posK },
    { name: 'previous token', WQ: prevQ, WK: prevK },
    { name: 'induction', WQ: indQ, WK: indK },
  ] };
};

// one real attention matrix via jax-js; fresh arrays each call (no .ref leak across calls)
const attnMatrix = (m, head, tau) => {
  const X = np.array(m.X), WQ = np.array(head.WQ), WK = np.array(head.WK);
  const Q = np.matmul(X.ref, WQ), K = np.matmul(X, WK);
  let s = np.matmul(Q, np.swapaxes(K, 0, 1)).mul(1 / (Math.sqrt(m.dh) * tau));
  s = s.add(np.array(m.mask));
  const A = nn.softmax(s, -1);
  const nested = A.js(); const flat = new Float64Array(m.N * m.N);
  for (let i = 0; i < m.N; i++) for (let j = 0; j < m.N; j++) flat[i * m.N + j] = nested[i][j];
  return flat;
};

defineViz('attentionpatterns', (root) => {
  const N = +root.dataset.size || 12;
  const model = buildModel(N);
  const recompute = (api) => { const tau = api.get('tau') || 1; api.state.mats = model.heads.map((h) => attnMatrix(model, h, tau)); };
  return {
    height: 270, stepsPerFrame: 0.04,
    controls: [
      { type: 'play' }, { type: 'step' }, { type: 'reset' }, { type: 'speed' },
      { type: 'range', name: 'tau', label: 'temperature τ', min: 0.3, max: 3, step: 0.05, value: 1, reset: false, fmt: (v) => v.toFixed(2) },
      { type: 'readout', name: 'ro' },
    ],
    onControl(name, value, api) { if (name === 'tau' && api.state.jaxReady) { recompute(api); } },
    setup(api) {
      api.state.qi = 0; api.state.mats = null;
      withJax(api, recompute);
    },
    step(api) { api.state.qi = (api.state.qi + 1) % N; },
    draw(api) {
      const { ctx, colors, size, state } = api; const W = size.W, H = size.H;
      if (!state.jaxReady || !state.mats) return drawJaxLoading(api);
      const gap = 14, cw = (W - gap * 2) / 3, head = 18;
      model.heads.forEach((h, k) => {
        const bx = k * (cw + gap);
        text(ctx, h.name, bx + cw / 2, 2, colors, { align: 'center', size: 11.5, weight: '600', color: colors.fg });
        heatmap(ctx, { x: bx, y: head, w: cw, h: H - head }, state.mats[k], N, colors, { activeRow: state.qi });
      });
      const tau = api.get('tau');
      api.readout('ro', `query t${state.qi} · τ ${(+tau).toFixed(2)} · ${N}×${N} causal · jax-js`);
    },
  };
});
</script>
