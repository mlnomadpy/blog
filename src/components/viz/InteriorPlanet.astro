---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 450 } = Astro.props;
---
<figure class="viz interiorplanet" data-caption={caption} data-height={height} data-height-mobile="580" tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The disenfranchisement theorem, staged. Five bodies form a ring; a sixth
// sits inside their convex hull. Under the dot-product law that sixth body
// can never win a single query anywhere in the plane (its score is a convex
// combination of the others', so it never tops the row). Under the kernel it
// keeps the neighborhood around itself. Drag it across the hull edge and
// watch its softmax territory snap into existence.
import { defineViz } from './engine/vizkit.js';
import { T, dot, fmt, axes, PALETTE } from './engine/draw.js';
import { drag } from './engine/pointer.js';
import { rows, convexHull, insideHull } from './geomattn.js';

const GRID = 68;
const RING = [
  [1.15, 0.4], [0.25, 1.2], [-1.0, 0.75], [-0.85, -0.85], [0.65, -1.1],
];
const R = 2.6;
const INNER = 5; // index of the inner body in the key list

function hex2rgb(h) {
  return [parseInt(h.slice(1, 3), 16), parseInt(h.slice(3, 5), 16), parseInt(h.slice(5, 7), 16)];
}

defineViz('interiorplanet', {
  title: 'A body inside the ring owns nothing, under one of the laws',
  height: 450,
  controls: [
    { type: 'button', name: 'restore', label: 'Put it back inside' },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    const st = api.state;
    st.inner = [0.1, 0.05];
    drag(api.canvas, {
      cursor: 'grab',
      onStart(p) {
        const bs = st.boxes || [];
        st.dragBox = bs.findIndex((b) => p.x >= b.x && p.x <= b.x + b.w && p.y >= b.y && p.y <= b.y + b.h);
        st.dragging = st.dragBox >= 0;
      },
      onMove(p) {
        if (!st.dragging) return;
        const b = st.boxes?.[st.dragBox];
        if (!b) return;
        st.inner = [
          Math.max(-R, Math.min(R, -R + (2 * R * (p.x - b.x)) / b.w)),
          Math.max(-R, Math.min(R, R - (2 * R * (p.y - b.y)) / b.h)),
        ];
        api.render();
      },
      onEnd() { st.dragging = false; },
    });
  },

  onAction(name, api) {
    if (name === 'restore') { api.state.inner = [0.1, 0.05]; api.render(); }
  },

  draw(api) {
    const { ctx, colors, size: { W, H } } = api, st = api.state;
    const keys = RING.concat([st.inner]);
    const hull = convexHull(RING);
    const inside = insideHull(st.inner, hull);

    const pad = 14, gapX = 18, top = 30, footer = 62;
    const half = (W - 2 * pad - gapX) / 2;
    const side = Math.min(half, H - top - footer);
    const boxes = [
      { x: pad + (half - side) / 2, y: top, w: side, h: side, name: 'softmax of q·k', law: 'soft' },
      { x: pad + half + gapX + (half - side) / 2, y: top, w: side, h: side, name: 'yat kernel', law: 'ker' },
    ];
    st.boxes = boxes;
    const accent = hex2rgb(PALETTE[0]);
    const shares = { soft: 0, ker: 0 };

    for (const b of boxes) {
      const off = document.createElement('canvas');
      off.width = GRID; off.height = GRID;
      const octx = off.getContext('2d'), img = octx.createImageData(GRID, GRID);
      for (let r = 0; r < GRID; r++) for (let c = 0; c < GRID; c++) {
        const q = [-R + (2 * R * c) / (GRID - 1), R - (2 * R * r) / (GRID - 1)];
        const rw = rows(q, keys);
        const win = b.law === 'soft' ? rw.winSoft : rw.winKer;
        const i4 = (r * GRID + c) * 4;
        if (win === INNER) {
          shares[b.law]++;
          img.data[i4] = accent[0]; img.data[i4 + 1] = accent[1]; img.data[i4 + 2] = accent[2];
          img.data[i4 + 3] = 200;
        } else {
          img.data[i4 + 3] = 0;
        }
      }
      octx.putImageData(img, 0, 0);
      ctx.imageSmoothingEnabled = true;
      ctx.fillStyle = colors.cellBg;
      ctx.fillRect(b.x, b.y, b.w, b.h);
      ctx.drawImage(off, b.x, b.y, b.w, b.h);
      axes(ctx, b, { xMin: -R, xMax: R, yMin: -R, yMax: R }, colors);
      T(ctx, colors, 'label');
      ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
      ctx.fillText(b.name, b.x, b.y - 8);
      const toPx = (p) => [
        b.x + ((p[0] + R) / (2 * R)) * b.w,
        b.y + (1 - (p[1] + R) / (2 * R)) * b.h,
      ];
      // the hull of the ring
      ctx.strokeStyle = colors.faint; ctx.setLineDash([5, 4]); ctx.lineWidth = 1.2;
      ctx.beginPath();
      hull.forEach((p, i) => {
        const [x, y] = toPx(p);
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      });
      ctx.closePath(); ctx.stroke(); ctx.setLineDash([]);
      // the ring bodies (gray: they are the incumbents)
      RING.forEach((k) => {
        const [x, y] = toPx(k);
        dot(ctx, x, y, 6, colors.muted);
        ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.4;
        ctx.beginPath(); ctx.arc(x, y, 6, 0, 2 * Math.PI); ctx.stroke();
      });
      // the contested body
      const [ix, iy] = toPx(st.inner);
      dot(ctx, ix, iy, 7, PALETTE[0]);
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.8;
      ctx.beginPath(); ctx.arc(ix, iy, 7, 0, 2 * Math.PI); ctx.stroke();
    }

    const pct = (n) => fmt((100 * n) / (GRID * GRID), 1) + '%';
    T(ctx, colors, 'small');
    ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillText('orange = queries the orange body wins; the dashed line is the other five bodies’ convex hull; drag the orange body', pad, H - 42);
    ctx.fillText(inside
      ? 'it sits inside the hull: its dot-product score is beaten everywhere, by the one-line convexity argument in the text'
      : 'outside the hull a separating direction exists, and the dot-product law grants it an infinite wedge of sky', pad, H - 25);
    api.readout('rd', `territory in view: softmax ${pct(shares.soft)}, kernel ${pct(shares.ker)}${inside ? ' (inside the hull)' : ' (outside the hull)'}`);
  },
});
</script>
