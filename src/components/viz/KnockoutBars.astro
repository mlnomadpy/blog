---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 320 } = Astro.props;
const id = `kb-${Math.random().toString(36).slice(2, 9)}`;
---
<figure class="viz">
  <div class="viz-controls kb-controls" data-kb={id}>
    <div class="kb-row">
      <span class="faint">knock out:</span>
      <div class="kb-buttons" data-group="subset">
        <button type="button" data-subset="times" class="active">×</button>
        <button type="button" data-subset="plus">+</button>
        <button type="button" data-subset="minus">−</button>
        <button type="button" data-subset="div">÷</button>
      </div>
      <span class="faint" style="margin-left:1.2rem">how:</span>
      <div class="kb-buttons" data-group="mode">
        <button type="button" data-mode="row" class="active">row</button>
        <button type="button" data-mode="slot">slot</button>
        <button type="button" data-mode="random">random</button>
      </div>
    </div>
    <div class="kb-readout" id={`${id}-readout`}>—</div>
  </div>
  <canvas id={`${id}-c`} height={height} aria-label="Per-operator change in OCR accuracy, bar chart of the paper's intervention table"></canvas>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .kb-controls { flex-direction: column; align-items: stretch; gap: 0.5rem; }
  .kb-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; }
  .kb-buttons { display: inline-flex; gap: 0.3rem; }
  .kb-buttons button {
    font-family: var(--mono);
    font-size: 0.82rem;
    padding: 0.3rem 0.7rem;
    background: var(--bg);
    color: var(--fg-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
    min-width: 34px;
  }
  .kb-buttons button:hover:not(:disabled) { color: var(--accent); border-color: var(--accent); }
  .kb-buttons button.active { color: var(--bg); background: var(--accent); border-color: var(--accent); }
  .kb-buttons button:disabled { opacity: 0.35; cursor: not-allowed; }
  .kb-readout {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
  }
</style>

<script is:inline define:vars={{ id }}>
(() => {
  const setup = () => {
    const c = document.getElementById(id + '-c');
    if (!c || c.dataset.ready) return;
    c.dataset.ready = '1';
    c.style.height = (+c.getAttribute('height') || 320) + 'px';   // pin: no CSS height -> collapsed canvas
    const ctx = c.getContext('2d');
    const wrap = document.querySelector(`[data-kb="${id}"]`);
    const subBtns = wrap.querySelectorAll('[data-group="subset"] button');
    const modeBtns = wrap.querySelectorAll('[data-group="mode"] button');
    const readout = document.getElementById(id + '-readout');

    // ΔOCR (percentage points), verbatim from Table 2 of Painting Arithmetic
    // (public/papers/painting-arithmetic.pdf). The paper reports SLOT and RANDOM
    // only for the × and + subsets, and a per-operator baseline only for ×
    // (86.5% -> 42.7% under ROW), so this chart shows deltas, nothing invented.
    const TABLE2 = {
      times: { N: 30,
        row:    { plus: -14.4, minus: -13.8, times: -43.7, div: -1.6 },
        slot:   { plus:  -1.9, minus:  -3.6, times: -40.0, div: -0.6 },
        random: { plus:  -8.9, minus:  -9.8, times:  -9.2, div: -2.6 } },
      plus: { N: 32,
        row:    { plus: -13.6, minus: -5.1, times:  -1.9, div: -2.3 },
        slot:   { plus:  -4.5, minus:  0.6, times:  -1.2, div: -0.4 },
        random: { plus: -12.5, minus: -8.2, times: -20.0, div: -3.9 } },
      minus: { N: 14,
        row:    { plus: -3.5, minus: -4.4, times: -3.2, div: -0.8 } },
      div: { N: 47,
        row:    { plus: -13.1, minus: -18.3, times: -9.7, div: -15.8 } },
    };
    const opLabel = { plus: '+', minus: '−', times: '×', div: '÷' };
    const opOrder = ['plus', 'minus', 'times', 'div'];

    let subset = 'times';
    let mode = 'row';
    const state = { dpr: 1, w: 0, h: 0 };

    let colors = readColors();
    function readColors() {
      const s = getComputedStyle(document.documentElement);
      const v = (n) => s.getPropertyValue(n).trim();
      return {
        accent: v('--accent') || '#b3661b',
        bg: v('--bg') || '#fbfaf6',
        bgSunken: v('--bg-sunken') || '#f1efe7',
        fg: v('--fg') || '#1a1a1a',
        muted: v('--fg-muted') || '#5a5f66',
        faint: v('--fg-faint') || '#8d8d8d',
        border: v('--border') || '#e4e1d6',
      };
    }
    const themeObs = new MutationObserver(() => { colors = readColors(); requestRedraw(); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    const fit = () => {
      const rect = c.getBoundingClientRect();
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      state.dpr = dpr;
      state.w = rect.width;
      state.h = rect.height;
      c.width = Math.round(rect.width * dpr);
      c.height = Math.round(rect.height * dpr);
    };

    let rafScheduled = false;
    let visible = false;
    const requestRedraw = () => {
      if (rafScheduled || !visible) return;
      rafScheduled = true;
      requestAnimationFrame(() => { rafScheduled = false; draw(); });
    };

    const syncButtons = () => {
      const avail = TABLE2[subset];
      modeBtns.forEach((b) => {
        const ok = !!avail[b.dataset.mode];
        b.disabled = !ok;
        if (!ok && mode === b.dataset.mode) mode = 'row';
        b.classList.toggle('active', b.dataset.mode === mode);
      });
      subBtns.forEach((b) => b.classList.toggle('active', b.dataset.subset === subset));
    };

    const draw = () => {
      const W = state.w, H = state.h;
      if (W === 0) return;
      ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);

      const padL = 54, padR = 16, padT = 24, padB = 52;
      const plotW = W - padL - padR;
      const plotH = H - padT - padB;
      const yMin = -50, yMax = 5;
      const sy = (v) => padT + (yMax - v) / (yMax - yMin) * plotH;
      const d = TABLE2[subset][mode];

      // Grid + axis ticks (every 10 pp)
      ctx.strokeStyle = colors.border;
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (let v = -50; v <= 0; v += 10) { const y = sy(v); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); }
      ctx.stroke();
      ctx.fillStyle = colors.faint;
      ctx.font = '10px ui-monospace, monospace';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      for (let v = -50; v <= 0; v += 10) ctx.fillText(v + ' pp', padL - 4, sy(v));
      // zero line, emphasised
      ctx.strokeStyle = colors.muted;
      ctx.beginPath(); ctx.moveTo(padL, sy(0)); ctx.lineTo(W - padR, sy(0)); ctx.stroke();

      ctx.save();
      ctx.translate(14, padT + plotH / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillStyle = colors.muted;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText('ΔOCR per operator (pp), paper Table 2', 0, 0);
      ctx.restore();

      const groupW = plotW / opOrder.length;
      const barW = Math.min(58, groupW * 0.42);

      opOrder.forEach((op, i) => {
        const cx = padL + groupW * i + groupW / 2;
        const isTargeted = (subset === op);
        const val = d[op];
        const y0 = sy(0), y1 = sy(val);
        const top = Math.min(y0, y1), h = Math.max(1, Math.abs(y1 - y0));
        ctx.fillStyle = isTargeted ? colors.accent : colors.accent + '55';
        ctx.strokeStyle = isTargeted ? colors.accent : colors.muted;
        ctx.lineWidth = 1;
        ctx.fillRect(cx - barW / 2, top, barW, h);
        ctx.strokeRect(cx - barW / 2, top, barW, h);

        // value label at the bar tip
        const label = (val > 0 ? '+' : '') + val.toFixed(1);
        ctx.fillStyle = isTargeted ? colors.accent : colors.muted;
        ctx.font = (isTargeted ? 'bold ' : '') + '11px ui-monospace, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = val <= 0 ? 'top' : 'bottom';
        ctx.fillText(label, cx, val <= 0 ? y1 + 4 : y1 - 4);

        // operator label under the plot
        ctx.fillStyle = isTargeted ? colors.fg : colors.muted;
        ctx.font = 'bold 15px ' + (getComputedStyle(document.body).fontFamily || 'serif');
        ctx.textBaseline = 'top';
        ctx.fillText(opLabel[op], cx, padT + plotH + 8);
        if (isTargeted) {
          ctx.font = '9px ui-monospace, monospace';
          ctx.fillStyle = colors.faint;
          ctx.fillText('targeted', cx, padT + plotH + 26);
        }
      });

      // header note: what the paper reports for this selection
      ctx.font = '10px ui-monospace, monospace';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = colors.faint;
      const note = (subset === 'minus' || subset === 'div')
        ? 'paper reports only the row intervention for this subset'
        : (subset === 'times' && mode === 'row') ? 'paper baseline for ×: 86.5% → 42.7% under this intervention' : '';
      if (note) ctx.fillText(note, padL, padT - 12);

      // specificity per the paper's Definition 3: target drop minus mean collateral
      const others = opOrder.filter((o) => o !== subset);
      const spec = -d[subset] + others.reduce((a, o) => a + d[o], 0) / others.length;
      readout.textContent = `subset = ${opLabel[subset]} (N=${TABLE2[subset].N}) · intervention = ${mode} · Δ on target = ${d[subset].toFixed(1)} pp · specificity (paper Def. 3) = ${spec >= 0 ? '+' : ''}${spec.toFixed(1)} pp`;
    };

    subBtns.forEach((b) => b.addEventListener('click', () => {
      subset = b.dataset.subset;
      syncButtons();
      requestRedraw();
    }));
    modeBtns.forEach((b) => b.addEventListener('click', () => {
      if (b.disabled) return;
      mode = b.dataset.mode;
      syncButtons();
      requestRedraw();
    }));

    syncButtons();
    const ro = new ResizeObserver(() => { fit(); requestRedraw(); });
    ro.observe(c);
    const io = new IntersectionObserver((entries) => {
      const was = visible;
      visible = entries[0].isIntersecting;
      if (visible && !was) { fit(); draw(); }
    }, { rootMargin: '120px' });
    io.observe(c);
    (window.__vizReg || (window.__vizReg = new Set())).add({ n: c, c: () => { themeObs.disconnect(); ro.disconnect(); io.disconnect(); } });
  };

  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:after-swap', setup);
})();
</script>
