---
interface Props { caption?: string; height?: number; }
const { caption, height = 460 } = Astro.props;
---
<figure class="viz residualstreampath" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The residual-stream trajectory through depth, drawn as a 2D shadow whose every
// segment length is the REAL measured per-sub-update path length and whose every
// bend is the REAL measured turning angle (from the probe batch at the final
// checkpoint, scripts/results/.../velocity_ledger.npz via export_velocity_viz.py).
// The true stream is 192-D; this plane is a shadow, but the "shorter and
// straighter" verdict the eye reads is exactly the model's measured verdict.
import { defineViz } from './engine/vizkit.js';
import { grid, panel, dot, T, fmt, gate, loadingText } from './engine/draw.js';
import { loadDepth, VCOL, VLABEL } from './velocityledger.js';

const PAIRS = {
  contrast: ['plain', 'ledger'],
  ngpt: ['ngpt_lite', 'ngpt_ledger'],
};

defineViz('residualstreampath', {
  title: 'The path the residual stream takes through depth: same destination, calmer journey',
  height: 460,
  controls: [
    { type: 'select', name: 'pair', label: 'compare', reset: false, options: [
      { value: 'contrast', label: 'plain vs ledger' },
      { value: 'ngpt', label: 'ngpt-lite vs ngpt-ledger' }], value: 'contrast' },
    { type: 'range', name: 'depth', label: 'sub-update', min: 0, max: 12, step: 1, value: 12, int: true, reset: false, play: { period: 6500, loop: false } },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    gate(api, loadDepth, (api, d) => {
      api.state.d = d;
      // shared bounds across all four variants so lengths compare honestly
      let m = 0;
      for (const k of Object.keys(d.variants)) {
        for (const p of d.variants[k].nodes) m = Math.max(m, Math.abs(p[0]), Math.abs(p[1]));
      }
      api.state.bound = m * 1.08;
    });
  },
  draw(api) {
    const { ctx, colors, size, state: st } = api;
    if (!st || !st.ready) { loadingText(api, 'loading the residual-stream trajectories…'); return; }
    const pair = PAIRS[api.get('pair')];
    const depth = api.get('depth');
    const cells = grid(size.W, size.H, 2, 1, 10);
    const B = st.bound;

    pair.forEach((key, i) => {
      const V = st.d.variants[key];
      const m = panel(ctx, cells[i], colors, { header: 44 });
      T(ctx, colors, 'label', { color: VCOL[key], weight: 'b' });
      ctx.fillText(VLABEL[key], cells[i].x + 10, cells[i].y + 16);
      T(ctx, colors, 'small', { color: colors.muted });
      ctx.fillText(`path length ${fmt(V.path_len, 0)} · mean bend ${fmt(V.mean_turn, 0)}°`, cells[i].x + 10, cells[i].y + 31);

      const px = (p) => [m.cx + (p[0] / B) * m.R, m.cy - (p[1] / B) * m.R];
      ctx.save(); ctx.beginPath();
      ctx.rect(cells[i].x, cells[i].y, cells[i].w, cells[i].h); ctx.clip();
      // faint axes cross
      ctx.strokeStyle = colors.border; ctx.setLineDash([2, 5]); ctx.beginPath();
      ctx.moveTo(m.cx - m.R, m.cy); ctx.lineTo(m.cx + m.R, m.cy);
      ctx.moveTo(m.cx, m.cy - m.R); ctx.lineTo(m.cx, m.cy + m.R); ctx.stroke(); ctx.setLineDash([]);

      const nodes = V.nodes;
      const L = nodes.length - 1;
      const dcur = Math.min(depth, L);
      // the walked path so far
      ctx.strokeStyle = VCOL[key]; ctx.lineWidth = 2.2; ctx.globalAlpha = 0.9;
      ctx.beginPath();
      for (let l = 0; l <= dcur; l++) { const p = px(nodes[l]); l ? ctx.lineTo(p[0], p[1]) : ctx.moveTo(p[0], p[1]); }
      ctx.stroke(); ctx.globalAlpha = 1;
      // the remaining path, ghosted
      ctx.strokeStyle = VCOL[key]; ctx.lineWidth = 1; ctx.globalAlpha = 0.22;
      ctx.beginPath();
      for (let l = dcur; l <= L; l++) { const p = px(nodes[l]); l === dcur ? ctx.moveTo(p[0], p[1]) : ctx.lineTo(p[0], p[1]); }
      ctx.stroke(); ctx.globalAlpha = 1;
      // embedding (start) and current head
      const p0 = px(nodes[0]); dot(ctx, p0[0], p0[1], 3, colors.muted);
      T(ctx, colors, 'small', { color: colors.muted });
      ctx.fillText('embed', p0[0] + 5, p0[1] - 4);
      const ph = px(nodes[dcur]); dot(ctx, ph[0], ph[1], 4.4, VCOL[key]);
      if (dcur === L) {
        T(ctx, colors, 'small', { color: VCOL[key], weight: 'b' });
        ctx.fillText('readout', ph[0] + 6, ph[1] + 2);
      }
      ctx.restore();
    });

    const L = st.d.variants[pair[0]].nodes.length - 1;
    api.readout('rd', `sub-update ${Math.min(depth, L)} of ${L} · a 2D shadow with real segment lengths and real bends · same corpus, same steps, same seeds`);
  },
});
</script>
