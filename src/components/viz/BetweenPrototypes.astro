---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 380 } = Astro.props;
---
<figure class="viz betweenproto" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { grid, panel, unitCircle, dot, text, PALETTE } from './engine/draw.js';

// The information a feature carries is its position BETWEEN the prototypes. As a
// feature moves through the frame, read its soft assignment, the softmax of its
// similarity to each prototype. Between cat and dog it reads "70% cat, 30% dog";
// that vector IS the dark knowledge a teacher distills. The codebook is the basis;
// the information is the coefficients.
const NAMES = ['cat', 'dog', 'car', 'truck'];
const LABG = [0, 0, 1, 1];                                  // animals / vehicles
const PROTO_ANG = [-0.42, 0.42, Math.PI - 0.42, Math.PI + 0.42];
const COLS = i => PALETTE[[0, 2, 1, 3][i]];

defineViz('betweenproto', {
  title: 'A feature lives between the prototypes',
  height: 380, stepsPerFrame: 1,
  controls: [
    { type: 'play' }, { type: 'speed' },
    { type: 'range', name: 'tau', label: 'sharpness τ', min: 2, max: 12, step: 0.5, value: 5, fmt: v => v.toFixed(1) },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) { api.state.theta = 0.42; api.state.trace = []; },
  step(api) {
    api.state.theta += 0.018;
    api.state.trace.push(api.state.theta);
    if (api.state.trace.length > 60) api.state.trace.shift();
  },
  draw(api) {
    const { ctx, colors, size, state } = api;
    const cells = grid(size.W, size.H, 2, 1, 14);
    const th = state.theta, feat = [Math.cos(th), Math.sin(th)];
    // soft assignment = softmax(τ · cos)
    const tau = api.get('tau');
    const logits = PROTO_ANG.map(a => tau * (feat[0] * Math.cos(a) + feat[1] * Math.sin(a)));
    const mx = Math.max(...logits), ex = logits.map(l => Math.exp(l - mx)), Z = ex.reduce((a, b) => a + b, 0);
    const soft = ex.map(e => e / Z);

    // ── left: the frame + the wandering feature ──
    const m = panel(ctx, cells[0], colors, { header: 20 });
    unitCircle(ctx, m, colors);
    // faint trace of the feature path
    ctx.strokeStyle = colors.faint; ctx.globalAlpha = 0.4; ctx.lineWidth = 1; ctx.beginPath();
    state.trace.forEach((t, k) => { const [x, y] = m.map([Math.cos(t), Math.sin(t)]); k ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }); ctx.stroke(); ctx.globalAlpha = 1;
    for (let i = 0; i < 4; i++) {
      const [px, py] = m.map([Math.cos(PROTO_ANG[i]), Math.sin(PROTO_ANG[i])]);
      dot(ctx, px, py, 8, COLS(i)); ctx.lineWidth = 1.8; ctx.strokeStyle = colors.bg; ctx.beginPath(); ctx.arc(px, py, 8, 0, 2 * Math.PI); ctx.stroke();
      text(ctx, NAMES[i], px, py - 14, colors, { align: 'center', size: 10, color: colors.muted });
    }
    const [fx, fy] = m.map(feat);
    ctx.fillStyle = colors.fg; ctx.beginPath(); ctx.arc(fx, fy, 5, 0, 2 * Math.PI); ctx.fill();
    ctx.strokeStyle = colors.bg; ctx.lineWidth = 1.5; ctx.stroke();
    text(ctx, 'a feature moving through the frame', cells[0].x + 8, cells[0].y + 4, colors, { size: 11.5, color: colors.fg });

    // ── right: its soft assignment (= dark knowledge) ──
    const box = cells[1]; panel(ctx, box, colors, {});
    text(ctx, 'soft assignment  (the dark knowledge)', box.x + 10, box.y + 8, colors, { size: 11.5, color: colors.fg });
    const bx = box.x + 70, bw = box.w - 90, top = box.y + 40, rh = (box.h - 90) / 4;
    for (let i = 0; i < 4; i++) {
      const y = top + i * rh;
      text(ctx, NAMES[i], box.x + 14, y + rh * 0.4, colors, { size: 11, color: COLS(i), align: 'left' });
      ctx.fillStyle = colors.cellBg; ctx.fillRect(bx, y, bw, rh * 0.6);
      ctx.fillStyle = COLS(i); ctx.fillRect(bx, y, bw * soft[i], rh * 0.6);
      ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(bx + 0.5, y + 0.5, bw - 1, rh * 0.6 - 1);
      text(ctx, (soft[i] * 100).toFixed(0) + '%', bx + bw * soft[i] + 6, y + rh * 0.3, colors, { size: 10, mono: true, color: colors.muted });
    }
    // region readout
    const animal = soft[0] + soft[1], topName = NAMES[soft.indexOf(Math.max(...soft))];
    const between = Math.max(...soft) < 0.55;
    text(ctx, between ? 'between superclasses, ambiguous, low confidence' : `mostly ${topName}, with a neighbour leaking in`, box.x + 10, box.y + box.h - 16, colors, { size: 10.5, mono: true, color: between ? colors.muted : colors.fg });
    api.readout('rd', `coords: ${soft.map((s, i) => NAMES[i][0] + (s * 100).toFixed(0)).join(' ')}`);
  },
});
</script>
