---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 460 } = Astro.props;
const id = `gl-${Math.random().toString(36).slice(2, 9)}`;
---
<figure class="viz" tabindex="0">
  <div class="viz-cell">
    <h4>Watch the gap open — live</h4>
    <div class="gl-controls">
      <button id={`${id}-play`} class="gl-play" type="button">▶ train</button>
      <button id={`${id}-reset`} class="gl-btn" type="button">restart</button>
      <label>sharpness 1/τ
        <input type="range" id={`${id}-sharp`} min="1" max="8" step="0.5" value="3" />
        <span id={`${id}-sv`} class="gl-n">3</span>
      </label>
      <label>learning rate
        <input type="range" id={`${id}-lr`} min="0.003" max="0.03" step="0.001" value="0.01" />
      </label>
      <label class="gl-toggle"><input type="checkbox" id={`${id}-lines`} checked /> pair lines</label>
      <label>speed <input type="range" id={`${id}-spd`} min="1" max="12" step="1" value="6" /></label>
      <span class="gl-readout" id={`${id}-readout`}></span>
    </div>
    <canvas id={`${id}-c`} height={height} aria-label="Two deep encoders trained live with a SigLIP loss; the two modality embeddings start overlapping and separate into two cones as the modality gap opens"></canvas>
    {caption && <figcaption>{caption}</figcaption>}
  </div>
</figure>

<script is:inline define:vars={{ id }}>
(() => {
  // The modality gap as a LIVE simulation: two small ReLU towers (same init),
  // SigLIP loss, real Adam + hand-written backprop (checked vs finite diffs),
  // mini-batched in the browser. Start overlapping -> the objective opens the gap.
  // Encoding: colour = modality (A / B), shape = class (○ / ✕).
  const D = 16, H = 32, DE = 2, N = 1200, BATCH = 64, NDISP = 420, MAXSTEP = 1400;

  const readColors = () => { const s = getComputedStyle(document.documentElement);
    const v = (n, f) => (s.getPropertyValue(n).trim() || f);
    return { accent: v('--accent', '#b3661b'), blue: '#4a7fb3', muted: v('--fg-muted', '#5a5f66'),
             border: v('--border', '#e4e1d6'), fg: v('--fg', '#1a1a1a'), cellBg: v('--bg-elev', '#fff') }; };
  let colors = readColors();

  const setup = () => {
    const c = document.getElementById(id + '-c'); if (!c || c.dataset.ready) return; c.dataset.ready = '1';
    const ctx = c.getContext('2d');
    const playBtn = document.getElementById(id + '-play'), resetBtn = document.getElementById(id + '-reset');
    const lrInp = document.getElementById(id + '-lr'), linesChk = document.getElementById(id + '-lines');
    const sharpInp = document.getElementById(id + '-sharp'), sv = document.getElementById(id + '-sv');
    const readout = document.getElementById(id + '-readout');
    sharpInp.addEventListener('input', () => { sv.textContent = sharpInp.value; });

    const mat = (r, cc) => Array.from({ length: r }, () => new Float64Array(cc));
    const rng = (() => { let s = 7 >>> 0; return () => { s |= 0; s = (s + 0x6D2B79F5) | 0;
      let t = Math.imul(s ^ (s >>> 15), 1 | s); t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296; }; })();
    const randn = () => { let u = 0, v = 0; while (!u) u = rng(); while (!v) v = rng();
      return Math.sqrt(-2*Math.log(u)) * Math.cos(2*Math.PI*v); };

    // ── data (2 classes, 2 modalities, t independent)
    const cls = new Int8Array(N), tA = new Float64Array(N);
    const lift = () => { const W = []; for (let d = 0; d < D; d++) W.push([randn(), randn()]);
      for (let m = 0; m < 2; m++) { let n = 0; for (let d = 0; d < D; d++) n += W[d][m]*W[d][m]; n = Math.sqrt(n)+1e-9;
        for (let d = 0; d < D; d++) W[d][m] /= n; } const b = []; for (let d = 0; d < D; d++) b.push(randn()*0.1); return { W, b }; };
    const LA = lift(), LB = lift();
    const build = (L, useTA) => { const X = []; for (let i = 0; i < N; i++) {
        if (useTA) { cls[i] = rng() < 0.5 ? 0 : 1; tA[i] = rng()*2 - 1; }
        const k = cls[i], s = (k === 1 ? 1 : -1) + randn()*0.12, t = useTA ? tA[i] : (rng()*2 - 1);
        const row = new Float64Array(D); for (let d = 0; d < D; d++) row[d] = s*L.W[d][0] + t*L.W[d][1] + L.b[d] + randn()*0.08;
        X.push(row); } return X; };
    const Xa = build(LA, true), Xb = build(LB, false);
    const whiten = (X) => { const mu = new Float64Array(D), sd = new Float64Array(D);
      for (let i = 0; i < N; i++) for (let d = 0; d < D; d++) mu[d] += X[i][d]/N;
      for (let i = 0; i < N; i++) for (let d = 0; d < D; d++) sd[d] += (X[i][d]-mu[d])**2/N;
      for (let d = 0; d < D; d++) sd[d] = Math.sqrt(sd[d]) + 1e-6;
      for (let i = 0; i < N; i++) for (let d = 0; d < D; d++) X[i][d] = (X[i][d]-mu[d])/sd[d]; };
    whiten(Xa); whiten(Xb);
    const dispIdx = Array.from({ length: NDISP }, (_, i) => i);

    // ── two ReLU towers (D->H relu -> H->DE), L2-normalised
    const initTower = () => ({ W1: mat(D, H), b1: new Float64Array(H), W2: mat(H, DE), b2: new Float64Array(DE),
                               sW1: { m: mat(D, H), v: mat(D, H) }, sb1: { m: new Float64Array(H), v: new Float64Array(H) },
                               sW2: { m: mat(H, DE), v: mat(H, DE) }, sb2: { m: new Float64Array(DE), v: new Float64Array(DE) } });
    let TA, TB, bias, sB, step;   // logit scale (sharpness) is user-set, not trained
    const reset = () => {
      // SAME init for both towers -> no gap at step 0
      const W1 = mat(D, H), W2 = mat(H, DE);
      for (let d = 0; d < D; d++) for (let j = 0; j < H; j++) W1[d][j] = randn()*Math.sqrt(2/D);
      for (let j = 0; j < H; j++) for (let e = 0; e < DE; e++) W2[j][e] = randn()*Math.sqrt(2/H);
      TA = initTower(); TB = initTower();
      for (let d = 0; d < D; d++) for (let j = 0; j < H; j++) { TA.W1[d][j] = W1[d][j]; TB.W1[d][j] = W1[d][j]; }
      for (let j = 0; j < H; j++) for (let e = 0; e < DE; e++) { TA.W2[j][e] = W2[j][e]; TB.W2[j][e] = W2[j][e]; }
      bias = -1.0; sB = { m: 0, v: 0 }; step = 0;
    };

    const fwd = (T, X, idx) => { const n = idx.length, h = mat(n, H), z = mat(n, DE), nrm = new Float64Array(n), rm = mat(n, H);
      for (let q = 0; q < n; q++) { const i = idx[q];
        for (let j = 0; j < H; j++) { let s = T.b1[j]; for (let d = 0; d < D; d++) s += X[i][d]*T.W1[d][j]; rm[q][j] = s > 0 ? 1 : 0; h[q][j] = s > 0 ? s : 0; }
        const zp = new Float64Array(DE); for (let e = 0; e < DE; e++) { let s = T.b2[e]; for (let j = 0; j < H; j++) s += h[q][j]*T.W2[j][e]; zp[e] = s; }
        let nn = 0; for (let e = 0; e < DE; e++) nn += zp[e]*zp[e]; nn = Math.sqrt(nn)+1e-9; nrm[q] = nn;
        for (let e = 0; e < DE; e++) z[q][e] = zp[e]/nn; }
      return { h, z, nrm, rm }; };

    const zeroG = () => ({ W1: mat(D, H), b1: new Float64Array(H), W2: mat(H, DE), b2: new Float64Array(DE) });
    const bwd = (T, X, idx, F, dZ, G) => { const n = idx.length;
      for (let q = 0; q < n; q++) { const i = idx[q], nn = F.nrm[q]; let zdg = 0; for (let e = 0; e < DE; e++) zdg += F.z[q][e]*dZ[q][e];
        const dzp = new Float64Array(DE); for (let e = 0; e < DE; e++) dzp[e] = (dZ[q][e] - F.z[q][e]*zdg)/nn;
        const dh = new Float64Array(H);
        for (let e = 0; e < DE; e++) { G.b2[e] += dzp[e]; for (let j = 0; j < H; j++) { G.W2[j][e] += F.h[q][j]*dzp[e]; dh[j] += T.W2[j][e]*dzp[e]; } }
        for (let j = 0; j < H; j++) { if (!F.rm[q][j]) continue; const g = dh[j]; G.b1[j] += g; for (let d = 0; d < D; d++) G.W1[d][j] += X[i][d]*g; } } };

    const sig = (x) => 1/(1 + Math.exp(-x));
    const softplus = (x) => x > 30 ? x : Math.log1p(Math.exp(-Math.abs(x))) + Math.max(x, 0);
    const B1 = 0.9, B2 = 0.999, EPS = 1e-8;
    const adamMat = (W, G, S, r, cc, lr, bc1, bc2) => { for (let a = 0; a < r; a++) for (let b = 0; b < cc; b++) {
        S.m[a][b] = B1*S.m[a][b] + (1-B1)*G[a][b]; S.v[a][b] = B2*S.v[a][b] + (1-B2)*G[a][b]**2;
        W[a][b] -= lr*(S.m[a][b]/bc1)/(Math.sqrt(S.v[a][b]/bc2)+EPS); } };
    const adamVec = (W, G, S, n, lr, bc1, bc2) => { for (let b = 0; b < n; b++) {
        S.m[b] = B1*S.m[b] + (1-B1)*G[b]; S.v[b] = B2*S.v[b] + (1-B2)*G[b]**2;
        W[b] -= lr*(S.m[b]/bc1)/(Math.sqrt(S.v[b]/bc2)+EPS); } };

    const trainStep = (lr) => {
      const idx = new Array(BATCH); for (let b = 0; b < BATCH; b++) idx[b] = (rng()*N) | 0;
      const A = fwd(TA, Xa, idx), Bf = fwd(TB, Xb, idx), t = parseFloat(sharpInp.value), n = BATCH, inv = 1/(n*n);
      const dZa = mat(n, DE), dZb = mat(n, DE); let dbias = 0;
      for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) { let dp = 0; for (let e = 0; e < DE; e++) dp += A.z[i][e]*Bf.z[j][e];
        const S = t*dp + bias, Y = i === j ? 1 : -1; const g = -Y*sig(-Y*S)*inv; dbias += g; const gt = g*t;
        for (let e = 0; e < DE; e++) { dZa[i][e] += gt*Bf.z[j][e]; dZb[j][e] += gt*A.z[i][e]; } }
      const GA = zeroG(), GB = zeroG(); bwd(TA, Xa, idx, A, dZa, GA); bwd(TB, Xb, idx, Bf, dZb, GB);
      step++; const bc1 = 1 - Math.pow(B1, step), bc2 = 1 - Math.pow(B2, step);
      adamMat(TA.W1, GA.W1, TA.sW1, D, H, lr, bc1, bc2); adamVec(TA.b1, GA.b1, TA.sb1, H, lr, bc1, bc2);
      adamMat(TA.W2, GA.W2, TA.sW2, H, DE, lr, bc1, bc2); adamVec(TA.b2, GA.b2, TA.sb2, DE, lr, bc1, bc2);
      adamMat(TB.W1, GB.W1, TB.sW1, D, H, lr, bc1, bc2); adamVec(TB.b1, GB.b1, TB.sb1, H, lr, bc1, bc2);
      adamMat(TB.W2, GB.W2, TB.sW2, H, DE, lr, bc1, bc2); adamVec(TB.b2, GB.b2, TB.sb2, DE, lr, bc1, bc2);
      sB.m = B1*sB.m + (1-B1)*dbias; sB.v = B2*sB.v + (1-B2)*dbias**2; bias -= lr*(sB.m/bc1)/(Math.sqrt(sB.v/bc2)+EPS);
    };

    const st = { dpr: 1, w: 0, h: 0, za: null, zb: null, gap: 0, mc: 0, playing: false, raf: 0, hist: [] };
    const refresh = () => { const A = fwd(TA, Xa, dispIdx), Bf = fwd(TB, Xb, dispIdx); st.za = A.z; st.zb = Bf.z;
      const ma = new Float64Array(DE), mb = new Float64Array(DE);
      for (let q = 0; q < NDISP; q++) for (let e = 0; e < DE; e++) { ma[e] += A.z[q][e]/NDISP; mb[e] += Bf.z[q][e]/NDISP; }
      let g = 0, mc = 0; for (let e = 0; e < DE; e++) g += (ma[e]-mb[e])**2;
      for (let q = 0; q < NDISP; q++) { let dp = 0; for (let e = 0; e < DE; e++) dp += A.z[q][e]*Bf.z[q][e]; mc += dp/NDISP; }
      st.gap = Math.sqrt(g); st.mc = mc;
      st.hist.push([st.gap, st.mc]); if (st.hist.length > 500) st.hist.shift(); };

    const draw = () => { const W = st.w, Hh = st.h; if (W === 0 || !st.za) return;
      ctx.setTransform(st.dpr, 0, 0, st.dpr, 0, 0); ctx.clearRect(0, 0, W, Hh);
      const pad = 16, side = Math.min(W - 2*pad, Hh - 2*pad), ox = (W-side)/2, oy = (Hh-side)/2;
      ctx.fillStyle = colors.cellBg; ctx.fillRect(ox, oy, side, side);
      ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(ox+0.5, oy+0.5, side-1, side-1);
      const cx = ox + side/2, cy = oy + side/2, R = side*0.42, r = 2.8;
      ctx.beginPath(); ctx.arc(cx, cy, R, 0, 2*Math.PI); ctx.strokeStyle = colors.border; ctx.stroke();
      const px = (p) => cx + p[0]*R, py = (p) => cy - p[1]*R;
      if (linesChk.checked) { ctx.strokeStyle = colors.muted; ctx.lineWidth = 0.5; ctx.globalAlpha = 0.22; ctx.beginPath();
        const stp = Math.max(1, Math.floor(NDISP/16));
        for (let q = 0; q < NDISP; q += stp) { ctx.moveTo(px(st.za[q]), py(st.za[q])); ctx.lineTo(px(st.zb[q]), py(st.zb[q])); }
        ctx.stroke(); ctx.globalAlpha = 1; }
      const drawSet = (Z, col) => { ctx.fillStyle = col; ctx.strokeStyle = col; ctx.lineWidth = 1.3;
        for (let q = 0; q < NDISP; q++) { const x = px(Z[q]), y = py(Z[q]), k = cls[dispIdx[q]];
          if (k === 0) { ctx.beginPath(); ctx.arc(x, y, r, 0, 2*Math.PI); ctx.fill(); }
          else { ctx.beginPath(); ctx.moveTo(x-r, y-r); ctx.lineTo(x+r, y+r); ctx.moveTo(x+r, y-r); ctx.lineTo(x-r, y+r); ctx.stroke(); } } };
      drawSet(st.za, colors.blue); drawSet(st.zb, colors.accent);

      // live gap-vs-step sparkline (top-right inset)
      const sw = side*0.36, sh = side*0.18, sx = ox + side - sw - 10, sy = oy + 10;
      ctx.fillStyle = colors.cellBg; ctx.fillRect(sx, sy, sw, sh);
      ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(sx+0.5, sy+0.5, sw-1, sh-1);
      const mid = sy + sh*0.5;
      ctx.strokeStyle = colors.border; ctx.setLineDash([2, 2]); ctx.beginPath(); ctx.moveTo(sx, mid); ctx.lineTo(sx+sw, mid); ctx.stroke(); ctx.setLineDash([]);
      const hh = st.hist;
      if (hh.length > 1) {
        const plot = (sel, col) => { ctx.strokeStyle = col; ctx.lineWidth = 1.5; ctx.beginPath();
          for (let i = 0; i < hh.length; i++) { const x = sx + (i/(hh.length-1))*sw;
            const y = mid - sel(hh[i])*(sh*0.46); i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); } ctx.stroke(); };
        plot(h => Math.min(1, h[0]/2), colors.accent);   // gap (0..2)  -> upper half
        plot(h => Math.max(-1, Math.min(1, h[1])), colors.blue);  // matched cosine (-1..1)
      }
      ctx.fillStyle = colors.muted; ctx.font = '9px ui-monospace, monospace'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText('gap', sx+3, sy+2); ctx.fillStyle = colors.blue; ctx.fillText('matched cos', sx+3, sy+sh-12);

      ctx.font = '11px ui-sans-serif, system-ui'; ctx.textBaseline = 'middle'; ctx.textAlign = 'left';
      const ly = oy + side - 40;
      ctx.fillStyle = colors.blue; ctx.beginPath(); ctx.arc(ox+14, ly, 4, 0, 6.3); ctx.fill();
      ctx.fillStyle = colors.muted; ctx.fillText('modality A', ox+24, ly);
      ctx.fillStyle = colors.accent; ctx.beginPath(); ctx.arc(ox+14, ly+14, 4, 0, 6.3); ctx.fill();
      ctx.fillStyle = colors.muted; ctx.fillText('modality B', ox+24, ly+14);
      ctx.fillStyle = colors.muted; ctx.beginPath(); ctx.arc(ox+14, ly+28, 3, 0, 6.3); ctx.fill();
      ctx.fillText('class 0 ○   class 1 ✕', ox+24, ly+28);
      readout.textContent = `step ${step}  ·  gap ${st.gap.toFixed(2)}  ·  matched cos ${st.mc>=0?'+':''}${st.mc.toFixed(2)}`;
    };

    const tick = () => { if (!st.playing) return; const lr = parseFloat(lrInp.value);
      for (let s = 0, K = +document.getElementById(id + '-spd').value; s < K; s++) trainStep(lr); refresh(); draw();
      if (step >= MAXSTEP) stop(); else st.raf = requestAnimationFrame(tick); };
    const stop = () => { st.playing = false; playBtn.textContent = '▶ train'; cancelAnimationFrame(st.raf); };
    const play = () => { if (step >= MAXSTEP) doReset(); st.playing = true; playBtn.textContent = '❚❚ pause'; st.raf = requestAnimationFrame(tick); };
    const doReset = () => { stop(); reset(); st.hist = []; refresh(); draw(); };

    playBtn.addEventListener('click', () => (st.playing ? stop() : play()));
    resetBtn.addEventListener('click', doReset);
    linesChk.addEventListener('change', draw);

    const fit = () => { const rect = c.getBoundingClientRect();
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      st.dpr = dpr; st.w = rect.width; st.h = rect.height;
      c.width = Math.round(rect.width*dpr); c.height = Math.round(rect.height*dpr); };

    reset(); refresh();
    const themeObs = new MutationObserver(() => { colors = readColors(); draw(); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    const ro = new ResizeObserver(() => { fit(); draw(); }); ro.observe(c);
    let kicked = false;
    const io = new IntersectionObserver((e) => { if (e[0].isIntersecting) { fit(); draw();
      if (!kicked) { kicked = true; play(); } } else stop(); }, { rootMargin: '0px' });
    io.observe(c);
  };

  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:after-swap', setup);
})();
</script>

<style>
.gl-controls { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; padding: 6px 0 10px; }
.gl-play { background: var(--accent); color: #fff; border: none; border-radius: 5px; padding: 4px 12px; font-size: 12px; cursor: pointer; font-family: inherit; min-width: 78px; }
.gl-btn { background: var(--bg-elev, #fff); color: var(--fg-muted); border: 1px solid var(--border); border-radius: 5px; padding: 4px 10px; font-size: 12px; cursor: pointer; font-family: inherit; }
.gl-controls label { display: inline-flex; align-items: center; gap: 6px; color: var(--fg-muted); font-size: 12px; }
.gl-controls input[type="range"] { accent-color: var(--accent); width: 92px; }
.gl-n { font-family: ui-monospace, monospace; font-size: 11px; color: var(--fg-muted); }
.gl-toggle input { accent-color: var(--accent); }
.gl-readout { margin-left: auto; font-family: ui-monospace, monospace; font-size: 11px; color: var(--fg-muted); white-space: nowrap; }
.viz-cell canvas { width: 100%; display: block; }
</style>
