---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 380 } = Astro.props;
---
<figure class="viz coeffmeter" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { panel, text, parseColor, PALETTE } from './engine/draw.js';
import { np, nn, withJax, drawJaxLoading } from './engine/jax.js';

const LABELS = ['cat', 'dog', 'car'];
const tri = [[0, -0.95], [0.85, 0.52], [-0.85, 0.52]];

function mixColor(w, colors) {
  const base = parseColor(colors.cellBg);
  const cols = [parseColor(PALETTE[0]), parseColor(PALETTE[2]), parseColor(PALETTE[1])];
  const rgb = [0, 1, 2].map(k => w[0] * cols[0][k] + w[1] * cols[1][k] + w[2] * cols[2][k]);
  return `rgb(${Math.round(base[0] + (rgb[0] - base[0]) * 0.95)},${Math.round(base[1] + (rgb[1] - base[1]) * 0.95)},${Math.round(base[2] + (rgb[2] - base[2]) * 0.95)})`;
}

function weights(t, tau) {
  const p = [
    0.5 + 0.36 * Math.cos(t * Math.PI * 2),
    0.5 + 0.36 * Math.cos(t * Math.PI * 2 - 2.1),
    0.5 + 0.36 * Math.cos(t * Math.PI * 2 - 4.2),
  ];
  return nn.softmax(np.array(p.map(v => tau * v))).js();
}

defineViz('coeffmeter', {
  title: 'Dark knowledge is a coefficient vector',
  height: 380,
  controls: [
    { type: 'range', name: 'pos', label: 'feature position', min: 0, max: 1, step: 0.005, value: 0.18, fmt: v => v.toFixed(2) },
    { type: 'range', name: 'tau', label: 'softmax sharpness', min: 0.8, max: 8, step: 0.1, value: 2.0, fmt: v => v.toFixed(1) },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    withJax(api);
  },
  draw(api) {
    if (!api.state.jaxReady) return drawJaxLoading(api);
    const { ctx, colors, size } = api;
    const box = { x: 6, y: 4, w: size.W - 12, h: size.H - 8 };
    panel(ctx, box, colors, {});
    const left = { x: box.x + 8, y: box.y + 28, w: box.w * 0.52, h: box.h - 52 };
    const right = { x: box.x + box.w * 0.58, y: box.y + 42, w: box.w * 0.36, h: box.h - 92 };
    const w = weights(api.get('pos'), api.get('tau'));
    const pxModel = tri.reduce((a, p, i) => [a[0] + w[i] * p[0], a[1] + w[i] * p[1]], [0, 0]);
    const cx = left.x + left.w / 2, cy = left.y + left.h / 2, R = Math.min(left.w, left.h) * 0.42;
    const xy = p => [cx + p[0] * R, cy + p[1] * R];

    ctx.strokeStyle = colors.border; ctx.lineWidth = 1.2;
    ctx.beginPath(); ctx.moveTo(...xy(tri[0])); ctx.lineTo(...xy(tri[1])); ctx.lineTo(...xy(tri[2])); ctx.closePath(); ctx.stroke();
    for (let i = 0; i < 3; i++) {
      const [x, y] = xy(tri[i]);
      ctx.fillStyle = PALETTE[[0, 2, 1][i]]; ctx.beginPath(); ctx.arc(x, y, 8, 0, 2 * Math.PI); ctx.fill();
      ctx.strokeStyle = colors.bg; ctx.lineWidth = 2; ctx.stroke();
      text(ctx, LABELS[i], x, y + (i === 0 ? -24 : 16), colors, { align: 'center', size: 11, weight: '600', color: PALETTE[[0, 2, 1][i]] });
    }
    const [fx, fy] = xy(pxModel);
    ctx.strokeStyle = colors.fg; ctx.setLineDash([3, 3]);
    for (let i = 0; i < 3; i++) { const [x, y] = xy(tri[i]); ctx.beginPath(); ctx.moveTo(fx, fy); ctx.lineTo(x, y); ctx.stroke(); }
    ctx.setLineDash([]);
    ctx.fillStyle = mixColor(w, colors); ctx.beginPath(); ctx.arc(fx, fy, 12, 0, 2 * Math.PI); ctx.fill();
    ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.5; ctx.stroke();

    text(ctx, 'projection onto the prototype frame', box.x + 10, box.y + 8, colors, { size: 12, weight: '600', color: colors.fg });
    text(ctx, 'soft assignment', right.x, right.y - 24, colors, { size: 12, weight: '600', color: colors.fg });
    for (let i = 0; i < 3; i++) {
      const y = right.y + i * 62, bw = right.w * w[i];
      ctx.fillStyle = PALETTE[[0, 2, 1][i]]; ctx.fillRect(right.x, y + 20, bw, 16);
      ctx.strokeStyle = colors.border; ctx.strokeRect(right.x + 0.5, y + 20.5, right.w - 1, 15);
      text(ctx, LABELS[i], right.x, y, colors, { size: 11, color: colors.muted });
      text(ctx, `${Math.round(w[i] * 100)}%`, right.x + right.w + 10, y + 18, colors, { size: 11, mono: true, color: colors.fg });
    }
    const entropy = -w.reduce((a, v) => a + v * Math.log2(v + 1e-12), 0);
    text(ctx, `entropy ${entropy.toFixed(2)} bits`, right.x, right.y + 205, colors, { size: 18, weight: '700', color: entropy > 1.1 ? colors.accent : colors.muted });
    text(ctx, api.get('tau') > 5 ? 'sharp logits: the vector becomes nearly one-hot' : 'soft logits: the relation survives in the coefficients', box.x + 10, box.y + box.h - 18, colors, { size: 10, mono: true, color: colors.muted });
    api.readout('rd', `${LABELS.map((l, i) => `${l} ${Math.round(100 * w[i])}%`).join(' · ')}`);
  },
});
</script>
