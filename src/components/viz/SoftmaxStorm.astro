---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 340 } = Astro.props;
---
<figure class="viz softmaxstorm" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { drawStormPanel, fmt, MAX_N } from './engine/storm.js';

defineViz('softmaxstorm', {
  height: 340,
  minHeight: 280,
  maxHeight: 440,
  maxStep: 720,
  controls: [
    { type: 'play' },
    { type: 'step', label: 'Tick' },
    { type: 'reset' },
    { type: 'speed', presets: [0.5, 1, 2, 4] },
    { type: 'newrow' },
    { type: 'range', name: 'N', label: 'tokens N', min: 16, max: MAX_N, step: 8, value: 64, int: true, reset: false },
    { type: 'readout', name: 'ro' },
  ],
  setup() {},
  step() {},
  draw(api) {
    const { ctx, colors, size } = api;
    const W = size.W, H = size.H;
    if (!W || !H) return;
    const N = api.get('N');
    const box = { x: 12, y: 8, w: W - 24, h: H - 16 };
    drawStormPanel(ctx, box, colors, api.iter, N);
    api.readout('ro', `N=${N} · ${fmt(N * N)} pair scores (N²)`);
  },
});
</script>
