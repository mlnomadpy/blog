---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 640 } = Astro.props;
---
<figure class="viz contrastiverace" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { rng32 } from './engine/datasets.js';
import { PALETTE } from './engine/draw.js';

// Eight contrastive losses optimised in-place on the SAME 2-D dataset, side by
// side. Each panel owns a copy of the points; its step() mutates them and
// returns the loss. Boilerplate (controls, loop, speed, resize, theme,
// visibility, keyboard) lives in vizkit, this file is just the losses + draw.
const randn = (rng) => { let u = 0, v = 0; while (u === 0) u = rng(); while (v === 0) v = rng(); return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v); };

const makeData = (kind, n, seed) => {
  const rng = rng32(seed); const pts = [], labels = [];
  if (kind === 'moons') {
    const half = Math.floor(n / 2);
    for (let i = 0; i < half; i++) { const t = Math.PI * (i / (half - 1)); pts.push([Math.cos(t) + randn(rng) * 0.07, Math.sin(t) + randn(rng) * 0.07]); labels.push(0); }
    for (let i = 0; i < n - half; i++) { const t = Math.PI * (i / (n - half - 1)); pts.push([1 - Math.cos(t) + randn(rng) * 0.07, 0.4 - Math.sin(t) + randn(rng) * 0.07]); labels.push(1); }
  } else if (kind === 'blobs') {
    const half = Math.floor(n / 2);
    for (let i = 0; i < half; i++) { pts.push([0.3 + randn(rng) * 0.4, 0.0 + randn(rng) * 0.4]); labels.push(0); }
    for (let i = 0; i < n - half; i++) { pts.push([-0.3 + randn(rng) * 0.4, 0.0 + randn(rng) * 0.4]); labels.push(1); }
  } else if (kind === 'rings') {
    const half = Math.floor(n / 2);
    for (let i = 0; i < half; i++) { const t = 2 * Math.PI * rng(); pts.push([0.4 * Math.cos(t) + randn(rng) * 0.05, 0.4 * Math.sin(t) + randn(rng) * 0.05]); labels.push(0); }
    for (let i = 0; i < n - half; i++) { const t = 2 * Math.PI * rng(); pts.push([1.1 * Math.cos(t) + randn(rng) * 0.05, 1.1 * Math.sin(t) + randn(rng) * 0.05]); labels.push(1); }
  } else if (kind === 'four') {
    const per = Math.floor(n / 4); const centers = [[0.6, 0.6], [-0.6, 0.6], [-0.6, -0.6], [0.6, -0.6]];
    for (let c = 0; c < 4; c++) { const k = (c === 3) ? (n - 3 * per) : per; for (let i = 0; i < k; i++) { pts.push([centers[c][0] + randn(rng) * 0.18, centers[c][1] + randn(rng) * 0.18]); labels.push(c); } }
  } else { // random / random-4
    const k = (kind === 'random-4') ? 4 : 2;
    for (let i = 0; i < n; i++) { pts.push([(rng() * 2 - 1) * 1.5, (rng() * 2 - 1) * 1.5]); labels.push(i % k); }
    for (let i = n - 1; i > 0; i--) { const j = Math.floor(rng() * (i + 1)); [labels[i], labels[j]] = [labels[j], labels[i]]; }
  }
  return { pts, labels };
};

// ── losses: each mutates pts in place and returns its loss value ──
const projectSphere = (pts) => { for (let i = 0; i < pts.length; i++) { const n = Math.hypot(pts[i][0], pts[i][1]) + 1e-9; pts[i][0] /= n; pts[i][1] /= n; } };
const applyGrad = (pts, grad, lr, n) => { for (let i = 0; i < pts.length; i++) { pts[i][0] -= lr * grad[i][0] / n; pts[i][1] -= lr * grad[i][1] / n; } };
const newGrad = (n) => { const g = new Array(n); for (let i = 0; i < n; i++) g[i] = [0, 0]; return g; };

const stepHadsell = (pts, labels, lr) => {
  const n = pts.length, margin = 1.2; const grad = newGrad(n); let loss = 0, m = 0;
  for (let i = 0; i < n; i++) for (let j = i + 1; j < n; j++) {
    const dx = pts[i][0] - pts[j][0], dy = pts[i][1] - pts[j][1]; const d2 = dx * dx + dy * dy; const d = Math.sqrt(d2 + 1e-9);
    if (labels[i] === labels[j]) { loss += d2; m++; grad[i][0] += 2 * dx; grad[i][1] += 2 * dy; grad[j][0] -= 2 * dx; grad[j][1] -= 2 * dy; }
    else if (d < margin) { loss += (margin - d) * (margin - d); m++; const f = -2 * (margin - d) / d; grad[i][0] += f * dx; grad[i][1] += f * dy; grad[j][0] -= f * dx; grad[j][1] -= f * dy; }
  }
  applyGrad(pts, grad, lr, n); return m ? loss / m : 0;
};

const stepTriplet = (pts, labels, lr, rng) => {
  const n = pts.length, margin = 0.3; const grad = newGrad(n); let loss = 0, cnt = 0;
  const byClass = {}; for (let i = 0; i < n; i++) (byClass[labels[i]] = byClass[labels[i]] || []).push(i);
  for (let i = 0; i < n; i++) {
    const pos = byClass[labels[i]].filter((j) => j !== i); const neg = []; for (const k in byClass) if (+k !== labels[i]) for (const j of byClass[k]) neg.push(j);
    if (!pos.length || !neg.length) continue;
    const p = pos[Math.floor(rng() * pos.length)]; const nd = neg[Math.floor(rng() * neg.length)];
    const dap = (pts[i][0] - pts[p][0]) ** 2 + (pts[i][1] - pts[p][1]) ** 2; const dan = (pts[i][0] - pts[nd][0]) ** 2 + (pts[i][1] - pts[nd][1]) ** 2;
    const slack = dap - dan + margin;
    if (slack > 0) { loss += slack; cnt++; grad[i][0] += 2 * (pts[nd][0] - pts[p][0]); grad[i][1] += 2 * (pts[nd][1] - pts[p][1]); grad[p][0] -= 2 * (pts[i][0] - pts[p][0]); grad[p][1] -= 2 * (pts[i][1] - pts[p][1]); grad[nd][0] += 2 * (pts[i][0] - pts[nd][0]); grad[nd][1] += 2 * (pts[i][1] - pts[nd][1]); }
  }
  applyGrad(pts, grad, lr, n); return cnt ? loss / cnt : 0;
};

const stepInfoNCE = (pts, labels, lr, rng) => {
  const n = pts.length, tau = 0.2; const grad = newGrad(n); projectSphere(pts); let loss = 0;
  const sim = []; for (let i = 0; i < n; i++) { sim[i] = []; for (let j = 0; j < n; j++) sim[i][j] = (pts[i][0] * pts[j][0] + pts[i][1] * pts[j][1]) / tau; }
  const byClass = {}; for (let i = 0; i < n; i++) (byClass[labels[i]] = byClass[labels[i]] || []).push(i);
  for (let i = 0; i < n; i++) {
    const pos = byClass[labels[i]].filter((j) => j !== i); if (!pos.length) continue;
    const p = pos[Math.floor(rng() * pos.length)];
    let mx = -Infinity; for (let j = 0; j < n; j++) if (j !== i) if (sim[i][j] > mx) mx = sim[i][j];
    let denom = 0; const w = new Array(n).fill(0); for (let j = 0; j < n; j++) if (j !== i) { w[j] = Math.exp(sim[i][j] - mx); denom += w[j]; }
    loss += -(sim[i][p] - mx - Math.log(denom));
    let gx = 0, gy = 0; for (let j = 0; j < n; j++) { if (j === i) continue; const pij = w[j] / denom; gx += pij * pts[j][0]; gy += pij * pts[j][1]; }
    gx -= pts[p][0]; gy -= pts[p][1]; grad[i][0] += gx / tau; grad[i][1] += gy / tau;
  }
  applyGrad(pts, grad, lr, n); projectSphere(pts); return loss / n;
};

const stepSupCon = (pts, labels, lr) => {
  const n = pts.length, tau = 0.2; const grad = newGrad(n); projectSphere(pts); let loss = 0;
  const sim = []; for (let i = 0; i < n; i++) { sim[i] = []; for (let j = 0; j < n; j++) sim[i][j] = (pts[i][0] * pts[j][0] + pts[i][1] * pts[j][1]) / tau; }
  const byClass = {}; for (let i = 0; i < n; i++) (byClass[labels[i]] = byClass[labels[i]] || []).push(i);
  for (let i = 0; i < n; i++) {
    const P = byClass[labels[i]].filter((j) => j !== i); if (!P.length) continue;
    let mx = -Infinity; for (let j = 0; j < n; j++) if (j !== i) if (sim[i][j] > mx) mx = sim[i][j];
    let denom = 0; const w = new Array(n).fill(0); for (let j = 0; j < n; j++) if (j !== i) { w[j] = Math.exp(sim[i][j] - mx); denom += w[j]; }
    let lloss = 0; for (const p of P) lloss += -(sim[i][p] - mx - Math.log(denom)); lloss /= P.length; loss += lloss;
    let gx = 0, gy = 0; for (let j = 0; j < n; j++) { if (j === i) continue; const pij = w[j] / denom; gx += pij * pts[j][0]; gy += pij * pts[j][1]; }
    let pmx = 0, pmy = 0; for (const p of P) { pmx += pts[p][0]; pmy += pts[p][1]; } pmx /= P.length; pmy /= P.length;
    gx -= pmx; gy -= pmy; grad[i][0] += gx / tau; grad[i][1] += gy / tau;
  }
  applyGrad(pts, grad, lr, n); projectSphere(pts); return loss / n;
};

const stepAlignUnif = (pts, labels, lr) => {
  const n = pts.length, t = 2.0, lam = 1.0; const grad = newGrad(n); projectSphere(pts); let lossA = 0, lossU = 0, pairsA = 0;
  for (let i = 0; i < n; i++) for (let j = i + 1; j < n; j++) {
    if (labels[i] !== labels[j]) continue; const dx = pts[i][0] - pts[j][0], dy = pts[i][1] - pts[j][1]; lossA += dx * dx + dy * dy; pairsA++;
    grad[i][0] += 2 * dx; grad[i][1] += 2 * dy; grad[j][0] -= 2 * dx; grad[j][1] -= 2 * dy;
  }
  let sumExp = 0; const E = [];
  for (let i = 0; i < n; i++) for (let j = i + 1; j < n; j++) { const dx = pts[i][0] - pts[j][0], dy = pts[i][1] - pts[j][1]; const d2 = dx * dx + dy * dy; const e = Math.exp(-t * d2); E.push([i, j, e, dx, dy]); sumExp += e; }
  lossU = Math.log(sumExp / E.length + 1e-12);
  for (const [i, j, e, dx, dy] of E) { const fac = (lam * (-t)) * (e / sumExp); grad[i][0] += fac * 2 * dx; grad[i][1] += fac * 2 * dy; grad[j][0] -= fac * 2 * dx; grad[j][1] -= fac * 2 * dy; }
  applyGrad(pts, grad, lr, n); projectSphere(pts); return (pairsA ? lossA / pairsA : 0) + lam * lossU;
};

const stepOrthog = (pts, labels, lr) => {
  const n = pts.length; const grad = newGrad(n); projectSphere(pts); let loss = 0;
  for (let i = 0; i < n; i++) for (let j = i + 1; j < n; j++) {
    const c = pts[i][0] * pts[j][0] + pts[i][1] * pts[j][1];
    if (labels[i] === labels[j]) { loss += 1 - c; grad[i][0] += -pts[j][0]; grad[i][1] += -pts[j][1]; grad[j][0] += -pts[i][0]; grad[j][1] += -pts[i][1]; }
    else { loss += c * c; grad[i][0] += 2 * c * pts[j][0]; grad[i][1] += 2 * c * pts[j][1]; grad[j][0] += 2 * c * pts[i][0]; grad[j][1] += 2 * c * pts[i][1]; }
  }
  applyGrad(pts, grad, lr, n); projectSphere(pts); return loss / (n * (n - 1) / 2);
};

const stepCLIP = (pts, labels, lr) => {
  const n = pts.length, tau = 0.2; const grad = newGrad(n); projectSphere(pts); let loss = 0;
  const sim = []; for (let i = 0; i < n; i++) { sim[i] = []; for (let j = 0; j < n; j++) sim[i][j] = (pts[i][0] * pts[j][0] + pts[i][1] * pts[j][1]) / tau; }
  const byClass = {}; for (let i = 0; i < n; i++) (byClass[labels[i]] = byClass[labels[i]] || []).push(i);
  const oneDir = (a, pp) => {
    let mx = -Infinity; for (let j = 0; j < n; j++) if (j !== a && sim[a][j] > mx) mx = sim[a][j];
    let denom = 0; const w = new Array(n).fill(0); for (let j = 0; j < n; j++) if (j !== a) { w[j] = Math.exp(sim[a][j] - mx); denom += w[j]; }
    loss += 0.5 * -(sim[a][pp] - mx - Math.log(denom));
    let gx = 0, gy = 0; for (let j = 0; j < n; j++) { if (j === a) continue; const pij = w[j] / denom; gx += pij * pts[j][0]; gy += pij * pts[j][1]; }
    gx -= pts[pp][0]; gy -= pts[pp][1]; grad[a][0] += 0.5 * gx / tau; grad[a][1] += 0.5 * gy / tau;
  };
  for (let i = 0; i < n; i++) { const pos = byClass[labels[i]].filter((j) => j !== i); if (!pos.length) continue; const pp = pos[Math.floor(rng() * pos.length)]; oneDir(i, pp); oneDir(pp, i); }
  applyGrad(pts, grad, lr, n); projectSphere(pts); return loss / n;
};

const stepSigLIP = (pts, labels, lr) => {
  const n = pts.length, target = -0.05, t = 10.0, b = -t * target; const grad = newGrad(n); projectSphere(pts); let loss = 0;
  for (let i = 0; i < n; i++) for (let j = i + 1; j < n; j++) {
    const y_ij = (labels[i] === labels[j]) ? 1 : -1; const s = pts[i][0] * pts[j][0] + pts[i][1] * pts[j][1]; const arg = t * s + b; const z = -y_ij * arg;
    let lz; if (z > 30) lz = z; else if (z < -30) lz = 0; else lz = Math.log(1 + Math.exp(z)); loss += lz;
    const sig = 1 / (1 + Math.exp(-z)); const dsim = -y_ij * t * sig;
    grad[i][0] += dsim * pts[j][0]; grad[i][1] += dsim * pts[j][1]; grad[j][0] += dsim * pts[i][0]; grad[j][1] += dsim * pts[i][1];
  }
  applyGrad(pts, grad, lr, n); projectSphere(pts); return loss / (n * (n - 1) / 2);
};
// stepCLIP/stepTriplet/stepInfoNCE pull a random positive each step; give them a closure rng
let rng = rng32(1);

const LOSSES = [
  { id: 'hadsell', name: 'Pair (Hadsell, 2006)', sub: 'L = d²₊ + max(0, m−d₋)²', step: stepHadsell, lr: 0.4, onSphere: false },
  { id: 'triplet', name: 'Triplet (FaceNet, 2015)', sub: 'L = max(0, d²ₐₚ − d²ₐₙ + m)', step: stepTriplet, lr: 0.4, onSphere: false },
  { id: 'infonce', name: 'InfoNCE / NT-Xent (2018)', sub: '−log eᶜᵒˢᐟᵗ / Σ eᶜᵒˢᐟᵗ', step: stepInfoNCE, lr: 0.05, onSphere: true },
  { id: 'clip', name: 'CLIP (bidirectional, 2021)', sub: 'symmetrised InfoNCE', step: stepCLIP, lr: 0.05, onSphere: true },
  { id: 'supcon', name: 'SupCon (2020)', sub: 'multi-positive InfoNCE', step: stepSupCon, lr: 0.05, onSphere: true },
  { id: 'siglip', name: 'SigLIP (pairwise σ, 2023)', sub: 'log(1+exp(−y(t·sim+b)))', step: stepSigLIP, lr: 0.01, onSphere: true },
  { id: 'alignunif', name: 'Align + Uniform (2020)', sub: 'L = d²₊ + λ log E[e⁻ᵗᵈ²]', step: stepAlignUnif, lr: 0.04, onSphere: true },
  { id: 'orthog', name: 'Cosine→0', sub: 'L = (1 − cos₊) + cos²₋', step: stepOrthog, lr: 0.08, onSphere: true },
];

const accuracy = (pts, labels) => {
  const sum = {}, cnt = {};
  for (let i = 0; i < pts.length; i++) { const y = labels[i]; if (!(y in sum)) { sum[y] = [0, 0]; cnt[y] = 0; } sum[y][0] += pts[i][0]; sum[y][1] += pts[i][1]; cnt[y]++; }
  const cents = {}; for (const y in sum) cents[y] = [sum[y][0] / cnt[y], sum[y][1] / cnt[y]];
  let correct = 0;
  for (let i = 0; i < pts.length; i++) { let best = null, bd = Infinity; for (const y in cents) { const d = (pts[i][0] - cents[y][0]) ** 2 + (pts[i][1] - cents[y][1]) ** 2; if (d < bd) { bd = d; best = +y; } } if (best === labels[i]) correct++; }
  return correct / pts.length;
};

const classColor = (y, alpha = 1) => { const hex = PALETTE[y % PALETTE.length]; const r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16); return `rgba(${r}, ${g}, ${b}, ${alpha})`; };

// per-panel geometry, shared by draw() and the hover hit-test
const COLS = 4, ROWS = 2, GAP = 8, PADTOP = 6, HEADER = 36, PLOTPAD = 10;
const layout = (W, H) => {
  const cellW = (W - GAP * (COLS + 1)) / COLS, cellH = (H - GAP * (ROWS + 1) - PADTOP) / ROWS; const rects = [];
  for (let r = 0; r < ROWS; r++) for (let cc = 0; cc < COLS; cc++) rects.push({ x: GAP + cc * (cellW + GAP), y: PADTOP + GAP + r * (cellH + GAP), w: cellW, h: cellH });
  return rects;
};
const plotGeom = (R, onSphere) => {
  const px = R.x + PLOTPAD, py = R.y + HEADER + PLOTPAD, pw = R.w - PLOTPAD * 2, ph = R.h - HEADER - PLOTPAD * 2 - 18;
  const range = onSphere ? 1.2 : 2.5; const cx = px + pw / 2, cy = py + ph / 2; const s = Math.min(pw, ph) / (range * 2);
  return { px, py, pw, ph, cx, cy, s };
};

defineViz('contrastiverace', {
  title: 'Eight contrastive losses, one dataset',
  height: 640, autoplay: false, stepsPerFrame: 1,
  controls: [
    { type: 'play' }, { type: 'step' }, { type: 'reset' }, { type: 'speed' },
    { type: 'newrow' },
    { type: 'select', name: 'data', label: 'data', value: 'random', options: [
      { value: 'random', label: 'random (2 classes)' }, { value: 'random-4', label: 'random (4 classes)' },
      { value: 'moons', label: 'two-moons' }, { value: 'blobs', label: 'overlapping blobs' },
      { value: 'rings', label: 'concentric rings' }, { value: 'four', label: 'four classes' } ] },
    { type: 'select', name: 'n', label: 'n', value: '60', options: [{ value: '40', label: '40' }, { value: '60', label: '60' }, { value: '80', label: '80' }, { value: '120', label: '120' }] },
    { type: 'number', name: 'seed', label: 'seed', value: 7, min: 0, max: 999, width: 54 },
    { type: 'readout', name: 'iter' },
  ],
  setup(api) {
    const kind = api.get('data'), n = parseInt(api.get('n'), 10), seed = parseInt(api.get('seed'), 10) || 0;
    const { pts: base, labels } = makeData(kind, n, seed);
    api.state.hover = -1;
    api.state.panels = LOSSES.map((L) => {
      const pts = base.map((p) => [p[0], p[1]]); if (L.onSphere) projectSphere(pts);
      return { loss: L, pts, labels, rng: rng32(seed * 1000 + L.id.charCodeAt(0)), accHistory: [], lastLoss: NaN, lastAcc: accuracy(pts, labels) };
    });
    // hover hit-test across panels, wired once per canvas
    if (!api.canvas.dataset.crHover) {
      api.canvas.dataset.crHover = '1';
      api.canvas.addEventListener('pointermove', (e) => {
        const rect = api.canvas.getBoundingClientRect(); const mx = e.clientX - rect.left, my = e.clientY - rect.top;
        const rects = layout(api.size.W, api.size.H); let found = -1;
        for (let pi = 0; pi < api.state.panels.length && found < 0; pi++) {
          const P = api.state.panels[pi], R = rects[pi];
          if (mx < R.x || mx > R.x + R.w || my < R.y || my > R.y + R.h) continue;
          const g = plotGeom(R, P.loss.onSphere);
          for (let i = 0; i < P.pts.length; i++) { const x = g.cx + P.pts[i][0] * g.s, y = g.cy - P.pts[i][1] * g.s; if ((x - mx) ** 2 + (y - my) ** 2 <= 16) { found = i; break; } }
        }
        if (found !== api.state.hover) { api.state.hover = found; api.render(); }
      });
      api.canvas.addEventListener('pointerleave', () => { if (api.state.hover !== -1) { api.state.hover = -1; api.render(); } });
    }
  },
  step(api) {
    for (const P of api.state.panels) { P.lastLoss = P.loss.step(P.pts, P.labels, P.loss.lr, P.rng); P.lastAcc = accuracy(P.pts, P.labels); P.accHistory.push(P.lastAcc); if (P.accHistory.length > 240) P.accHistory.shift(); }
    api.readout('iter', 'iter ' + api.iter);
  },
  draw(api) {
    const { ctx, colors, size, state } = api; const W = size.W, H = size.H; if (W === 0) return;
    const { accent, muted, faint, border, fg, cellBg } = colors; const rects = layout(W, H);
    for (let pi = 0; pi < state.panels.length; pi++) {
      const P = state.panels[pi], R = rects[pi];
      ctx.fillStyle = cellBg; ctx.strokeStyle = border; ctx.lineWidth = 1; ctx.fillRect(R.x, R.y, R.w, R.h); ctx.strokeRect(R.x + 0.5, R.y + 0.5, R.w - 1, R.h - 1);
      ctx.fillStyle = fg; ctx.font = '600 12px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'top'; ctx.fillText(P.loss.name, R.x + 8, R.y + 6);
      ctx.fillStyle = faint; ctx.font = '10px ui-monospace, monospace'; ctx.fillText(P.loss.sub, R.x + 8, R.y + 22);
      const acc = P.lastAcc, accColor = acc >= 0.95 ? colors.green : (acc >= 0.8 ? accent : muted);
      ctx.fillStyle = accColor; ctx.font = '600 11px ui-monospace, monospace'; ctx.textAlign = 'right'; ctx.fillText('acc ' + (acc * 100).toFixed(0) + '%', R.x + R.w - 8, R.y + 6);
      ctx.fillStyle = faint; ctx.font = '10px ui-monospace, monospace'; ctx.fillText(isFinite(P.lastLoss) ? ('L ' + P.lastLoss.toFixed(3)) : '', R.x + R.w - 8, R.y + 22);
      const g = plotGeom(R, P.loss.onSphere);
      ctx.save(); ctx.beginPath(); ctx.rect(g.px, g.py, g.pw, g.ph); ctx.clip();
