---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 480 } = Astro.props;
---
<figure class="viz mazefloodfill" data-poster="mazefloodfill" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// Depth you can see. The same shared operator, trained only on 11×11 grids, is run
// here on a grid you choose. "Reachable" spreads one ring per iteration out from the
// goal, so the bigger the grid the more turns it needs, and the network solves it by
// simply iterating longer. Watch the front propagate to its fixed point. Live compute.
import { defineViz } from './engine/vizkit.js';
import { gate, loadingText, mix, parseColor } from './engine/draw.js';
import { loadReady, compute, makeMaze } from './yatdeqmaze.js';

const KMAX = 60, REACH = '#3a8f5e';
// the slider spans [0, KMAX] but is mapped onto the grid's real frame count, so the
// slider label and the "iter" readout always show the same (real) iteration number
let curMax = KMAX;
const toIter = (v) => Math.round((v / KMAX) * curMax);

defineViz('mazefloodfill', {
  title: 'One operator, trained on 11×11, thinking its way across any grid',
  height: 480,
  controls: [
    { type: 'select', name: 'size', label: 'grid', value: '15', reset: false,
      options: [{ value: '11', label: '11×11 (train size)' }, { value: '15', label: '15×15' }, { value: '21', label: '21×21' }, { value: '27', label: '27×27 (never seen)' }] },
    { type: 'select', name: 'ex', label: 'maze', value: '0', reset: false,
      options: [0, 1, 2, 3, 4, 5].map((i) => ({ value: '' + i, label: 'maze ' + (i + 1) })) },
    { type: 'range', name: 'k', label: 'iteration', min: 0, max: KMAX, step: 1, value: KMAX, int: true,
      reset: false, fmt: (v) => toIter(v), play: { period: 6500, loop: false } },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    gate(api, loadReady, (api, model) => {
      try { api.state.cmp = compute(model); api.state.model = model; build(api); }
      catch (e) { console.error('mazefloodfill build failed:', e && e.message, e && e.stack); throw e; }
    });
  },
  onControl(name, v, api) { if ((name === 'size' || name === 'ex') && api.state.cmp) { build(api); api.setControl('k', KMAX); api.render(); } },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H;
    if (W === 0) return;
    ctx.clearRect(0, 0, W, H);
    if (!st.ready || !st.M) { loadingText(api, 'propagating…'); return; }
    const M = st.M, k = Math.min(toIter(api.get('k')), M.maxk);
    const field = M.fields[k];

    const pad = 16, infoW = 168;
    const gw = W - pad * 2 - infoW, gh = H - pad * 2;
    const cell = Math.floor(Math.min(gw, gh) / M.W);
    const gx = pad + (gw - cell * M.W) / 2, gy = pad + (gh - cell * M.H) / 2;
    const bg = parseColor(colors.bg || '#fff'), reach = parseColor(REACH), wallc = parseColor(colors.border);

    for (let i = 0; i < M.H; i++) for (let j = 0; j < M.W; j++) {
      const c = i * M.W + j, x = gx + j * cell, y = gy + i * cell, p = field[c];
      let col;
      if (M.wallFlat[c]) col = mix(bg, wallc, 0.9);                 // wall
      else col = mix(bg, reach, Math.max(0, p) * 0.92);            // free: fill with belief
      ctx.fillStyle = `rgb(${col[0] | 0},${col[1] | 0},${col[2] | 0})`;
      ctx.fillRect(x + 0.5, y + 0.5, cell - 1, cell - 1);
    }
    // goal marker
    const gi = M.goal[0], gj = M.goal[1];
    ctx.strokeStyle = colors.fg; ctx.lineWidth = 2; ctx.beginPath();
    ctx.arc(gx + gj * cell + cell / 2, gy + gi * cell + cell / 2, Math.max(2, cell * 0.32), 0, 6.283); ctx.stroke();

    // info column
    const ix = gx + cell * M.W + 22;
    let ok = 0, tot = 0, front = 0;
    for (let c = 0; c < M.n; c++) if (!M.wallFlat[c]) { tot++; const pred = field[c] > 0.5 ? 1 : 0; if (pred === M.reachFlat[c]) ok++; if (M.reachFlat[c] && field[c] <= 0.5) front++; }
    const acc = tot ? ok / tot : 0;
    ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillStyle = colors.muted; ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillText(`grid ${M.H}×${M.W}`, ix, gy + 6);
    ctx.fillText(`goal reaches ${M.radius} cells deep`, ix, gy + 24);
    ctx.fillStyle = colors.fg; ctx.font = 'bold 22px ui-sans-serif, system-ui'; ctx.fillText('iter ' + k, ix, gy + 58);
    ctx.fillStyle = colors.muted; ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillText('cells matching truth', ix, gy + 84);
    ctx.fillStyle = front === 0 ? REACH : colors.accent; ctx.font = 'bold 18px ui-sans-serif, system-ui';
    ctx.fillText((acc * 100).toFixed(1) + '%', ix, gy + 106);
    ctx.fillStyle = colors.muted; ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillText(front === 0 ? 'front has arrived' : `${front} cells not reached yet`, ix, gy + 128);
    // legend
    const ly = gy + 164;
    ctx.fillStyle = `rgb(${mix(bg, reach, 0.92).map((v) => v | 0).join(',')})`; ctx.fillRect(ix, ly, 12, 12);
    ctx.fillStyle = colors.muted; ctx.fillText('reachable', ix + 18, ly + 10);
    ctx.fillStyle = `rgb(${mix(bg, wallc, 0.9).map((v) => v | 0).join(',')})`; ctx.fillRect(ix, ly + 20, 12, 12);
    ctx.fillStyle = colors.muted; ctx.fillText('wall', ix + 18, ly + 30);

    api.readout('rd', front === 0
      ? `iteration ${k}: the front has reached every cell, the answer has settled (${(acc * 100).toFixed(1)}% correct)`
      : `iteration ${k}: still propagating, ${front} reachable cells not yet found`);
  },
});

function build(api) {
  const st = api.state, n = api.get('size'), ei = +api.get('ex');
  const ex = st.model.examples[n][ei];
  const runner = makeMaze(st.cmp, ex.wall, ex.goal);
  const H = runner.H, W = runner.W, maxk = Math.min(KMAX, 2 * Math.max(H, W) + 6);
  const fields = [runner.prob()];
  for (let k = 0; k < maxk; k++) { runner.step(); fields.push(runner.prob()); }
  const wallFlat = new Uint8Array(H * W), reachFlat = new Uint8Array(H * W);
  for (let i = 0; i < H; i++) for (let j = 0; j < W; j++) { wallFlat[i * W + j] = ex.wall[i][j]; reachFlat[i * W + j] = ex.reach[i][j]; }
  st.M = { H, W, n: H * W, fields, maxk, wallFlat, reachFlat, goal: ex.goal, radius: ex.radius };
  curMax = maxk;
  api.setControl('k', api.get('k'));   // refresh the slider label under the new mapping
}
</script>
