---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 470 } = Astro.props;
---
<figure class="viz ringweight" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The payoff of letting the weight be a place. The data is two rings: an inner
// disk (one class) inside an outer ring (the other). No line separates them, so a
// weight that can only be a direction is stuck near chance, rotate and slide it all
// you like. Switch the weight to a place, a single point you drop in the plane, and
// classify by distance to it: put it at the center and one well-placed point splits
// the rings almost perfectly. A direction cannot solve this; a location can.
// Accuracy is computed live on the points.
import { defineViz } from './engine/vizkit.js';

const DOM = 2.0;
const hex = (h) => [parseInt(h.slice(1, 3), 16), parseInt(h.slice(3, 5), 16), parseInt(h.slice(5, 7), 16)];

function rings() {
  let s = 7700119; const rnd = () => (s = (s * 16807) % 2147483647) / 2147483647;
  const pts = [];
  for (let i = 0; i < 80; i++) { const a = rnd() * 6.283, r = Math.sqrt(rnd()) * 0.62; pts.push({ x: Math.cos(a) * r, y: Math.sin(a) * r, c: 0 }); }
  for (let i = 0; i < 120; i++) { const a = rnd() * 6.283, r = 1.15 + rnd() * 0.55; pts.push({ x: Math.cos(a) * r, y: Math.sin(a) * r, c: 1 }); }
  return pts;
}

defineViz('ringweight', {
  title: 'Rings: a direction cannot separate them, a single placed point can',
  height: 470,
  controls: [
    { type: 'select', name: 'mode', label: 'weight is', reset: false, options: [
      { value: 'line', label: 'a direction (a separating line)' },
      { value: 'point', label: 'a place (a prototype + radius)' },
    ], value: 'line' },
    { type: 'range', name: 'rad', label: 'boundary radius', min: 0.3, max: 1.6, step: 0.02, value: 0.9, reset: false, fmt: (v) => v.toFixed(2) },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) { api.state = { pts: rings(), h: { x: 0.0, y: 1.3 }, p: { x: 0.55, y: 0.4 }, drag: false }; bind(api); },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H; if (W === 0 || !st) return;
    const mode = api.get('mode'), rad = api.get('rad');
    const A_COL = '#b3661b', B_COL = '#4a7fb3';
    ctx.clearRect(0, 0, W, H);
    const pad = 12, topH = 30, side = Math.min(W - pad * 2, H - pad - topH - 14);
    const x0 = (W - side) / 2, y0 = pad + topH;
    const sx = (wx) => x0 + (wx + DOM) / (2 * DOM) * side, sy = (wy) => y0 + (DOM - wy) / (2 * DOM) * side;
    const wxOf = (px) => (px - x0) / side * 2 * DOM - DOM, wyOf = (py) => DOM - (py - y0) / side * 2 * DOM;
    const sR = (r) => r / (2 * DOM) * side;
    st._g = { x0, y0, side, sx, sy, wxOf, wyOf };

    ctx.fillStyle = colors.fg; ctx.font = 'bold 13px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillText(mode === 'line' ? 'drag the handle to aim and slide the line; no angle separates the rings'
                                 : 'drag the prototype; a circle at the right radius splits inner from outer', pad, pad + 13);

    // classify + accuracy
    let pred; const p = st.p, h = st.h;
    if (mode === 'line') { const n = Math.hypot(h.x, h.y) || 1; const wx = h.x / n, wy = h.y / n; const off = wx * h.x + wy * h.y;
      pred = (P) => ((P.x * wx + P.y * wy - off) >= 0 ? 1 : 0); }
    else { pred = (P) => (Math.hypot(P.x - p.x, P.y - p.y) <= rad ? 0 : 1); }
    let correct = 0; for (const P of st.pts) if (pred(P) === P.c) correct++;
    const acc = 100 * correct / st.pts.length;

    // faint region tint
    const HM = 70, cell = side / HM, bg = hex(colors.bg), ca = hex(A_COL), cb = hex(B_COL);
    for (let r = 0; r < HM; r++) for (let cc = 0; cc < HM; cc++) {
      const X = wxOf(x0 + (cc + 0.5) * cell), Y = wyOf(y0 + (r + 0.5) * cell);
      const yc = pred({ x: X, y: Y, c: 0 }); const col = yc === 0 ? ca : cb;
      ctx.fillStyle = `rgba(${col[0]},${col[1]},${col[2]},0.10)`; ctx.fillRect(x0 + cc * cell, y0 + r * cell, cell + 0.6, cell + 0.6);
    }
    ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(x0 + 0.5, y0 + 0.5, side - 1, side - 1);

    // boundary (clipped to the plot box so the line never spills into the margins)
    ctx.save(); ctx.beginPath(); ctx.rect(x0, y0, side, side); ctx.clip();
    if (mode === 'line') { const n = Math.hypot(h.x, h.y) || 1; const ux = -h.y / n, uy = h.x / n;
      ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.6; ctx.beginPath();
      ctx.moveTo(sx(h.x + ux * DOM * 2), sy(h.y + uy * DOM * 2)); ctx.lineTo(sx(h.x - ux * DOM * 2), sy(h.y - uy * DOM * 2)); ctx.stroke();
      arrowTo(ctx, sx(0), sy(0), sx(h.x), sy(h.y), colors.muted, 1.8);
      ctx.fillStyle = colors.fg; ctx.beginPath(); ctx.arc(sx(h.x), sy(h.y), 6, 0, 6.283); ctx.fill(); ctx.lineWidth = 2; ctx.strokeStyle = colors.bg; ctx.stroke();
    } else {
      ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.8; ctx.beginPath(); ctx.arc(sx(p.x), sy(p.y), Math.max(0, sR(rad)), 0, 6.283); ctx.stroke();
    }
    ctx.restore();

    // data on top
    for (const P of st.pts) { ctx.globalAlpha = 0.85; ctx.fillStyle = P.c ? B_COL : A_COL; ctx.beginPath(); ctx.arc(sx(P.x), sy(P.y), 2.6, 0, 6.283); ctx.fill(); }
    ctx.globalAlpha = 1;

    if (mode === 'point') {
      ctx.fillStyle = colors.accent; ctx.beginPath(); ctx.arc(sx(p.x), sy(p.y), 7, 0, 6.283); ctx.fill();
      ctx.lineWidth = 2; ctx.strokeStyle = colors.bg; ctx.stroke();
      ctx.fillStyle = colors.accent; ctx.font = 'bold 11px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'bottom';
      ctx.fillText('prototype', sx(p.x) + 9, sy(p.y) - 6);
    }

    // accuracy badge
    const good = acc > 90;
    ctx.fillStyle = good ? '#3a8f5e' : colors.muted; ctx.font = 'bold 15px ui-sans-serif, system-ui'; ctx.textAlign = 'right'; ctx.textBaseline = 'top';
    ctx.fillText(`${acc.toFixed(0)}% separated`, x0 + side - 8, y0 + 8);
    api.readout('rd', mode === 'line' ? `best a direction can do here is near chance · ${acc.toFixed(0)}% · the classes are nested, not side by side`
                                       : `a single placed point at the right radius: ${acc.toFixed(0)}% · drag it to the center`);
  },
});

function arrowTo(ctx, x0, y0, x1, y1, color, w = 2) {
  ctx.strokeStyle = color; ctx.lineWidth = w; ctx.beginPath(); ctx.moveTo(x0, y0); ctx.lineTo(x1, y1); ctx.stroke();
  const a = Math.atan2(y1 - y0, x1 - x0), h = 8;
  ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x1 - h * Math.cos(a - 0.4), y1 - h * Math.sin(a - 0.4));
  ctx.moveTo(x1, y1); ctx.lineTo(x1 - h * Math.cos(a + 0.4), y1 - h * Math.sin(a + 0.4)); ctx.stroke();
}
function bind(api) {
  if (api.canvas.dataset.rwBound) return; api.canvas.dataset.rwBound = '1'; api.canvas.style.cursor = 'grab';
  const at = (e) => { const rc = api.canvas.getBoundingClientRect(); return { px: (e.clientX - rc.left) * api.size.W / rc.width, py: (e.clientY - rc.top) * api.size.H / rc.height }; };
  api.canvas.addEventListener('pointerdown', (e) => { const st = api.state, g = st && st._g; if (!g) return; st.drag = true; mv(api, at(e)); api.render(); });
  api.canvas.addEventListener('pointermove', (e) => { if (!api.state || !api.state.drag) return; mv(api, at(e)); api.render(); });
  const up = () => { if (api.state) api.state.drag = false; };
  api.canvas.addEventListener('pointerup', up); api.canvas.addEventListener('pointercancel', up);
}
function mv(api, { px, py }) { const st = api.state, g = st._g; const wx = Math.max(-DOM, Math.min(DOM, g.wxOf(px))), wy = Math.max(-DOM, Math.min(DOM, g.wyOf(py)));
  if (api.get('mode') === 'line') { st.h.x = wx; st.h.y = wy; } else { st.p.x = wx; st.p.y = wy; } }
</script>
