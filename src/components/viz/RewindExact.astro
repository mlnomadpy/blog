---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 440 } = Astro.props;
---
<figure class="viz rewindexact" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// Time reversibility, run live. The momentum update
//   v' = mu v + (1-mu) F(x),  x' = x + h v'
// can be solved backward exactly: x = x' - h v', then v = (v' - (1-mu)F(x))/mu.
// So from nothing but the FINAL state (x_L, v_L) of the trained rings net, the
// browser reconstructs the entire trajectory, and the input, by running the
// same blocks in reverse. Press play: forward first (solid), then the rewind
// retraces it (hollow), and the readout tracks the worst reconstruction error.
// A plain residual block (mu = 0) throws the old velocity away each layer;
// there is no formula to run it backward.
import { defineViz } from './engine/vizkit.js';
import { panel, dot, T, fmt, gate, loadingText } from './engine/draw.js';
import { loadInertia, rollForward, rollBackward, CLS } from './momres.js';

const NP = 10;   // probe points

defineViz('rewindexact', {
  title: 'Rewind the network from its final state alone',
  height: 440,
  controls: [
    { type: 'range', name: 't', label: 'forward, then rewind', min: 0, max: 64, step: 1, value: 64, int: true, reset: false, play: { period: 9000, loop: false } },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    gate(api, loadInertia, (api, d) => {
      const net = d.nets['0.9'], h = d.h;
      const probes = [];
      for (const c of [0, 1]) {
        const cand = [];
        for (let i = 0; i < d.test_y.length; i++) if (d.test_y[i] === c) cand.push(i);
        cand.sort((a, b) => Math.atan2(d.test_X[a][1], d.test_X[a][0]) - Math.atan2(d.test_X[b][1], d.test_X[b][0]));
        for (let k = 0; k < NP / 2; k++) probes.push(cand[Math.floor(((k + 0.4) * cand.length) / (NP / 2))]);
      }
      api.state.runs = probes.map((i) => {
        const fwd = rollForward(net, h, d.test_X[i]);
        const last = fwd[fwd.length - 1];
        const bwd = rollBackward(net, h, last.x, last.v);
        // per-layer reconstruction error, indexed by how far the rewind has gone
        const err = fwd.map((s, l) => Math.hypot(bwd[l].x[0] - s.x[0], bwd[l].x[1] - s.x[1]));
        return { y: d.test_y[i], fwd: fwd.map((s) => s.x), bwd: bwd.map((s) => s.x), err };
      });
      api.state.L = net.W1.length;
      let m = 0;
      for (const r of api.state.runs) for (const p of r.fwd) m = Math.max(m, Math.abs(p[0]), Math.abs(p[1]));
      api.state.B = Math.min(m, 6) * 1.08;
    });
  },
  draw(api) {
    const { ctx, colors, size, state: st } = api;
    if (!st || !st.ready) { loadingText(api, 'loading the trained net…'); return; }
    const L = st.L, t = api.get('t');
    const fdepth = Math.min(t, L);                 // forward head: 0..L
    const rdepth = L - Math.max(0, t - L);         // rewind head: L..0
    const m = panel(ctx, { x: 6, y: 0, w: size.W - 12, h: size.H }, colors, { header: 26 });
    const px = (p) => [m.cx + (p[0] / st.B) * m.R, m.cy - (p[1] / st.B) * m.R];
    ctx.save(); ctx.beginPath(); ctx.rect(6, 26, size.W - 12, size.H - 26); ctx.clip();
    const phase = t <= L ? 'forward' : 'rewind';
    T(ctx, colors, 'label', { color: colors.fg, weight: 'b' });
    ctx.fillText(phase === 'forward' ? `forward pass, layer ${fdepth} of ${L}` : `rewinding from (x_L, v_L), back to layer ${rdepth}`, 16, 17);

    let worst = 0;
    st.runs.forEach((r) => {
      const col = CLS[r.y];
      // forward path up to fdepth (solid)
      ctx.strokeStyle = col; ctx.lineWidth = 1.3; ctx.globalAlpha = 0.55; ctx.beginPath();
      for (let l = 0; l <= fdepth; l++) { const p = px(r.fwd[l]); l ? ctx.lineTo(p[0], p[1]) : ctx.moveTo(p[0], p[1]); }
      ctx.stroke(); ctx.globalAlpha = 1;
      const hf = px(r.fwd[fdepth]);
      dot(ctx, hf[0], hf[1], 3, col);
      if (phase === 'rewind') {
        // reconstructed states from rdepth..L, hollow, landing on the path
        ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.3;
        for (let l = L; l >= rdepth; l -= 2) {
          const p = px(r.bwd[l]);
          ctx.beginPath(); ctx.arc(p[0], p[1], 3.4, 0, 6.283); ctx.stroke();
        }
        for (let l = L; l >= rdepth; l--) worst = Math.max(worst, r.err[l]);
        const hb = px(r.bwd[rdepth]);
        ctx.strokeStyle = '#c2553a'; ctx.lineWidth = 1.8;
        ctx.beginPath(); ctx.arc(hb[0], hb[1], 5, 0, 6.283); ctx.stroke();
      }
    });
    ctx.restore();
    if (phase === 'rewind') {
      T(ctx, colors, 'label', { color: colors.muted, align: 'right' });
      ctx.fillText(`worst |x_rewound - x_true| so far: ${worst.toExponential(1)}`, size.W - 16, 17);
    }
    api.readout('rd', phase === 'forward'
      ? `carrying ${NP} points through the trained momentum net (mu = 0.9), computed live`
      : `rewound to layer ${rdepth} using only the final (position, velocity) · worst error ${worst.toExponential(1)}`);
  },
});
</script>
