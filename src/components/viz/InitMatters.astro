---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 380 } = Astro.props;
---
<figure class="viz initmatters" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// Where the pictures come from. Two Yat-MLPs, identical except for how the
// prototypes were initialized: from training examples (left) or from noise
// (right). They reach the same accuracy. Only the left one is legible. So the
// readability is not a free gift of the kernel; it comes from the prototypes
// living where the data lives. The kernel makes a picture possible; anchoring it
// to the data makes the picture actual.
import { defineViz } from './engine/vizkit.js';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const loadImg = (src) => new Promise((res) => { const im = new Image(); im.onload = () => res(im); im.onerror = () => res(null); im.src = src; });

defineViz('initmatters', {
  title: 'Same kernel, same accuracy, one is readable',
  height: 380,
  controls: [{ type: 'readout', name: 'rd' }],

  setup(api) {
    api.state = { ready: false };
    Promise.all([
      loadImg(`${BASE}/yat-fmnist/protos.png`),
      loadImg(`${BASE}/yat-fmnist/random.png`),
      fetch(`${BASE}/yat-fmnist/meta.json`).then((r) => r.json()),
    ]).then(([data, rand, meta]) => {
      if (!api.state) return;
      Object.assign(api.state, { ready: true, data, rand, meta });
      api.render();
    });
  },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H;
    if (W === 0 || !st) return;
    ctx.clearRect(0, 0, W, H);
    if (!st.ready) {
      ctx.fillStyle = colors.muted; ctx.font = '12px ui-monospace, monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText('loading…', W / 2, H / 2); return;
    }
    const meta = st.meta, K = meta.K, cols = 10, rows = Math.ceil(K / cols);
    const pad = 10, gap = 22, header = 44, footer = 30;
    const panelW = (W - pad * 2 - gap) / 2;
    const availH = H - pad - header - footer, cg = 3;
    const cell = Math.min((panelW - (cols - 1) * cg) / cols, (availH - (rows - 1) * cg) / rows);
    const gw = cols * cell + (cols - 1) * cg, gh = rows * cell + (rows - 1) * cg;
    const gy = pad + header + (availH - gh) / 2;

    const panel = (img, x0, title, acc, good) => {
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top'; ctx.fillStyle = colors.fg; ctx.font = '12px ui-sans-serif, system-ui';
      ctx.fillText(title, x0 + gw / 2, pad);
      ctx.font = 'bold 22px ui-sans-serif, system-ui'; ctx.fillStyle = good ? colors.accent : colors.muted;
      ctx.fillText(`${acc}%`, x0 + gw / 2, pad + 16);
      ctx.imageSmoothingEnabled = true;
      for (let k = 0; k < K; k++) {
        const c = k % cols, r = Math.floor(k / cols);
        ctx.drawImage(img, (k % 10) * 28, Math.floor(k / 10) * 28, 28, 28, x0 + c * (cell + cg), gy + r * (cell + cg), cell, cell);
      }
      ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(x0 - 4.5, gy - 4.5, gw + 8, gh + 8);
    };

    const lx = pad + (panelW - gw) / 2, rx = pad + panelW + gap + (panelW - gw) / 2;
    panel(st.data, lx, 'prototypes initialized from examples', meta.yatAcc, true);
    panel(st.rand, rx, 'prototypes initialized from noise', meta.randomAcc, false);

    ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
    ctx.fillStyle = colors.fg; ctx.font = '12px ui-sans-serif, system-ui';
    ctx.fillText('Both are Yat kernels. Both classify. Only the left is readable.', W / 2, H - 14);
    ctx.fillStyle = colors.muted; ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillText('legibility comes from prototypes that live on the data, not from the kernel alone', W / 2, H - 2);

    api.readout('rd', `accuracy is the same (${meta.yatAcc}% vs ${meta.randomAcc}%); readability is not, the kernel makes a picture possible, anchoring it to the data makes it actual`);
  },
});
</script>
