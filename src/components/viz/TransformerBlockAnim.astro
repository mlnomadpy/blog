---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 340 } = Astro.props;
const id = `tba-${Math.random().toString(36).slice(2, 9)}`;
const stages = [
  { label: 'input residual stream' },
  { label: 'attention sub-block' },
  { label: 'add attention output' },
  { label: 'MLP sub-block' },
  { label: 'add MLP output' },
];
---
<figure class="viz" tabindex="0">
  <div class="viz-controls anim-controls" data-anim={id}>
    <div class="anim-row">
      <button type="button" class="anim-step" data-act="prev" title="previous stage (←)">◀ prev</button>
      <button type="button" class="anim-play" data-act="play" title="play / pause (space)">▶ play</button>
      <button type="button" class="anim-step" data-act="next" title="next stage (→)">next ▶</button>
      <button type="button" class="anim-step" data-act="reset" title="reset to first stage">reset</button>
      <span class="anim-spd-group" data-spd-group>
        <button type="button" data-spd="0.5">0.5×</button>
        <button type="button" data-spd="1" class="active">1×</button>
        <button type="button" data-spd="2">2×</button>
      </span>
      <span class="anim-zoom-group" data-zoom-group>
        <button type="button" data-zoom="-" title="zoom out">−</button>
        <button type="button" data-zoom="0" title="reset zoom & pan">⤢</button>
        <button type="button" data-zoom="+" title="zoom in">+</button>
      </span>
    </div>
    <input type="range" class="anim-scrub" min="0" max="1000" value="0" step="1" data-scrub aria-label="scrub through the animation" />
    <div class="anim-progress">
      {stages.map((s, i) => (
        <button type="button" class="anim-dot" data-step={i} aria-label={`stage ${i + 1}: ${s.label}`}>
          <span class="anim-dot-num">{i + 1}</span>
          <span class="anim-dot-label">{s.label}</span>
        </button>
      ))}
    </div>
    <span class="faint anim-stage-readout" id={`${id}-stage`}>—</span>
  </div>
  <canvas id={`${id}-c`} height={height} aria-label="Animated transformer block: residual stream through attention and MLP sub-blocks"></canvas>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script is:inline define:vars={{ id }}>
(() => {
  const setup = () => {
    const c = document.getElementById(id + '-c');
    if (!c || c.dataset.ready) return;
    c.dataset.ready = '1';
    const ctx = c.getContext('2d');
    const wrap = document.querySelector(`[data-anim="${id}"]`);
    const stageReadout = document.getElementById(id + '-stage');
    const dots = wrap.querySelectorAll('.anim-dot');
    const stageNames = [
      'input: a token sequence flows in along the residual stream',
      'attention sub-block, each token mixes with the rest via QKᵀ kernel',
      'residual add: attention output is summed back into the residual stream',
      'MLP sub-block, per-token nonlinear update (one row at a time)',
      'residual add: MLP output is summed back into the residual stream',
    ];

    let step = 0;
    let prog = 0;
    let playing = false;
    let lastTs = 0;
    let speedMul = 1;
    const stepDur = 1300;
    const totalSteps = stageNames.length;
    const figure = c.closest('figure');
    const scrub = wrap.querySelector('[data-scrub]');
    const spdGroup = wrap.querySelector('[data-spd-group]');
    const zoomGroup = wrap.querySelector('[data-zoom-group]');

    // Scene is drawn at fixed virtual dimensions; transform fits it to canvas.
    const scene = { w: 760, h: 320 };
    let zoom = 1;
    let panX = 0;
    let panY = 0;
    const minZoom = 0.6, maxZoom = 4;

    const computeTransform = () => {
      const W = state.w, H = state.h;
      const bs = Math.min((W - 8) / scene.w, (H - 8) / scene.h);
      const s = bs * zoom;
      const overflowX = Math.max(0, (scene.w * s - W) / 2);
      const overflowY = Math.max(0, (scene.h * s - H) / 2);
      panX = Math.max(-overflowX, Math.min(overflowX, panX));
      panY = Math.max(-overflowY, Math.min(overflowY, panY));
      return { s, tx: (W - scene.w * s) / 2 + panX, ty: (H - scene.h * s) / 2 + panY };
    };
    const updateScrub = () => {
      if (!scrub || scrub.matches(':active')) return;
      const frac = (step + prog) / totalSteps;
      scrub.value = String(Math.round(frac * 1000));
    };

    const state = { dpr: 1, w: 0, h: 0 };
    const fit = () => {
      const rect = c.getBoundingClientRect();
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      state.dpr = dpr;
      state.w = rect.width;
      state.h = rect.height;
      c.width = Math.round(rect.width * dpr);
      c.height = Math.round(rect.height * dpr);
    };

    let colors = readColors();
    function readColors() {
      const s = getComputedStyle(document.documentElement);
      const v = (n) => s.getPropertyValue(n).trim();
      return {
        accent: v('--accent') || '#b3661b',
        accentSoft: v('--accent-soft') || '#b3661b14',
        bg: v('--bg') || '#fbfaf6',
        bgSunken: v('--bg-sunken') || '#f1efe7',
        bgElev: v('--bg-elev') || '#ffffff',
        fg: v('--fg') || '#1a1a1a',
        muted: v('--fg-muted') || '#5a5f66',
        faint: v('--fg-faint') || '#8d8d8d',
        border: v('--border') || '#e4e1d6',
      };
    }
    const themeObs = new MutationObserver(() => { colors = readColors(); requestRedraw(); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    const ease = (t) => t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
    let rafScheduled = false;
    let visible = false;
    const requestRedraw = () => {
      if (rafScheduled || !visible) return;
      rafScheduled = true;
      requestAnimationFrame(() => { rafScheduled = false; draw(); });
    };

    const N = 5;
    const tokenLabels = ['the', 'cat', 'sat', 'on', 'mat'];

    const drawTokenColumn = (cx, cy, fillAlphas, highlight, label) => {
      const cell = 28;
      const cellW = 56;
      const totalH = N * cell;
      const x0 = cx - cellW / 2;
      const y0 = cy - totalH / 2;
      for (let i = 0; i < N; i++) {
        ctx.fillStyle = colors.bgSunken;
        ctx.strokeStyle = highlight ? colors.accent : colors.border;
        ctx.lineWidth = highlight ? 1.4 : 1;
        ctx.fillRect(x0, y0 + i * cell, cellW, cell - 2);
        ctx.strokeRect(x0, y0 + i * cell, cellW, cell - 2);
        // Fill overlay representing the residual content "intensity"
        const a = fillAlphas[i] != null ? fillAlphas[i] : 0.35;
        ctx.fillStyle = colors.accent;
        ctx.globalAlpha = 0.15 + 0.55 * a;
        ctx.fillRect(x0 + 3, y0 + i * cell + 3, cellW - 6, cell - 8);
        ctx.globalAlpha = 1;
        ctx.fillStyle = colors.fg;
        ctx.font = 'bold 11px ' + (getComputedStyle(document.body).fontFamily || 'serif');
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(tokenLabels[i], x0 + cellW / 2, y0 + i * cell + (cell - 2) / 2);
      }
      if (label) {
        ctx.fillStyle = highlight ? colors.accent : colors.muted;
        ctx.font = '600 11px ui-monospace, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.fillText(label, cx, y0 - 6);
      }
      return { x0, y0, cellW, cellH: cell, totalH };
    };

    const drawBlock = (cx, cy, w, h, title, sub, highlight, glow = 0) => {
      const x0 = cx - w / 2;
      const y0 = cy - h / 2;
      // Background fill
      ctx.fillStyle = highlight ? colors.accentSoft : colors.bgElev;
      ctx.strokeStyle = highlight ? colors.accent : colors.border;
      ctx.lineWidth = highlight ? 1.5 : 1;
      ctx.beginPath();
      const r = 8;
      ctx.moveTo(x0 + r, y0);
      ctx.lineTo(x0 + w - r, y0);
      ctx.quadraticCurveTo(x0 + w, y0, x0 + w, y0 + r);
      ctx.lineTo(x0 + w, y0 + h - r);
      ctx.quadraticCurveTo(x0 + w, y0 + h, x0 + w - r, y0 + h);
      ctx.lineTo(x0 + r, y0 + h);
      ctx.quadraticCurveTo(x0, y0 + h, x0, y0 + h - r);
      ctx.lineTo(x0, y0 + r);
      ctx.quadraticCurveTo(x0, y0, x0 + r, y0);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
      if (glow > 0) {
        ctx.save();
        ctx.shadowColor = colors.accent;
        ctx.shadowBlur = 14 * glow;
        ctx.strokeStyle = colors.accent;
        ctx.lineWidth = 1.5 + glow * 1.2;
        ctx.stroke();
        ctx.restore();
      }
      ctx.fillStyle = highlight ? colors.accent : colors.fg;
      ctx.font = '600 12px ' + (getComputedStyle(document.body).fontFamily || 'serif');
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(title, cx, cy - 6);
      if (sub) {
        ctx.fillStyle = highlight ? colors.accent : colors.muted;
        ctx.font = '10px ui-monospace, monospace';
        ctx.fillText(sub, cx, cy + 10);
      }
    };

    const flowArrow = (x0, y0, x1, y1, t, label, highlight = false) => {
      ctx.strokeStyle = highlight ? colors.accent : colors.muted;
      ctx.lineWidth = highlight ? 1.6 : 1.3;
      ctx.beginPath();
      ctx.moveTo(x0, y0); ctx.lineTo(x1, y1);
      ctx.stroke();
      const a = Math.atan2(y1 - y0, x1 - x0);
      const s = 7;
      ctx.fillStyle = highlight ? colors.accent : colors.muted;
      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x1 - s * Math.cos(a - 0.4), y1 - s * Math.sin(a - 0.4));
      ctx.lineTo(x1 - s * Math.cos(a + 0.4), y1 - s * Math.sin(a + 0.4));
      ctx.closePath();
      ctx.fill();
      if (t > 0 && t < 1) {
        const px = x0 + (x1 - x0) * t;
        const py = y0 + (y1 - y0) * t;
        ctx.fillStyle = colors.accent;
        ctx.beginPath();
        ctx.arc(px, py, 4, 0, Math.PI * 2);
        ctx.fill();
      }
      if (label) {
        ctx.fillStyle = colors.faint;
        ctx.font = '9px ui-monospace, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.fillText(label, (x0 + x1) / 2, Math.min(y0, y1) - 3);
      }
    };

    // Residual stream content per stage (alpha per token)
    const baseAlphas = [0.45, 0.3, 0.35, 0.4, 0.5];
    const attnDelta  = [0.2, 0.4, 0.25, 0.3, 0.35];
    const mlpDelta   = [0.15, 0.25, 0.3, 0.2, 0.25];

    const sum = (a, b) => a.map((v, i) => Math.min(1, v + b[i]));

    const draw = () => {
      if (state.w === 0) return;
      ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      ctx.clearRect(0, 0, state.w, state.h);
      const { s, tx, ty } = computeTransform();
      ctx.setTransform(state.dpr * s, 0, 0, state.dpr * s, state.dpr * tx, state.dpr * ty);

      const W = scene.w, H = scene.h;
      const yMid = H / 2;
      const margin = 20;
      const t = ease(prog);

      // Five columns evenly spaced in the fixed-width scene
      const colX = [
        margin + 38,
        margin + 38 + 130,
        margin + 38 + 130 + 130,
        margin + 38 + 130 + 130 + 130,
        W - margin - 38,
      ];

      // Compute residual stream content at each visible stage
      const afterAttn = sum(baseAlphas, attnDelta.map((v, i) => step >= 2 ? v : (step === 1 ? v * t : 0)));
      const afterMlp  = sum(afterAttn, mlpDelta.map((v, i) => step >= 4 ? v : (step === 3 ? v * t : 0)));

      // Residual stream at the input
      drawTokenColumn(colX[0], yMid, baseAlphas, step === 0, 'residual stream');

      // Attention block (or its glowing version while active)
      const attnHi = step === 1;
      const attnGlow = step === 1 ? t : 0;
      drawBlock(colX[1], yMid, 120, 100, 'attention', 'kernel: QKᵀ / √d', attnHi || step >= 2, attnGlow);

      // After-attention column
      drawTokenColumn(colX[2], yMid, afterAttn, step === 2, step >= 2 ? 'x + Attn(x)' : '');

      // MLP block
      const mlpHi = step === 3;
      const mlpGlow = step === 3 ? t : 0;
      drawBlock(colX[3], yMid, 120, 100, 'MLP', 'φ(W₁ x + b₁) · W₂', mlpHi || step >= 4, mlpGlow);

      // Output column
      drawTokenColumn(colX[4], yMid, afterMlp, step === 4, step >= 4 ? 'block output' : '');

      // Arrows
      const f1 = step === 0 ? t : (step >= 1 ? 1 : 0);
      flowArrow(colX[0] + 30, yMid, colX[1] - 60, yMid, f1, '', step === 1);
      const f2 = step === 1 ? t : (step >= 2 ? 1 : 0);
      flowArrow(colX[1] + 60, yMid, colX[2] - 30, yMid, f2, '+', step === 2);
      const f3 = step === 2 ? t : (step >= 3 ? 1 : 0);
      flowArrow(colX[2] + 30, yMid, colX[3] - 60, yMid, f3, '', step === 3);
      const f4 = step === 3 ? t : (step >= 4 ? 1 : 0);
      flowArrow(colX[3] + 60, yMid, colX[4] - 30, yMid, f4, '+', step === 4);

      // Residual skip lines (curved arrows top of frame)
      const arcY = 28;
      ctx.strokeStyle = colors.faint;
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 4]);
      // skip from input → after-attn
      ctx.beginPath();
      ctx.moveTo(colX[0], yMid - 75);
      ctx.bezierCurveTo(colX[0], arcY, colX[2], arcY, colX[2], yMid - 75);
      ctx.stroke();
      // skip from after-attn → output
      ctx.beginPath();
      ctx.moveTo(colX[2], yMid - 75);
      ctx.bezierCurveTo(colX[2], arcY, colX[4], arcY, colX[4], yMid - 75);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.fillStyle = colors.faint;
      ctx.font = '9px ui-monospace, monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('residual', (colX[0] + colX[2]) / 2, arcY - 8);
      ctx.fillText('residual', (colX[2] + colX[4]) / 2, arcY - 8);

      // Subtitle
      ctx.fillStyle = colors.faint;
      ctx.font = '10px ui-monospace, monospace';
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      ctx.fillText('transformer block · x → x + Attn(x) → x + Attn(x) + MLP(x + Attn(x))', margin, 10);

      // In-canvas stage banner (bottom-right)
      const banner = 'stage ' + (step + 1) + '/' + totalSteps + ' · ' + stageNames[step];
      ctx.font = '600 11px ui-monospace, monospace';
      const bw = Math.min(W - margin * 2, ctx.measureText(banner).width + 16);
      const bh = 22;
      const bx = W - margin - bw;
      const by = H - 28;
      ctx.fillStyle = colors.accentSoft;
      ctx.strokeStyle = colors.accent;
      ctx.lineWidth = 1;
      ctx.beginPath();
      const br = 6;
      ctx.moveTo(bx + br, by);
      ctx.lineTo(bx + bw - br, by);
      ctx.quadraticCurveTo(bx + bw, by, bx + bw, by + br);
      ctx.lineTo(bx + bw, by + bh - br);
      ctx.quadraticCurveTo(bx + bw, by + bh, bx + bw - br, by + bh);
      ctx.lineTo(bx + br, by + bh);
      ctx.quadraticCurveTo(bx, by + bh, bx, by + bh - br);
      ctx.lineTo(bx, by + br);
      ctx.quadraticCurveTo(bx, by, bx + br, by);
      ctx.closePath();
      ctx.fill();
      ctx.stroke();
      ctx.fillStyle = colors.accent;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(banner, bx + bw / 2, by + bh / 2);

      // Stage indicator sync
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === step);
        d.classList.toggle('passed', i < step);
      });
      stageReadout.textContent = banner;
      updateScrub();
    };

    const setStep = (s) => {
      step = Math.max(0, Math.min(stageNames.length - 1, s));
      prog = 0;
      requestRedraw();
    };

    const setPlaying = (p) => {
      playing = p;
      const btn = wrap.querySelector('[data-act="play"]');
      if (btn) btn.textContent = playing ? '❚❚ pause' : '▶ play';
      if (btn && playing) btn.classList.remove('viz-play-ready');
      if (playing) { lastTs = 0; requestAnimationFrame(tick); }
    };

    const tick = (ts) => {
      if (!playing) return;
      if (!c.isConnected) { playing = false; return; } // detached by a view-transition swap
      if (!lastTs) lastTs = ts;
      const dt = ts - lastTs;
      lastTs = ts;
      prog += (dt * speedMul) / stepDur;
      if (prog >= 1) {
        prog = 0;
        if (step + 1 >= totalSteps) {
          setPlaying(false);
          requestRedraw();
          return;
        }
        step += 1;
      }
      requestRedraw();
      requestAnimationFrame(tick);
    };

    wrap.querySelectorAll('button[data-act]').forEach((b) => b.addEventListener('click', () => {
      const k = b.dataset.act;
      if (k === 'prev') { setStep(step - 1); }
      else if (k === 'next') { setStep(step + 1); }
      else if (k === 'reset') { setStep(0); setPlaying(false); }
      else if (k === 'play') { setPlaying(!playing); }
    }));
    dots.forEach((d, i) => d.addEventListener('click', () => setStep(i)));

    if (spdGroup) {
      spdGroup.querySelectorAll('button[data-spd]').forEach((b) => b.addEventListener('click', () => {
        speedMul = parseFloat(b.dataset.spd);
        spdGroup.querySelectorAll('button').forEach((o) => o.classList.toggle('active', o === b));
      }));
    }

    if (scrub) {
      scrub.addEventListener('input', () => {
        const frac = parseFloat(scrub.value) / 1000;
        const pos = frac * totalSteps;
        const newStep = Math.min(totalSteps - 1, Math.floor(pos));
        const newProg = Math.min(1, pos - newStep);
        step = newStep;
        prog = newProg;
        if (playing) setPlaying(false);
        requestRedraw();
      });
    }

    if (figure) {
      figure.addEventListener('keydown', (e) => {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
        if (e.key === 'ArrowLeft') { setStep(step - 1); e.preventDefault(); }
        else if (e.key === 'ArrowRight') { setStep(step + 1); e.preventDefault(); }
        else if (e.key === ' ' || e.key === 'Spacebar') { setPlaying(!playing); e.preventDefault(); }
      });
    }

    const onVis = () => { if (document.hidden && playing) setPlaying(false); };
    document.addEventListener('visibilitychange', onVis);

    if (zoomGroup) {
      zoomGroup.querySelectorAll('button[data-zoom]').forEach((b) => b.addEventListener('click', () => {
        const k = b.dataset.zoom;
        if (k === '+') zoom = Math.min(maxZoom, zoom * 1.25);
        else if (k === '-') zoom = Math.max(minZoom, zoom / 1.25);
        else { zoom = 1; panX = 0; panY = 0; }
        requestRedraw();
      }));
    }
    let panning = false;
    let lastPan = null;
    c.addEventListener('pointerdown', (e) => {
      panning = true;
      lastPan = { x: e.clientX, y: e.clientY };
      c.setPointerCapture?.(e.pointerId);
      c.style.cursor = 'grabbing';
    });
    c.addEventListener('pointermove', (e) => {
      if (!panning) return;
      panX += e.clientX - lastPan.x;
      panY += e.clientY - lastPan.y;
      lastPan = { x: e.clientX, y: e.clientY };
      requestRedraw();
    });
    const endPan = (e) => {
      panning = false;
      c.style.cursor = 'grab';
      try { c.releasePointerCapture?.(e.pointerId); } catch {}
    };
    c.addEventListener('pointerup', endPan);
    c.addEventListener('pointercancel', endPan);
    c.style.cursor = 'grab';
    c.addEventListener('wheel', (e) => {
      e.preventDefault();
      const f = e.deltaY > 0 ? 0.9 : 1.1;
      zoom = Math.max(minZoom, Math.min(maxZoom, zoom * f));
      requestRedraw();
    }, { passive: false });

    const ro = new ResizeObserver(() => { fit(); requestRedraw(); });
    ro.observe(c);
    const io = new IntersectionObserver((entries) => {
      const was = visible;
      visible = entries[0].isIntersecting;
      if (visible && !was) { fit(); draw(); }
      else if (!visible && was && playing) setPlaying(false); // pause when scrolled away
    }, { rootMargin: '120px' });
    io.observe(c);
    (window.__vizReg || (window.__vizReg = new Set())).add({ n: c, c: () => { playing = false; themeObs.disconnect(); ro.disconnect(); io.disconnect(); document.removeEventListener('visibilitychange', onVis); } });
    wrap.querySelector('[data-act="play"]')?.classList.add('viz-play-ready');
  };

  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:after-swap', setup);
})();
</script>
