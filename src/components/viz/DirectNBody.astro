---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 360 } = Astro.props;
---
<figure class="viz directnbody" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { setupBodies, stepDirect, drawDirectPanel, directCost, fmt, MAX_N } from './engine/nbody.js';

defineViz('directnbody', {
  height: 360,
  minHeight: 300,
  maxHeight: 460,
  maxStep: 900,
  controls: [
    { type: 'play' },
    { type: 'step', label: 'Tick' },
    { type: 'reset' },
    { type: 'speed', presets: [0.5, 1, 2, 4] },
    { type: 'newrow' },
    { type: 'range', name: 'N', label: 'bodies N', min: 8, max: MAX_N, step: 4, value: 40, int: true, reset: true },
    { type: 'readout', name: 'ro' },
  ],
  setup(api) {
    setupBodies(api);
  },
  step(api) {
    stepDirect(api.state, api.get('N'));
  },
  draw(api) {
    const { ctx, colors, size, state } = api;
    const W = size.W, H = size.H;
    if (!W || !H) return;
    const N = api.get('N');
    const box = { x: 12, y: 8, w: W - 24, h: H - 16 };
    drawDirectPanel(ctx, box, colors, state, N);
    api.readout('ro', `N=${N} · ${fmt(directCost(N))} pairwise forces per tick · O(N²)`);
  },
});
</script>
