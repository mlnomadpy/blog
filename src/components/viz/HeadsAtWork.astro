---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 480 } = Astro.props;
---
<figure class="viz headsatwork" data-caption={caption} data-height={height} data-height-mobile="570" tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The trained routing itself, from the telemetry run: attention maps of both
// models on the same Shakespeare window, captured at checkpoints through
// training. Scrub training with the step control, pick a layer and head, and
// compare what the two compatibility functions learned to route. Both start
// as near-uniform haze and sharpen into structure; the kernel's maps get
// there without an exponential anywhere.
import { defineViz } from './engine/vizkit.js';
import { T, fmt, gate, loadingText } from './engine/draw.js';
import { load } from './yatattn.js';

defineViz('headsatwork', {
  title: 'The same window, two routings',
  height: 480,
  autoplay: false,
  controls: [
    { type: 'select', name: 'step', label: 'training step', value: 'last',
      options: [{ value: '0', label: 'step 0' }, { value: 'a', label: '10%' }, { value: 'b', label: '50%' }, { value: 'last', label: 'trained' }] },
    { type: 'select', name: 'lh', label: 'layer', value: '1',
      options: [{ value: '0', label: 'layer 1' }, { value: '1', label: 'layer 4' }, { value: '2', label: 'layer 6' }] },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    gate(api, () => load('maps'), (a, d) => { a.state.md = d; });
  },

  draw(api) {
    const { ctx, colors, size: { W, H } } = api, st = api.state;
    if (!st.ready || !st.md) { loadingText(api); return; }
    const md = st.md;
    const stepKeys = Object.keys(md.maps?.softmax || {}).sort((a, b) => {
      const na = +a.replace('step', ''), nb = +b.replace('step', '');
      return na - nb;
    });
    if (!stepKeys.length) { loadingText(api); return; }
    const sel = api.get('step');
    const key = sel === '0' ? stepKeys[0] : sel === 'a' ? stepKeys[1] : sel === 'b' ? stepKeys[2] : stepKeys[stepKeys.length - 1];
    const li = parseInt(api.get('lh'), 10), hi = 0;

    const pad = 16, half = (W - 3 * pad) / 2, mapH = Math.min(half, H - 170);
    const panels = [
      { x: pad, name: 'softmax attention', v: 'softmax' },
      { x: 2 * pad + half, name: 'yat-kernel attention', v: 'yat' },
    ];
    panels.forEach((p) => {
      const A = md.maps[p.v]?.[key]?.[li]?.[hi];
      const box = { x: p.x, y: 34, w: half, h: mapH };
      T(ctx, colors, 'label');
      ctx.fillText(`${p.name}, layer ${md.layers[li] + 1}, head ${md.heads[hi] + 1}`, box.x, box.y - 8);
      if (!A) return;
      const Tn = A.length;
      const off = document.createElement('canvas'); off.width = Tn; off.height = Tn;
      const octx = off.getContext('2d'), img = octx.createImageData(Tn, Tn);
      for (let r = 0; r < Tn; r++) for (let c = 0; c < Tn; c++) {
        const v = A[r][c] / 255;
        const idx = (r * Tn + c) * 4;
        img.data[idx] = 20 + 235 * v;
        img.data[idx + 1] = 30 + 140 * v;
        img.data[idx + 2] = 90 + 30 * (1 - v);
        img.data[idx + 3] = 255;
      }
      octx.putImageData(img, 0, 0);
      ctx.imageSmoothingEnabled = false;
      ctx.drawImage(off, box.x, box.y, box.w, box.h);
      ctx.strokeStyle = colors.border;
      ctx.strokeRect(box.x, box.y, box.w, box.h);
    });
    T(ctx, colors, 'small');
    ctx.fillText('rows are queries (later characters), columns are the keys they may attend to; brightness = attention weight (sqrt scale)', pad, 34 + mapH + 20);
    const prompt = (md.prompt || '').slice(0, 64).replace(/\n/g, ' ');
    ctx.fillText(`the window both models read: "${prompt}..."`, pad, 34 + mapH + 40);
    api.readout('rd', `checkpoint: ${key.replace('step', 'step ')} of 12000; both maps are the run's real attention weights on this window`);
  },
});
</script>
