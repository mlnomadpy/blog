---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 280 } = Astro.props;
---
<figure class="viz rbfexpansion" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { np, withJax, drawJaxLoading } from './engine/jax.js';

// RBF basis expansion: fit f as Σ αⱼ K(·, kⱼ) over fixed anchors by solving the
// real kernel ridge system (K + λI)α = y live, jax-js builds the Gram matrix and
// solves it with np.linalg.solve (LU under the hood), n=9.
const n = 9, M = 240, PADL = 30, PADR = 14, PADT = 16, PADB = 26;
const target = (x) => Math.sin(x * Math.PI * 2.2) * 0.6 - x * 0.1 + 0.1;

// (K + λI)α = y via jax-js. Builds the Gram matrix as a vectorised outer-diff,
// adds ridge on the diagonal, and solves. Fresh arrays, read once → no .ref leak.
const fitAlpha = (centers, targets, inv2ss, lambda) => {
  const C = np.array(Array.from(centers));
  const di = np.subtract(np.reshape(C.ref, [n, 1]), np.reshape(C, [1, n]));  // (n,n) center gaps
  const G = np.exp(di.ref.mul(di).mul(-inv2ss));                             // Gaussian Gram
  const K = np.add(G, np.array(eye(n, lambda)));                            // + λI ridge
  return np.linalg.solve(K, np.array(Array.from(targets))).js();
};
const eye = (m, v) => Array.from({ length: m }, (_, i) => Array.from({ length: m }, (_, j) => (i === j ? v : 0)));

defineViz('rbfexpansion', {
  height: 280,
  controls: [
    { type: 'range', name: 'sigma', label: 'kernel width σ', min: -1.5, max: -0.3, step: 0.05, value: -0.9, reset: false, fmt: (v) => Math.pow(10, v).toFixed(2) },
    { type: 'toggle', name: 'basis', label: 'show basis sections', value: true },
    { type: 'readout', name: 'ro' },
  ],
  setup(api) {
    const centers = new Float32Array(n), targets = new Float32Array(n);
    for (let k = 0; k < n; k++) { centers[k] = k / (n - 1); targets[k] = target(centers[k]); }
    const xs = new Float32Array(M + 1); for (let i = 0; i <= M; i++) xs[i] = i / M;
    api.state.centers = centers; api.state.targets = targets; api.state.xs = xs;
    withJax(api);
  },
  draw(api) {
    const { ctx, colors, size, state } = api; const W = size.W, H = size.H; if (W === 0) return;
    if (!state.jaxReady) return drawJaxLoading(api);
    const { accent, muted, faint, border } = colors; const { centers, targets, xs } = state;
    const plotW = W - PADL - PADR, plotH = H - PADT - PADB, yMin = -1.0, yMax = 1.0, yRange = yMax - yMin;
    const sx = (x) => PADL + x * plotW, sy = (y) => PADT + (yMax - y) / yRange * plotH;
    ctx.strokeStyle = border; ctx.lineWidth = 1; ctx.beginPath();
    ctx.moveTo(PADL, sy(yMin)); ctx.lineTo(W - PADR, sy(yMin)); ctx.moveTo(PADL, sy(0)); ctx.lineTo(W - PADR, sy(0)); ctx.moveTo(PADL, sy(yMax)); ctx.lineTo(W - PADR, sy(yMax)); ctx.stroke();
    const sigma = Math.pow(10, api.get('sigma')); const inv2ss = 1 / (2 * sigma * sigma), lambda = 1e-4;
    const alpha = fitAlpha(centers, targets, inv2ss, lambda);
    // target (dashed)
    ctx.strokeStyle = faint; ctx.setLineDash([4, 4]); ctx.lineWidth = 1.2; ctx.beginPath();
    for (let i = 0; i <= M; i++) { const px = sx(xs[i]), py = sy(target(xs[i])); i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py); } ctx.stroke(); ctx.setLineDash([]);
    // basis sections + sum
    const showBasis = api.get('basis');
    if (showBasis) { ctx.strokeStyle = accent + '55'; ctx.lineWidth = 1;
      for (let j = 0; j < n; j++) { ctx.beginPath(); for (let i = 0; i <= M; i++) { const d = xs[i] - centers[j]; const v = alpha[j] * Math.exp(-(d * d) * inv2ss); const px = sx(xs[i]), py = sy(v); i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py); } ctx.stroke(); } }
    ctx.strokeStyle = accent; ctx.lineWidth = 1.8; ctx.beginPath();
    let sse = 0;
    for (let i = 0; i <= M; i++) { let s = 0; for (let j = 0; j < n; j++) { const d = xs[i] - centers[j]; s += alpha[j] * Math.exp(-(d * d) * inv2ss); } const px = sx(xs[i]), py = sy(s); i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py); const e = s - target(xs[i]); sse += e * e; } ctx.stroke();
    ctx.fillStyle = muted; for (let k = 0; k < n; k++) { ctx.beginPath(); ctx.arc(sx(centers[k]), sy(targets[k]), 3, 0, Math.PI * 2); ctx.fill(); }
    api.readout('ro', `σ ${sigma.toFixed(2)} · ${n} anchors · RMSE ${Math.sqrt(sse / (M + 1)).toFixed(3)} · jax-js`);
  },
});
</script>
