---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 470 } = Astro.props;
---
<figure class="viz representerbuild" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The representer theorem, built by hand. The optimal weight in an RKHS is not a
// free vector floating in a separate space; it is a combination of the data's own
// kernel bumps, f(x) = Σ αᵢ k(xᵢ, x). So the weight lives in the span of the data,
// in the same space, next to the points. Drag a point up or down to raise or lower
// its coefficient αᵢ and watch the decision surface (and its boundary) bend; press
// "fit the labels" to let a real kernel-ridge solve choose the αᵢ that separate the
// two classes. The weight is the data, recombined.
import { defineViz } from './engine/vizkit.js';

const DOM = 2.0, SIG = 0.7, HM = 80;
const hex = (h) => [parseInt(h.slice(1, 3), 16), parseInt(h.slice(3, 5), 16), parseInt(h.slice(5, 7), 16)];

function anchors() {
  // six fixed points, three per class, a layout where a line cannot separate them
  return [
    { x: -1.1, y: 0.6, c: 0 }, { x: -0.2, y: 1.0, c: 0 }, { x: 0.9, y: 0.7, c: 0 },
    { x: -0.9, y: -0.7, c: 1 }, { x: 0.1, y: -1.05, c: 1 }, { x: 1.05, y: -0.55, c: 1 },
  ].map((p) => ({ ...p, a: p.c ? -0.0 : 0.0 }));
}
const kern = (ax, ay, bx, by) => Math.exp(-((ax - bx) ** 2 + (ay - by) ** 2) / (2 * SIG * SIG));

function solve(pts, lam) {                              // (G + λI) α = y, real Gaussian elimination
  const n = pts.length; const A = [];
  for (let i = 0; i < n; i++) { A.push([]); for (let j = 0; j < n; j++) A[i].push(kern(pts[i].x, pts[i].y, pts[j].x, pts[j].y) + (i === j ? lam : 0)); A[i].push(pts[i].c ? -1 : 1); }
  for (let col = 0; col < n; col++) {
    let piv = col; for (let r = col + 1; r < n; r++) if (Math.abs(A[r][col]) > Math.abs(A[piv][col])) piv = r;
    [A[col], A[piv]] = [A[piv], A[col]]; const d = A[col][col] || 1e-9;
    for (let j = col; j <= n; j++) A[col][j] /= d;
    for (let r = 0; r < n; r++) if (r !== col) { const f = A[r][col]; for (let j = col; j <= n; j++) A[r][j] -= f * A[col][j]; }
  }
  return A.map((row) => row[n]);
}

defineViz('representerbuild', {
  title: 'The optimal weight is a combination of the data: f(x) = Σ αᵢ k(xᵢ, x)',
  height: 470,
  controls: [
    { type: 'button', name: 'fit', label: 'fit the labels' },
    { type: 'button', name: 'zero', label: 'clear αᵢ' },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) { const pts = anchors(); const al = solve(pts, 0.18); pts.forEach((p, i) => p.a = al[i]); api.state = { pts, drag: -1, dragY0: 0, a0: 0 }; bind(api); },

  onAction(name, api) {
    const st = api.state; if (!st) return;
    if (name === 'fit') { const al = solve(st.pts, 0.18); st.pts.forEach((p, i) => p.a = al[i]); }
    if (name === 'zero') st.pts.forEach((p) => p.a = 0);
  },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H; if (W === 0 || !st) return;
    const BLUE = '#4a7fb3', ORANGE = '#b3661b';
    ctx.clearRect(0, 0, W, H);
    const pad = 12, topH = 30, side = Math.min(W - pad * 2, H - pad - topH - 14);
    const x0 = (W - side) / 2, y0 = pad + topH;
    const sx = (wx) => x0 + (wx + DOM) / (2 * DOM) * side, sy = (wy) => y0 + (DOM - wy) / (2 * DOM) * side;
    const wxOf = (px) => (px - x0) / side * 2 * DOM - DOM, wyOf = (py) => DOM - (py - y0) / side * 2 * DOM;
    st._g = { x0, y0, side, sx, sy, wxOf, wyOf };

    ctx.fillStyle = colors.fg; ctx.font = 'bold 13px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillText('the weight is built from the data points; drag one up or down to change its αᵢ', pad, pad + 13);

    // signed decision field f(x) = Σ αᵢ k(xᵢ, x)
    const f = (X, Y) => { let s = 0; for (const p of st.pts) s += p.a * kern(p.x, p.y, X, Y); return s; };
    let maxa = 1e-6; for (let r = 0; r < HM; r++) for (let cc = 0; cc < HM; cc++) { const X = wxOf(x0 + (cc + 0.5) * side / HM), Y = wyOf(y0 + (r + 0.5) * side / HM); maxa = Math.max(maxa, Math.abs(f(X, Y))); }
    const bg = hex(colors.bg), cb = hex(BLUE), co = hex(ORANGE), cell = side / HM;
    for (let r = 0; r < HM; r++) for (let cc = 0; cc < HM; cc++) {
      const X = wxOf(x0 + (cc + 0.5) * cell), Y = wyOf(y0 + (r + 0.5) * cell); const v = f(X, Y) / maxa;
      const col = v >= 0 ? co : cb; const a = 0.55 * Math.min(1, Math.abs(v));
      ctx.fillStyle = `rgba(${col[0]},${col[1]},${col[2]},${a})`; ctx.fillRect(x0 + cc * cell, y0 + r * cell, cell + 0.6, cell + 0.6);
    }
    // zero contour (decision boundary) by marching the sign on a finer grid sample
    ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.4; ctx.globalAlpha = 0.7;
    const NB = 140; for (let r = 0; r < NB; r++) for (let cc = 0; cc < NB; cc++) {
      const X = wxOf(x0 + (cc + 0.5) * side / NB), Y = wyOf(y0 + (r + 0.5) * side / NB);
      const v = f(X, Y), vr = f(wxOf(x0 + (cc + 1.5) * side / NB), Y), vd = f(X, wyOf(y0 + (r + 1.5) * side / NB));
      if ((v > 0) !== (vr > 0) || (v > 0) !== (vd > 0)) { ctx.fillStyle = colors.fg; ctx.fillRect(x0 + (cc + 0.5) * side / NB, y0 + (r + 0.5) * side / NB, 1.4, 1.4); }
    }
    ctx.globalAlpha = 1;
    ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(x0 + 0.5, y0 + 0.5, side - 1, side - 1);

    // anchors: ring = true class, radius ∝ |αᵢ|, fill sign = sign(αᵢ)
    for (const p of st.pts) {
      const X = sx(p.x), Y = sy(p.y); const R = 5 + 16 * Math.min(1, Math.abs(p.a));
      ctx.globalAlpha = 0.85; ctx.fillStyle = p.a >= 0 ? ORANGE : BLUE; ctx.beginPath(); ctx.arc(X, Y, R, 0, 6.283); ctx.fill();
      ctx.globalAlpha = 1; ctx.lineWidth = 2.4; ctx.strokeStyle = p.c ? BLUE : ORANGE; ctx.beginPath(); ctx.arc(X, Y, R + 2.5, 0, 6.283); ctx.stroke();
      ctx.fillStyle = colors.fg; ctx.font = '9px ui-monospace, monospace'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(p.a.toFixed(1), X, Y);
    }

    const nz = st.pts.filter((p) => Math.abs(p.a) > 0.05).length;
    api.readout('rd', `f = Σ αᵢ k(xᵢ, ·) over ${nz}/${st.pts.length} points · ring = class, fill = sign αᵢ, size = |αᵢ| · drag a point up/down`);
  },
});

function bind(api) {
  if (api.canvas.dataset.rbBound) return; api.canvas.dataset.rbBound = '1'; api.canvas.style.cursor = 'ns-resize';
  const at = (e) => { const rc = api.canvas.getBoundingClientRect(); return { px: (e.clientX - rc.left) * api.size.W / rc.width, py: (e.clientY - rc.top) * api.size.H / rc.height }; };
  api.canvas.addEventListener('pointerdown', (e) => {
    const st = api.state, g = st && st._g; if (!g) return; const { px, py } = at(e);
    let best = -1, bd = 24; st.pts.forEach((p, i) => { const d = Math.hypot(px - g.sx(p.x), py - g.sy(p.y)); if (d < bd) { bd = d; best = i; } });
    if (best >= 0) { st.drag = best; st.dragY0 = py; st.a0 = st.pts[best].a; }
  });
  api.canvas.addEventListener('pointermove', (e) => { const st = api.state, g = st && st._g; if (!g || st.drag < 0) return; const { py } = at(e); st.pts[st.drag].a = Math.max(-1.4, Math.min(1.4, st.a0 + (st.dragY0 - py) / 90)); api.render(); });
  const up = () => { if (api.state) api.state.drag = -1; };
  api.canvas.addEventListener('pointerup', up); api.canvas.addEventListener('pointercancel', up);
}
</script>
