---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 440 } = Astro.props;
---
<figure class="viz toldial" data-caption={caption} data-height={height} data-height-mobile="530" tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// One dial, no retraining: crank the tolerance and this panel re-renders 120
// held-out inputs through the trained net at that precision, live, reporting
// accuracy and mean work. Below, the run's measured dial positions on log-log
// axes: accepted steps against tolerance, riding the slope -1/3 line that a
// second-order integrator's error control predicts.
import { defineViz } from './engine/vizkit.js';
import { T, dot, fmt, axes, gate, loadingText, legend } from './engine/draw.js';
import { load, renderAdaptive } from './adepth.js';

const TOLS = [0.3, 0.1, 0.03, 0.01, 0.003];
const NEVAL = 120;

defineViz('toldial', {
  title: 'Precision as a dial',
  height: 440,
  autoplay: false,
  controls: [
    { type: 'select', name: 'tol', label: 'tolerance', value: '0.03',
      options: TOLS.map((t) => ({ value: String(t), label: `tol ${t}` })) },
    { type: 'select', name: 'ds', label: 'dataset', value: 'spirals',
      options: [{ value: 'moons', label: 'moons' }, { value: 'rings', label: 'rings' }, { value: 'spirals', label: 'spirals' }] },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    const st = api.state;
    st.live = null;
    gate(api, () => Promise.all([load('models'), load('sweep')]), (a, d) => {
      a.state.models = d[0]; a.state.sweep = d[1];
    });
  },

  draw(api) {
    const { ctx, colors, size: { W, H } } = api, st = api.state;
    if (!st.ready || !st.models) { loadingText(api); return; }
    const tol = parseFloat(api.get('tol')), ds = api.get('ds');
    if (!st.live || st.tol !== tol || st.ds !== ds) {
      st.tol = tol; st.ds = ds;
      const mm = st.models[ds];
      let correct = 0, work = 0;
      const works = [];
      for (let i = 0; i < NEVAL; i++) {
        const res = renderAdaptive(mm.model, mm.X[i], tol);
        if ((res.logits[1] > res.logits[0] ? 1 : 0) === mm.y[i]) correct++;
        work += res.work; works.push(res.work);
      }
      st.live = { acc: correct / NEVAL, work: work / NEVAL, works };
    }

    const pad = 16;
    // top: work histogram at this tol, live
    const hbox = { x: pad + 30, y: 34, w: W - 2 * pad - 40, h: (H - 170) / 2 - 20 };
    const works = st.live.works, wmax = Math.max(...works), wmin = Math.min(...works);
    const bins = new Array(16).fill(0);
    works.forEach((w) => bins[Math.min(15, Math.floor(((w - wmin) / Math.max(1, wmax - wmin)) * 15.999))]++);
    const bmax = Math.max(...bins);
    axes(ctx, hbox, { xMin: wmin, xMax: wmax, yMin: 0, yMax: bmax, xTicks: [wmin, Math.round((wmin + wmax) / 2), wmax], yTicks: [] }, colors);
    T(ctx, colors, 'label');
    ctx.fillText(`work per input at tol ${tol}, 120 inputs rendered live in your browser`, hbox.x, hbox.y - 8);
    bins.forEach((b, i) => {
      const bw = hbox.w / 16;
      ctx.fillStyle = '#4a7fb388';
      ctx.fillRect(hbox.x + i * bw + 1, hbox.y + (1 - b / bmax) * hbox.h, bw - 2, (b / bmax) * hbox.h);
    });

    // bottom: the run's measured accepted-vs-tol on log-log + slope -1/3 guide
    const lbox = { x: pad + 30, y: hbox.y + hbox.h + 44, w: W - 2 * pad - 40, h: (H - 190) / 2 - 20 };
    const rows = st.sweep[ds].rows;
    const lx = (t) => lbox.x + ((Math.log10(t) - Math.log10(0.003)) / (Math.log10(0.3) - Math.log10(0.003))) * lbox.w;
    const ly = (a) => lbox.y + (1 - (Math.log10(a) - Math.log10(10)) / (Math.log10(120) - Math.log10(10))) * lbox.h;
    axes(ctx, lbox, { xMin: 0, xMax: 1, yMin: 0, yMax: 1, xTicks: [], yTicks: [] }, colors);
    T(ctx, colors, 'label');
    ctx.fillText('the run: accepted steps against tolerance, log-log, with the slope -1/3 of a second-order method', lbox.x, lbox.y - 8);
    T(ctx, colors, 'small');
    TOLS.forEach((t) => { ctx.fillText(String(t), lx(t) - 8, lbox.y + lbox.h + 14); });
    [16, 32, 64].forEach((a) => { ctx.fillText(String(a), lbox.x - 24, ly(a) + 4); });
    // guide line slope -1/3 through the middle measured point
    const mid = rows[2];
    ctx.setLineDash([5, 4]); ctx.strokeStyle = colors.border; ctx.lineWidth = 1.2; ctx.beginPath();
    const a0 = mid.accepted * Math.pow(0.3 / mid.tol, -1 / 3);
    const a1 = mid.accepted * Math.pow(0.003 / mid.tol, -1 / 3);
    ctx.moveTo(lx(0.3), ly(a0)); ctx.lineTo(lx(0.003), ly(a1)); ctx.stroke(); ctx.setLineDash([]);
    ctx.strokeStyle = '#c2553a'; ctx.lineWidth = 1.8; ctx.beginPath();
    rows.forEach((r, i) => {
      const x = lx(r.tol), y = ly(r.accepted);
      i ? ctx.lineTo(x, y) : ctx.moveTo(x, y);
    });
    ctx.stroke();
    rows.forEach((r) => dot(ctx, lx(r.tol), ly(r.accepted), 4, r.tol === tol ? '#e8a33a' : '#c2553a'));

    const fixedAcc = st.sweep[ds].acc_fixed;
    api.readout('rd', `tol ${tol}: accuracy ${fmt(st.live.acc * 100, 1)}% (fixed-depth ${fmt(fixedAcc * 100, 1)}%), mean work ${fmt(st.live.work, 1)} evaluations`);
  },
});
</script>
