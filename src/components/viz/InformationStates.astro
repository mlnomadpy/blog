---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 470 } = Astro.props;
---
<figure class="viz informationstates" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { panel, unitCircle, dot, text, PALETTE } from './engine/draw.js';
import * as ng from './engine/nanograd.js';

// The three states of information, live. A supervised contrastive encoder maps
// class blobs onto the circle. Watch the representation pass through three phases:
// RANDOM (scattered, no class structure), ORGANIZED (same-class points cluster,
// but the clusters are not yet spread), STRUCTURED (the clusters settle into a
// maximally-separated simplex). The loss falls in a slow-then-fast way, and the
// structure metric climbs during the slow stretch; the plateau is where the
// reorganization happens before it shows up in the loss. nanograd autodiff.
const D = 6, HID = 16, DE = 2, M = 12;
const randn = () => { const u = Math.random() || 1e-9, v = Math.random(); return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v); };

defineViz('informationstates', {
  title: 'Random → organized → structured',
  height: 470, stepsPerFrame: 0.22, maxStep: 900,
  controls: [
    { type: 'play' }, { type: 'step' }, { type: 'button', name: 'reroll', label: 're-roll', reset: true },
    { type: 'speed', presets: [0.5, 1, 2] },
    { type: 'range', name: 'K', label: 'classes', min: 3, max: 5, step: 1, value: 4, int: true, reset: true, fmt: v => v },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    const K = api.get('K'), N = K * M;
    const X = new Float64Array(N * D), labels = new Int32Array(N);
    const centres = [];
    for (let c = 0; c < K; c++) { const ce = new Float64Array(D); for (let k = 0; k < D; k++) ce[k] = randn() * 1.3; centres.push(ce); }
    for (let c = 0; c < K; c++) for (let p = 0; p < M; p++) { const i = c * M + p; labels[i] = c; for (let k = 0; k < D; k++) X[i * D + k] = centres[c][k] + randn() * 0.6; }
    const Xt = ng.tensor(N, D, X);
    const mp = new Float64Array(N * N), mm = new Float64Array(N * N); let nP = 0, nM = 0;
    for (let i = 0; i < N; i++) for (let j = 0; j < N; j++) { if (i === j) continue; if (labels[i] === labels[j]) { mp[i * N + j] = 1; nP++; } else { mm[i * N + j] = 1; nM++; } }
    const Mp = ng.tensor(N, N, mp), Mm = ng.tensor(N, N, mm);
    const W1 = ng.param(D, HID, () => randn() * Math.sqrt(2 / D)), b1 = ng.param(1, HID, () => 0);
    const W2 = ng.param(HID, DE, () => randn() * 0.3), b2 = ng.param(1, DE, () => 0);
    const enc = () => ng.normRows(ng.add(ng.matmul(ng.relu(ng.add(ng.matmul(Xt, W1), b1)), W2), b2));
    api.state = {
      K, N, labels, enc,
      adam: new ng.Adam([W1, b1, W2, b2], 0.01),
      lossFn: () => {
        const z = enc(), S = ng.matmul(z, ng.transpose(z)), y = ng.yatk(S, 0.5, 0.5);
        const intra = ng.div(ng.sumAll(ng.mul(ng.recip(ng.addk(y, 1)), Mp)), ng.scalar(nP));
        const inter = ng.div(ng.sumAll(ng.mul(ng.addk(y, 1), Mm)), ng.scalar(nM));
        return ng.add(intra, inter);
      },
      hist: [], shist: [], loss0: null,
    };
  },
  step(api) {
    const L = api.state.lossFn();
    ng.backward(L);
    api.state.adam.step();
    if (api.state.loss0 == null) api.state.loss0 = L.d[0];
    api.state.hist.push(L.d[0]);
    // structure score sampled from current embedding
    api.state.shist.push(api.state._struct ?? 0);
    if (api.state.hist.length > 1500) { api.state.hist.shift(); api.state.shist.shift(); }
  },
  draw(api) {
    const { ctx, colors, size, state } = api;
    const box = { x: 6, y: 4, w: size.W - 12, h: size.H - 8 };
    panel(ctx, box, colors, {});
    const K = state.K, N = state.N, labels = state.labels;
    const z = state.enc();

    // class means + metrics
    const cen = [];
    for (let c = 0; c < K; c++) { let sx = 0, sy = 0; for (let i = 0; i < N; i++) if (labels[i] === c) { sx += z.d[i * DE]; sy += z.d[i * DE + 1]; } const nn = Math.hypot(sx, sy) + 1e-9; cen.push([sx / nn, sy / nn]); }
    // intra tightness: mean cos(point, its class mean)
    let intra = 0; for (let i = 0; i < N; i++) { const c = labels[i]; intra += z.d[i * DE] * cen[c][0] + z.d[i * DE + 1] * cen[c][1]; } intra /= N;
    // separation: mean pairwise class-mean cosine (lower = more spread); target = -1/(K-1)
    let meanCos = 0, cnt = 0, minCos = 1;
    for (let a = 0; a < K; a++) for (let b = a + 1; b < K; b++) { const cc = cen[a][0] * cen[b][0] + cen[a][1] * cen[b][1]; meanCos += cc; cnt++; minCos = Math.min(minCos, cc); }
    meanCos /= Math.max(1, cnt);
    const sep = (1 - meanCos) / (1 + 1 / (K - 1));           // 0..~1, →1 at simplex
    const tight = Math.max(0, Math.min(1, (intra - 0.3) / 0.65));
    const struct = Math.max(0, Math.min(1, tight * sep));
    state._struct = struct;

    // state label
    let label, lcol;
    if (tight < 0.55) { label = 'RANDOM'; lcol = colors.muted; }
    else if (sep < 0.6) { label = 'ORGANIZED'; lcol = colors.blue; }
    else { label = 'STRUCTURED'; lcol = colors.green; }

    // ── left: embedding on the circle ──
    const half = (box.w - 26) / 2;
    const lb = { x: box.x + 10, y: box.y + 28, w: half, h: box.h - 60 };
    const m = panel(ctx, lb, colors, { header: 22 });
    text(ctx, 'representation (L2-normalized)', lb.x + 8, lb.y + 5, colors, { size: 11.5, color: colors.fg });
    unitCircle(ctx, m, colors);
    ctx.globalAlpha = 0.65;
    for (let i = 0; i < N; i++) { const [px, py] = m.map([z.d[i * DE], z.d[i * DE + 1]]); dot(ctx, px, py, 2.4, PALETTE[labels[i] % PALETTE.length]); }
    ctx.globalAlpha = 1;
    for (let c = 0; c < K; c++) { const [px, py] = m.map(cen[c]); ctx.beginPath(); ctx.arc(px, py, 6, 0, 2 * Math.PI); ctx.fillStyle = PALETTE[c % PALETTE.length]; ctx.fill(); ctx.lineWidth = 2; ctx.strokeStyle = colors.bg; ctx.stroke(); }

    // ── right: state badge + curves ──
    const rb = { x: box.x + box.w - half - 10, y: box.y + 28, w: half, h: box.h - 60 };
    // badge
    ctx.fillStyle = lcol + '22'; ctx.strokeStyle = lcol; ctx.lineWidth = 1.2;
    ctx.beginPath(); ctx.roundRect(rb.x, rb.y, rb.w, 30, 6); ctx.fill(); ctx.stroke();
    text(ctx, label, rb.x + rb.w / 2, rb.y + 15, colors, { align: 'center', baseline: 'middle', size: 14, weight: '700', color: lcol });
    // curves panel
    const cp = { x: rb.x, y: rb.y + 40, w: rb.w, h: rb.h - 40 };
    panel(ctx, cp, colors, {});
    text(ctx, 'loss', cp.x + 8, cp.y + 5, colors, { size: 10.5, mono: true, color: colors.accent });
    text(ctx, 'structure', cp.x + cp.w - 8, cp.y + 5, colors, { align: 'right', size: 10.5, mono: true, color: colors.green });
    const hist = state.hist, sh = state.shist, n = hist.length, l0 = state.loss0 || 1;
    const sx = (i) => cp.x + 8 + (n < 2 ? 0 : (i / (n - 1)) * (cp.w - 16));
    if (n >= 2) {
      // loss (normalized to its own max)
      const lmax = Math.max(...hist, 1e-9);
      ctx.strokeStyle = colors.accent; ctx.lineWidth = 1.8; ctx.beginPath();
      for (let i = 0; i < n; i++) { const py = cp.y + 22 + (1 - hist[i] / lmax) * (cp.h - 40); const px = sx(i); i ? ctx.lineTo(px, py) : ctx.moveTo(px, py); }
      ctx.stroke();
      // structure 0..1
      ctx.strokeStyle = colors.green; ctx.lineWidth = 1.8; ctx.beginPath();
      for (let i = 0; i < n; i++) { const py = cp.y + 22 + (1 - sh[i]) * (cp.h - 40); const px = sx(i); i ? ctx.lineTo(px, py) : ctx.moveTo(px, py); }
      ctx.stroke();
    }
    text(ctx, 'iteration →', cp.x + cp.w / 2, cp.y + cp.h - 13, colors, { align: 'center', size: 9.5, mono: true, color: colors.muted });

    const note = `tightness ${intra.toFixed(2)} · min class-pair cos ${minCos.toFixed(2)} (simplex target ${(-1 / (K - 1)).toFixed(2)})`;
    text(ctx, note, box.x + 12, box.y + box.h - 16, colors, { size: 10, mono: true, color: colors.muted });
    api.readout('rd', `iter ${api.iter} · ${label.toLowerCase()}`);
  },
});
</script>
