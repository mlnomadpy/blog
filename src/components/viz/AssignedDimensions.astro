---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 380 } = Astro.props;
---
<figure class="viz assigndim" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// Where the dimensions come from, and what each one means. The image is cut into a
// 7x7 grid of patches; in every patch we measure all seven detectors. Patch times
// detector gives 343 numbers, and unlike a trained network's features, every one
// has a name you assigned: "how much 30-degree edge sits in this patch". Pick a
// detector to see its energy across the grid; hover a patch to read one dimension.
import { defineViz } from './engine/vizkit.js';
import { loadHB, samplesImg, CHAN_COL } from './handbuilt.js';
import { gate, loadingText } from './engine/draw.js';

defineViz('assigndim', {
  title: 'Every dimension is a named detector at a patch',
  height: 380,
  controls: [
    { type: 'range', name: 'sample', label: 'garment', min: 0, max: 59, step: 1, value: 2, int: true, reset: false, fmt: (v) => v },
    { type: 'range', name: 'ch', label: 'detector', min: 0, max: 6, step: 1, value: 3, int: true, reset: false, fmt: (v) => (v < 6 ? v * 30 + '°' : 'corner') },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    api.state.hover = -1;
    gate(api, () => Promise.all([loadHB(), samplesImg()]), (api, [d, imgs]) => {
      Object.assign(api.state, { d, imgs }); bind(api);
    });
  },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H;
    if (W === 0 || !st) return;
    ctx.clearRect(0, 0, W, H);
    if (!st.ready) { loadingText(api); return; }
    const d = st.d, G = d.GRID, NC = d.nChan, k = api.get('sample'), ch = api.get('ch');
    const s = d.samples[k], raw = s.featRaw || s.feat;
    const chName = ch === NC - 1 ? 'corner' : `${d.centersDeg[ch]}°`;

    const pad = 16, top = 34;
    ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillStyle = colors.muted; ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillText(`a ${G}x${G} grid of patches, ${NC} detectors each, ${d.dim} named dimensions. hover a patch.`, pad, 18);

    const side = Math.min((W - pad * 3) / 2, H - top - 36);
    const lx = pad + (W - pad * 2 - side * 2 - pad) / 2, rx = lx + side + pad, y0 = top;
    const cw = side / G;

    // selected channel's pooled energy across the grid, normalised for display
    const vals = new Float64Array(G * G); let mx = 1e-6;
    for (let r = 0; r < G; r++) for (let c = 0; c < G; c++) { const v = raw[ch * G * G + r * G + c]; vals[r * G + c] = v; if (v > mx) mx = v; }
    const col = CHAN_COL[ch], cr = parseInt(col.slice(1, 3), 16), cg = parseInt(col.slice(3, 5), 16), cb = parseInt(col.slice(5, 7), 16);

    // LEFT: the garment with the grid drawn over it
    ctx.imageSmoothingEnabled = true;
    ctx.drawImage(st.imgs, (k % 10) * 28, ((k / 10) | 0) * 28, 28, 28, lx, y0, side, side);
    ctx.strokeStyle = colors.border; ctx.lineWidth = 1;
    for (let g = 0; g <= G; g++) { const t = g * cw; ctx.beginPath(); ctx.moveTo(lx + t, y0); ctx.lineTo(lx + t, y0 + side); ctx.moveTo(lx, y0 + t); ctx.lineTo(lx + side, y0 + t); ctx.stroke(); }
    ctx.fillStyle = colors.fg; ctx.font = 'bold 11px ui-sans-serif, system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    ctx.fillText(`${d.classes[s.label]} cut into patches`, lx + side / 2, y0 + side + 7);

    // RIGHT: that detector's energy in each patch
    for (let r = 0; r < G; r++) for (let c = 0; c < G; c++) {
      const t = Math.pow(vals[r * G + c] / mx, 0.7), x = rx + c * cw, y = y0 + r * cw;
      ctx.fillStyle = `rgb(${(24 + (cr - 24) * t) | 0},${(22 + (cg - 22) * t) | 0},${(20 + (cb - 20) * t) | 0})`;
      ctx.fillRect(x, y, cw + 0.5, cw + 0.5);
    }
    ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(rx + 0.5, y0 + 0.5, side - 1, side - 1);
    ctx.fillStyle = CHAN_COL[ch]; ctx.font = 'bold 11px ui-sans-serif, system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    ctx.fillText(`detector "${chName}" across the grid`, rx + side / 2, y0 + side + 7);

    // hover highlight on both panels
    st._geo = { lx, rx, y0, side, cw, G };
    if (st.hover >= 0) {
      const hr = (st.hover / G) | 0, hc = st.hover % G;
      ctx.strokeStyle = colors.accent; ctx.lineWidth = 2.5;
      ctx.strokeRect(lx + hc * cw, y0 + hr * cw, cw, cw);
      ctx.strokeRect(rx + hc * cw, y0 + hr * cw, cw, cw);
    }

    api.readout('rd', st.hover >= 0
      ? `dimension "${chName} at patch (${(st.hover / G | 0) + 1}, ${st.hover % G + 1})" = ${raw[ch * G * G + (st.hover / G | 0) * G + (st.hover % G)].toFixed(3)}`
      : `${d.dim} dimensions = ${NC} detectors x ${G * G} patches. showing detector "${chName}". every axis is something you can name.`);
  },
});

function bind(api) {
  if (api.canvas.dataset.adBound) return; api.canvas.dataset.adBound = '1';
  api.canvas.addEventListener('pointermove', (e) => {
    const st = api.state; if (!st || !st._geo) return;
    const g = st._geo, rc = api.canvas.getBoundingClientRect();
    const px = (e.clientX - rc.left) * api.size.W / rc.width, py = (e.clientY - rc.top) * api.size.H / rc.height;
    let cell = -1;
    for (const ox of [g.lx, g.rx]) if (px >= ox && px < ox + g.side && py >= g.y0 && py < g.y0 + g.side) {
      const c = Math.min(g.G - 1, ((px - ox) / g.cw) | 0), r = Math.min(g.G - 1, ((py - g.y0) / g.cw) | 0); cell = r * g.G + c;
    }
    if (cell !== st.hover) { st.hover = cell; api.render(); }
  });
  api.canvas.addEventListener('pointerleave', () => { if (api.state) { api.state.hover = -1; api.render(); } });
}
</script>
