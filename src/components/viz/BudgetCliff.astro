---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 420 } = Astro.props;
---
<figure class="viz budgetcliff" data-caption={caption} data-height={height} data-height-mobile="500" tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The nine measured gradient agreements from the run, against the one-line
// prediction. For each friction mu, the dashed vertical marks the depth where
// (1/mu)^L x eps32 reaches 1, the napkin estimate of where float noise
// amplified by the rewind catches up with the signal. The measured cliffs
// fall where the arithmetic said they would. Move the pointer along a curve
// to read exact values.
import { defineViz } from './engine/vizkit.js';
import { T, dot, fmt, axes, gate, loadingText, legend } from './engine/draw.js';
import { load } from './revmem.js';

const EPS32 = 1.1920929e-7;
const MUS = [{ mu: 0.9, col: '#4a7fb3' }, { mu: 0.6, col: '#8a6fb3' }, { mu: 0.3, col: '#c2553a' }];
const LMIN = 8, LMAX = 128;

defineViz('budgetcliff', {
  title: 'Where the gradient dies, predicted and measured',
  height: 420,
  autoplay: false,
  controls: [{ type: 'readout', name: 'rd' }],

  setup(api) {
    gate(api, () => load(), (a, d) => { a.state.fid = d.fidelity; });
    api.state.hover = null;
  },

  pointer(api, ev) {
    const st = api.state;
    if (!st.fid || !st.box) return;
    const { x, y } = ev;
    let best = null, bd = 26;
    st.pts?.forEach((p) => {
      const d = Math.hypot(p.px - x, p.py - y);
      if (d < bd) { bd = d; best = p; }
    });
    st.hover = best;
    api.requestDraw?.();
  },

  draw(api) {
    const { ctx, colors, size: { W, H } } = api, st = api.state;
    if (!st.ready || !st.fid) { loadingText(api); return; }
    const pad = 16, box = { x: pad + 34, y: 34, w: W - 2 * pad - 40, h: H - 150 };
    st.box = box;
    const lx = (L) => box.x + ((Math.log2(L) - 3) / (7 - 3)) * box.w; // L: 8..128
    const cy = (c) => box.y + (1 - Math.max(0, c)) * box.h;

    axes(ctx, box, { xMin: 3, xMax: 7, yMin: 0, yMax: 1, grid: true,
                     xTicks: [3, 4, 5, 6, 7], fmtX: (v) => String(2 ** v),
                     yTicks: [0, 0.5, 1] }, colors);
    T(ctx, colors, 'label');
    ctx.fillText('gradient agreement (cosine, reversible vs stored) against depth', box.x, box.y - 8);
    ctx.save(); ctx.translate(pad + 2, box.y + box.h / 2); ctx.rotate(-Math.PI / 2);
    T(ctx, colors, 'small'); ctx.textAlign = 'center'; ctx.fillText('cosine', 0, 0);
    ctx.restore(); ctx.textAlign = 'left';

    st.pts = [];
    MUS.forEach(({ mu, col }) => {
      const rows = st.fid.filter((r) => r.mu === mu);
      // predicted death: (1/mu)^L * eps32 = 1  ->  L* = ln(1/eps32)/ln(1/mu)
      const Lstar = Math.log(1 / EPS32) / Math.log(1 / mu);
      if (Lstar >= LMIN && Lstar <= LMAX) {
        const x = lx(Lstar);
        ctx.setLineDash([5, 4]); ctx.strokeStyle = col; ctx.lineWidth = 1.2;
        ctx.beginPath(); ctx.moveTo(x, box.y); ctx.lineTo(x, box.y + box.h); ctx.stroke();
        ctx.setLineDash([]);
        T(ctx, colors, 'small'); ctx.fillStyle = col;
        ctx.fillText(`predicted L* = ${fmt(Lstar, 0)}`, x + 4, box.y + 14 + MUS.findIndex((m) => m.mu === mu) * 14);
      }
      ctx.strokeStyle = col; ctx.lineWidth = 1.8; ctx.beginPath();
      rows.forEach((r, i) => {
        const c = r.cosine === null ? 0 : r.cosine;
        const x = lx(r.L), y = cy(c);
        i ? ctx.lineTo(x, y) : ctx.moveTo(x, y);
      });
      ctx.stroke();
      rows.forEach((r) => {
        const c = r.cosine === null ? 0 : r.cosine;
        const x = lx(r.L), y = cy(c);
        dot(ctx, x, y, 4, col);
        if (r.cosine === null) {
          T(ctx, colors, 'small'); ctx.fillStyle = col;
          ctx.fillText('nan', x - 8, y - 8);
        }
        st.pts.push({ px: x, py: y, mu, L: r.L, cos: r.cosine, rel: r.rel_err, budget: r.budget });
      });
    });

    legend(ctx, pad, H - 66, MUS.map(({ mu, col }) => ({ color: col, label: `mu = ${mu}` })), colors);
    T(ctx, colors, 'small');
    ctx.fillText('dashed verticals: the napkin prediction (1/mu)^L x eps32 = 1, computed before looking at the measurements', pad, H - 22);

    const hv = st.hover;
    api.readout('rd', hv
      ? `mu ${hv.mu}, depth ${hv.L}: cosine ${hv.cos === null ? 'nan' : fmt(hv.cos, 6)}, noise budget ${hv.budget.toExponential(1)}`
      : 'hover a measured point for its exact cosine and noise budget');
  },
});
</script>
