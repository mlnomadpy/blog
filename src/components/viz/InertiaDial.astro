---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 480 } = Astro.props;
---
<figure class="viz inertiadial" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The inertia dial. Four networks with identical architecture and parameter
// count were really trained on the rings task, differing only in the damping
// mu of their velocity state (mu = 0 is the plain residual net). This panel
// loads their exact trained weights and runs the real forward dynamics live in
// the browser: the decision field over the plane, the accuracy on 256 held-out
// points, and a few hidden trajectories are all recomputed on the spot when
// you turn the dial. Every net closes a contour around the inner disk (the
// scoreboard is nearly blind to mu); what the dial changes is the dynamics
// that build it, visible in the six probe trajectories.
import { defineViz } from './engine/vizkit.js';
import { panel, dot, T, heatmapField, parseColor, gate, loadingText } from './engine/draw.js';
import { loadInertia, netRunner, rollForward, CLS } from './momres.js';

const MUS = ['0.0', '0.3', '0.6', '0.9'];
const GRID = 44, VIEW = 2.3;

defineViz('inertiadial', {
  title: 'Turn the inertia up: four really-trained nets, integrated live',
  height: 480,
  controls: [
    { type: 'range', name: 'mi', label: 'velocity memory mu', min: 0, max: 3, step: 1, value: 0, int: true, reset: false, fmt: (v) => MUS[v] },
    { type: 'toggle', name: 'paths', label: 'show hidden trajectories', value: true },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    gate(api, loadInertia, (api, d) => {
      api.state.d = d;
      api.state.fields = {};   // muKey -> Float32Array of p(class 1) on the grid
      api.state.accs = {};     // muKey -> live accuracy on the exported test set
      api.state.trajs = {};    // muKey -> a few float64 trajectories
      // probe points for the live trajectories: 3 inner, 3 outer, spread
      const X = d.test_X, y = d.test_y, probes = [];
      for (const c of [0, 1]) {
        const cand = [];
        for (let i = 0; i < y.length; i++) if (y[i] === c) cand.push(i);
        cand.sort((a, b) => Math.atan2(X[a][1], X[a][0]) - Math.atan2(X[b][1], X[b][0]));
        for (let k = 0; k < 3; k++) probes.push(cand[Math.floor((k + 0.3) * cand.length / 3)]);
      }
      api.state.probes = probes;
    });
  },
  draw(api) {
    const { ctx, colors, size, state: st } = api;
    if (!st || !st.ready) { loadingText(api, 'loading the four trained nets…'); return; }
    const d = st.d, muKey = MUS[api.get('mi')];

    // live compute, once per dial position, then cached
    if (!st.fields[muKey]) {
      const run = netRunner(d, muKey);
      const pts = [];
      for (let r = 0; r < GRID; r++) for (let c = 0; c < GRID; c++)
        pts.push([-VIEW + (2 * VIEW * c) / (GRID - 1), VIEW - (2 * VIEW * r) / (GRID - 1)]);
      st.fields[muKey] = Float32Array.from(run.probs(pts));
      const p1 = run.probs(d.test_X);
      let ok = 0;
      for (let i = 0; i < p1.length; i++) if ((p1[i] > 0.5 ? 1 : 0) === d.test_y[i]) ok++;
      st.accs[muKey] = (100 * ok) / p1.length;
      st.trajs[muKey] = st.probes.map((i) => ({
        y: d.test_y[i],
        path: rollForward(d.nets[muKey], d.h, d.test_X[i]).map((s) => s.x),
      }));
    }

    const m = panel(ctx, { x: 6, y: 0, w: size.W - 12, h: size.H }, colors, { header: 26 });
    const net = d.nets[muKey];
    T(ctx, colors, 'label', { color: colors.fg, weight: 'b' });
    ctx.fillText(`trained at mu = ${net.mu}`, 16, 17);
    T(ctx, colors, 'label', { color: colors.muted, align: 'right' });
    ctx.fillText(`live accuracy on 256 held-out points: ${st.accs[muKey].toFixed(1)}%`, size.W - 16, 17);

    // decision field p(outer class), orange -> blue across the boundary
    const field = st.fields[muKey];
    const side = Math.max(m.R * 2, m.side - 10), box = { x: m.cx - side / 2, y: m.cy - side / 2, w: side, h: side };
    heatmapField(ctx, box, (u, v) => {
      const c = Math.min(GRID - 1, Math.round(u * (GRID - 1)));
      const r = Math.min(GRID - 1, Math.round(v * (GRID - 1)));
      return field[r * GRID + c];
    }, GRID, colors, { version: muKey + '|' + colors.accent, gamma: 1, cap: 1, base: parseColor('#d8b58f'), hi: parseColor('#4a7fb3') });

    // p = 0.5 boundary contour (marching squares on the live field)
    const px = (x, y) => [box.x + ((x + VIEW) / (2 * VIEW)) * side, box.y + ((VIEW - y) / (2 * VIEW)) * side];
    ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.6;
    const gxy = (r, c) => [-VIEW + (2 * VIEW * c) / (GRID - 1), VIEW - (2 * VIEW * r) / (GRID - 1)];
    ctx.beginPath();
    for (let r = 0; r < GRID - 1; r++) for (let c = 0; c < GRID - 1; c++) {
      const v00 = field[r * GRID + c] - 0.5, v01 = field[r * GRID + c + 1] - 0.5;
      const v10 = field[(r + 1) * GRID + c] - 0.5, v11 = field[(r + 1) * GRID + c + 1] - 0.5;
      const pts = [];
      const cut = (a, b, pa, pb) => { if ((a < 0) !== (b < 0)) { const t = a / (a - b); pts.push([pa[0] + t * (pb[0] - pa[0]), pa[1] + t * (pb[1] - pa[1])]); } };
      const p00 = gxy(r, c), p01 = gxy(r, c + 1), p10 = gxy(r + 1, c), p11 = gxy(r + 1, c + 1);
      cut(v00, v01, p00, p01); cut(v01, v11, p01, p11); cut(v11, v10, p11, p10); cut(v10, v00, p10, p00);
      if (pts.length === 2) { const a = px(pts[0][0], pts[0][1]), b = px(pts[1][0], pts[1][1]); ctx.moveTo(a[0], a[1]); ctx.lineTo(b[0], b[1]); }
    }
    ctx.stroke();

    // the held-out points (light outline so the blue class reads on the blue field)
    for (let i = 0; i < d.test_X.length; i++) {
      const p = px(d.test_X[i][0], d.test_X[i][1]);
      if (p[0] < box.x || p[0] > box.x + side || p[1] < box.y || p[1] > box.y + side) continue;
      dot(ctx, p[0], p[1], 1.9, CLS[d.test_y[i]]);
      ctx.strokeStyle = 'rgba(255,255,255,0.55)'; ctx.lineWidth = 0.7;
      ctx.beginPath(); ctx.arc(p[0], p[1], 2.2, 0, 6.283); ctx.stroke();
    }

    // live hidden trajectories of six probe points
    if (api.get('paths')) {
      for (const t of st.trajs[muKey]) {
        ctx.strokeStyle = t.y ? '#31597f' : '#7a4512';   // darker class colours so the paths read over the field
        ctx.lineWidth = 1.7; ctx.globalAlpha = 0.9; ctx.beginPath();
        let started = false;
        for (const s of t.path) {
          const p = px(s[0], s[1]);
          const inb = p[0] > box.x && p[0] < box.x + side && p[1] > box.y && p[1] < box.y + side;
          if (!inb) { started = false; continue; }
          started ? ctx.lineTo(p[0], p[1]) : ctx.moveTo(p[0], p[1]); started = true;
        }
        ctx.stroke(); ctx.globalAlpha = 1;
        const last = t.path[t.path.length - 1], pl = px(last[0], last[1]);
        if (pl[0] > box.x && pl[0] < box.x + side && pl[1] > box.y && pl[1] < box.y + side)
          dot(ctx, pl[0], pl[1], 3.4, t.y ? '#31597f' : '#7a4512');
      }
    }
    api.readout('rd', `mu = ${net.mu} · field, contour, accuracy and paths computed live from the exported trained weights`);
  },
});
</script>
