---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 420 } = Astro.props;
---
<figure class="viz hierarchycascade" data-poster="hierarchycascade" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { panel, text, PALETTE } from './engine/draw.js';
import { np, withJax, drawJaxLoading } from './engine/jax.js';

const N = 12;
const NAMES = ['cat', 'dog', 'wolf', 'fox', 'car', 'bus', 'jet', 'ship', 'oak', 'fern', 'rose', 'palm'];
const GROUPS = ['animals', 'vehicles', 'plants'];
const G = i => Math.floor(i / 4);
const SUB = i => Math.floor((i % 4) / 2);

function modeValue(k, i) {
  if (k === 0) return [-1, 0, 1][G(i)];
  if (k === 1) return G(i) === 0 ? (SUB(i) ? 0.8 : -0.8) : 0;
  if (k === 2) return G(i) === 1 ? (SUB(i) ? 0.8 : -0.8) : 0;
  if (k === 3) return G(i) === 2 ? (SUB(i) ? 0.8 : -0.8) : 0;
  return (i % 2 ? 1 : -1) * 0.45;
}

function coords(depth, strength) {
  const lambdas = [1.4, depth >= 2 ? 0.85 : 0.05, depth >= 2 ? 0.85 : 0.05, depth >= 2 ? 0.85 : 0.05, depth >= 3 ? 0.42 : 0.03];
  const M = Array.from({ length: N }, (_, i) => Array.from({ length: 5 }, (_, k) => modeValue(k, i)));
  const W = [
    [0.85 * strength, 0],
    [0, 0.45 * strength],
    [0.22 * strength, 0.32 * strength],
    [-0.18 * strength, 0.42 * strength],
    [0, 0.25 * strength],
  ];
  const spectral = np.matmul(np.array(M), np.array(W)).js();
  return Array.from({ length: N }, (_, i) => {
    const circle = 2 * Math.PI * i / N;
    const x = (1 - strength) * Math.cos(circle) + spectral[i][0];
    const y = (1 - strength) * Math.sin(circle) + spectral[i][1];
    return {
      x,
      y,
      lambdas,
    };
  });
}

defineViz('hierarchycascade', {
  title: 'A hierarchy is a cascade of eigenmodes',
  height: 420,
  controls: [
    { type: 'range', name: 'depth', label: 'visible depth', min: 1, max: 3, step: 1, value: 2, int: true, fmt: v => v },
    { type: 'range', name: 'strength', label: 'hierarchy strength', min: 0, max: 1, step: 0.02, value: 0.9, fmt: v => v.toFixed(2) },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    withJax(api);
  },
  draw(api) {
    if (!api.state.jaxReady) return drawJaxLoading(api);
    const { ctx, colors, size } = api;
    const left = { x: 6, y: 4, w: size.W * 0.30 - 8, h: size.H - 8 };
    const mid = { x: size.W * 0.30 + 4, y: 4, w: size.W * 0.30 - 8, h: size.H - 8 };
    const right = { x: size.W * 0.60 + 4, y: 4, w: size.W * 0.40 - 10, h: size.H - 8 };
    panel(ctx, left, colors, {});
    panel(ctx, mid, colors, {});
    panel(ctx, right, colors, {});

    text(ctx, 'tree', left.x + 8, left.y + 6, colors, { size: 12, color: colors.fg, weight: '600' });
    const root = [left.x + left.w / 2, left.y + 42];
    ctx.fillStyle = colors.fg; ctx.beginPath(); ctx.arc(root[0], root[1], 4, 0, 2 * Math.PI); ctx.fill();
    const depth = api.get('depth');
    for (let g = 0; g < 3; g++) {
      const gx = left.x + left.w * (0.2 + 0.3 * g), gy = left.y + 105;
      ctx.strokeStyle = PALETTE[g]; ctx.globalAlpha = 0.65; ctx.lineWidth = 1.6;
      ctx.beginPath(); ctx.moveTo(root[0], root[1] + 4); ctx.lineTo(gx, gy - 5); ctx.stroke();
      ctx.globalAlpha = 1; ctx.fillStyle = PALETTE[g]; ctx.beginPath(); ctx.arc(gx, gy, 5, 0, 2 * Math.PI); ctx.fill();
      text(ctx, GROUPS[g], gx, gy + 12, colors, { align: 'center', size: 9.5, color: PALETTE[g] });
      for (let s = 0; s < 2 && depth >= 2; s++) {
        const sx = gx + (s ? 24 : -24), sy = left.y + 178;
        ctx.strokeStyle = PALETTE[g]; ctx.globalAlpha = 0.45; ctx.beginPath(); ctx.moveTo(gx, gy + 5); ctx.lineTo(sx, sy - 4); ctx.stroke(); ctx.globalAlpha = 1;
        ctx.fillStyle = PALETTE[g]; ctx.beginPath(); ctx.arc(sx, sy, 3.5, 0, 2 * Math.PI); ctx.fill();
        if (depth >= 3) for (let leaf = 0; leaf < 2; leaf++) {
          const lx = sx + (leaf ? 10 : -10), ly = left.y + 245;
          ctx.strokeStyle = colors.border; ctx.beginPath(); ctx.moveTo(sx, sy + 4); ctx.lineTo(lx, ly - 3); ctx.stroke();
          ctx.fillStyle = PALETTE[g]; ctx.beginPath(); ctx.arc(lx, ly, 2.8, 0, 2 * Math.PI); ctx.fill();
        }
      }
    }
    text(ctx, depth === 1 ? 'coarse split only' : depth === 2 ? 'coarse + family splits' : 'coarse + family + leaves', left.x + left.w / 2, left.y + left.h - 22, colors, { align: 'center', size: 10, mono: true, color: colors.muted });

    const pts = coords(depth, api.get('strength'));
    const lambdas = pts[0].lambdas;
    text(ctx, 'eigenmodes', mid.x + 8, mid.y + 6, colors, { size: 12, color: colors.fg, weight: '600' });
    const bx = mid.x + 30, by = mid.y + 58, bw = mid.w - 60, rowH = 55;
    for (let k = 0; k < 5; k++) {
      const y = by + k * rowH;
      ctx.fillStyle = k === 0 ? colors.accent : k < 4 ? colors.blue : colors.green;
      ctx.globalAlpha = lambdas[k] > 0.08 ? 0.9 : 0.25;
      ctx.fillRect(bx, y, bw * lambdas[k] / 1.4, 12);
      ctx.globalAlpha = 1;
      text(ctx, k === 0 ? 'superclass' : k < 4 ? `split group ${k}` : 'leaf detail', bx, y + 18, colors, { size: 9.5, color: colors.muted });
      for (let i = 0; i < N; i++) {
        const x = bx + i * (bw / (N - 1));
        const v = modeValue(k, i);
        ctx.fillStyle = v < 0 ? colors.blue : colors.accent;
        ctx.globalAlpha = Math.min(1, Math.abs(v));
        ctx.fillRect(x - 2, y + 34 - Math.max(0, v) * 12, 4, Math.abs(v) * 12 + 1);
      }
      ctx.globalAlpha = 1;
    }

    text(ctx, 'codebook geometry', right.x + 8, right.y + 6, colors, { size: 12, color: colors.fg, weight: '600' });
    let mx = 1;
    for (const p of pts) mx = Math.max(mx, Math.abs(p.x), Math.abs(p.y));
    const cx = right.x + right.w / 2, cy = right.y + right.h / 2 + 8, R = Math.min(right.w, right.h) * 0.36 / mx;
    for (let i = 0; i < N; i++) for (let j = i + 1; j < N; j++) {
      if (G(i) !== G(j)) continue;
      ctx.strokeStyle = PALETTE[G(i)]; ctx.globalAlpha = SUB(i) === SUB(j) ? 0.22 : 0.08;
      ctx.beginPath(); ctx.moveTo(cx + pts[i].x * R, cy + pts[i].y * R); ctx.lineTo(cx + pts[j].x * R, cy + pts[j].y * R); ctx.stroke();
    }
    ctx.globalAlpha = 1;
    for (let i = 0; i < N; i++) {
      const x = cx + pts[i].x * R, y = cy + pts[i].y * R;
      ctx.fillStyle = PALETTE[G(i)]; ctx.beginPath(); ctx.arc(x, y, 5.5, 0, 2 * Math.PI); ctx.fill();
      ctx.strokeStyle = colors.bg; ctx.lineWidth = 1.5; ctx.stroke();
      text(ctx, NAMES[i], x, y + 9, colors, { align: 'center', size: 8.5, color: colors.muted });
    }
    text(ctx, 'each deeper level spends another spectral mode', right.x + right.w / 2, right.y + right.h - 18, colors, { align: 'center', size: 10, mono: true, color: colors.muted });
    api.readout('rd', `depth ${depth} · ${depth === 1 ? 'one coarse mode' : depth === 2 ? 'coarse + submodes' : 'leaf modes included'}`);
  },
});
</script>
