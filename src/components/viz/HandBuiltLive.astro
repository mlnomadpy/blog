---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 420 } = Astro.props;
---
<figure class="viz hblive" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The whole network, run live on something you draw. Paint a garment in the pad
// (or load a real one) and the entire hand-built pipeline runs in your browser:
// Sobel gradients, soft orientation binning into seven detector maps, a 7x7 patch
// pool to 343 named numbers, then the Yat kernel against 200 stored prototypes and
// a nearest-prototype vote. Nothing is precomputed for your drawing. This is the
// "too good to be true" check: there is no trained network hiding anywhere, just
// detectors and a vote, and you can watch it decide.
import { defineViz } from './engine/vizkit.js';
import { loadHB, samplesImg, exemplarImg, extractFeatures, classify, ensureJax, CLASS_COL, CHAN_COL } from './handbuilt.js';
import { gate, loadingText } from './engine/draw.js';

const PER = 20;

defineViz('hblive', {
  title: 'Draw one, and watch the hand-built network decide',
  height: 420,
  controls: [
    { type: 'button', name: 'clear', label: 'clear' },
    { type: 'button', name: 'example', label: 'load an example' },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    api.state.img = new Float32Array(784);
    api.state.need = true;
    const off = document.createElement('canvas'); off.width = 28; off.height = 28; api.state._off = off;
    // offscreen tiles for the 7 live detector maps (drawImage is DPR-safe)
    api.state._mapc = Array.from({ length: 7 }, () => { const c = document.createElement('canvas'); c.width = 28; c.height = 28; return c; });
    gate(api, () => ensureJax().then(() => Promise.all([loadHB(), samplesImg(), exemplarImg()])), (api, [d, imgs, exe]) => {
      Object.assign(api.state, { d, imgs, exe });
      bind(api);
      loadSample(api, 9 * 6 + 3);   // start with a recognizable example
    });
  },

  onAction(name, api) {
    const st = api.state; if (!st || !st.ready) return;
    if (name === 'clear') { st.img.fill(0); st.need = true; }
    else if (name === 'example') { st._k = (st._k == null ? 0 : st._k + 7) % 60; loadSample(api, st._k); }
    api.render();
  },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H;
    if (W === 0 || !st) return;
    ctx.clearRect(0, 0, W, H);
    if (!st.ready) { loadingText(api, 'computing in your browser…'); return; }
    if (st.need) recompute(api);
    const d = st.d, res = st.res;

    const pad = 14, top = 28;
    ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillStyle = colors.muted; ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillText('paint a garment in white, or load a real one. the whole network runs live on it.', pad, 16);

    // ── draw pad ──
    const padS = Math.min(150, H - top - 130);
    const px = pad, py = top;
    ctx.fillStyle = '#16140f'; ctx.fillRect(px, py, padS, padS);
    drawImg(ctx, st._padc || (st._padc = mkImg(st.img, '#16140f')), px, py, padS);
    ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(px - 0.5, py - 0.5, padS + 1, padS + 1);
    st._pad = { x: px, y: py, s: padS };
    ctx.fillStyle = colors.faint; ctx.font = '10px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
    ctx.fillText('your drawing', px, py + padS + 5);

    // ── live detector maps (proof the extraction is real) ──
    const mx0 = px + padS + 26, mcell = Math.min(46, (W - mx0 - pad - 6 * 6) / 7);
    const my = top + 2;
    for (let ch = 0; ch < 7; ch++) {
      const x = mx0 + ch * (mcell + 6);
      drawImg(ctx, st._mapc[ch], x, my, mcell);
      ctx.lineWidth = 1.4; ctx.strokeStyle = CHAN_COL[ch]; ctx.strokeRect(x - 0.5, my - 0.5, mcell + 1, mcell + 1);
      ctx.fillStyle = CHAN_COL[ch]; ctx.font = '8px ui-sans-serif, system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText(ch === 6 ? 'corner' : `${d.centersDeg[ch]}°`, x + mcell / 2, my + mcell + 3);
    }
    ctx.fillStyle = colors.muted; ctx.font = '10px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
    ctx.fillText('your drawing through the seven detectors, computed live', mx0, my + mcell + 18);

    // ── verdict: nearest prototype + class vote ──
    const vy = top + padS + 34;
    const matchClass = d.vote[res.best];
    // nearest prototype exemplar
    ctx.imageSmoothingEnabled = true;
    const exS = 64;
    ctx.drawImage(st.exe, (res.best % PER) * 28, ((res.best / PER) | 0) * 28, 28, 28, pad, vy, exS, exS);
    ctx.lineWidth = 2; ctx.strokeStyle = CLASS_COL[matchClass]; ctx.strokeRect(pad - 0.5, vy - 0.5, exS + 1, exS + 1);
    ctx.fillStyle = CLASS_COL[matchClass]; ctx.font = '10px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
    ctx.fillText('most resembles', pad, vy + exS + 5);
    ctx.fillStyle = colors.fg; ctx.font = 'bold 11px ui-sans-serif, system-ui';
    ctx.fillText(d.classes[matchClass], pad, vy + exS + 18);

    // class vote bars
    const bx = pad + exS + 76, bw = W - pad - bx - 40, bh = (H - vy - 6) / 10;
    let smax = 0; for (let c = 0; c < 10; c++) if (res.scores[c] > smax) smax = res.scores[c];
    for (let c = 0; c < 10; c++) {
      const yy = vy + c * bh, win = c === res.pred;
      ctx.fillStyle = win ? colors.fg : colors.muted; ctx.font = (win ? 'bold ' : '') + '10px ui-sans-serif, system-ui'; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
      ctx.fillText(d.classes[c], bx - 6, yy + bh / 2);
      const w = Math.max(1, (res.scores[c] / (smax || 1)) * bw);
      ctx.fillStyle = CLASS_COL[c]; ctx.globalAlpha = win ? 1 : 0.45; ctx.fillRect(bx, yy + 1.5, w, bh - 3); ctx.globalAlpha = 1;
      if (win) { ctx.fillStyle = colors.fg; ctx.font = 'bold 10px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'middle'; ctx.fillText('vote', bx + w + 5, yy + bh / 2); }
    }

    api.readout('rd', `live: 343 detector readings from your drawing, scored against 200 prototypes, vote = ${d.classes[res.pred]}. no training, no precomputation.`);
  },
});

// recompute the full pipeline on the current drawing
function recompute(api) {
  const st = api.state; st.need = false;
  const out = extractFeatures(st.d, st.img);
  st.res = classify(st.d, out.feat);
  let best = 0; for (let u = 1; u < st.res.act.length; u++) if (st.res.act[u] > st.res.act[best]) best = u;
  st.res.best = best;
  // rebuild the live detector-map tiles, each normalised to its own max for visibility
  for (let ch = 0; ch < 7; ch++) {
    const m = out.maps[ch]; let mx = 1e-6; for (let i = 0; i < m.length; i++) if (m[i] > mx) mx = m[i];
    const col = CHAN_COL[ch], cr = parseInt(col.slice(1, 3), 16), cg = parseInt(col.slice(3, 5), 16), cb = parseInt(col.slice(5, 7), 16);
    const oc = st._mapc[ch], octx = oc.getContext('2d'), img = octx.createImageData(28, 28);
    for (let i = 0; i < 784; i++) { const t = Math.pow(m[i] / mx, 0.6); const o = i * 4; img.data[o] = (24 + (cr - 24) * t) | 0; img.data[o + 1] = (22 + (cg - 22) * t) | 0; img.data[o + 2] = (20 + (cb - 20) * t) | 0; img.data[o + 3] = 255; }
    octx.putImageData(img, 0, 0);
  }
  st._padc = mkImg(st.img, '#16140f');
}

// a 28x28 offscreen canvas of a grayscale image (white ink on a dark pad)
function mkImg(arr, bg) {
  const c = document.createElement('canvas'); c.width = 28; c.height = 28; const ctx = c.getContext('2d');
  const img = ctx.createImageData(28, 28);
  const br = parseInt(bg.slice(1, 3), 16), bgc = parseInt(bg.slice(3, 5), 16), bb = parseInt(bg.slice(5, 7), 16);
  for (let i = 0; i < 784; i++) { const t = arr[i], o = i * 4; img.data[o] = (br + (232 - br) * t) | 0; img.data[o + 1] = (bgc + (226 - bgc) * t) | 0; img.data[o + 2] = (bb + (212 - bb) * t) | 0; img.data[o + 3] = 255; }
  ctx.putImageData(img, 0, 0); return c;
}
function drawImg(ctx, off, x, y, s) { ctx.imageSmoothingEnabled = off.width > s ? true : false; ctx.drawImage(off, x, y, s, s); }

function loadSample(api, k) {
  const st = api.state, off = st._off, octx = off.getContext('2d');
  octx.clearRect(0, 0, 28, 28); octx.imageSmoothingEnabled = false;
  octx.drawImage(st.imgs, (k % 10) * 28, ((k / 10) | 0) * 28, 28, 28, 0, 0, 28, 28);
  const dd = octx.getImageData(0, 0, 28, 28).data;
  for (let i = 0; i < 784; i++) st.img[i] = dd[i * 4] / 255;
  st.need = true;
}

function bind(api) {
  if (api.canvas.dataset.hlBound) return; api.canvas.dataset.hlBound = '1';
  let painting = false;
  const paint = (e) => {
    const st = api.state, g = st._pad; if (!g) return;
    const rc = api.canvas.getBoundingClientRect();
    const cx = (e.clientX - rc.left) * api.size.W / rc.width, cy = (e.clientY - rc.top) * api.size.H / rc.height;
    const fx = (cx - g.x) / g.s * 28, fy = (cy - g.y) / g.s * 28;
    if (fx < -1 || fx > 29 || fy < -1 || fy > 29) return false;
    for (let dy = -2; dy <= 2; dy++) for (let dx = -2; dx <= 2; dx++) {
      const ix = Math.round(fx) + dx, iy = Math.round(fy) + dy; if (ix < 0 || ix >= 28 || iy < 0 || iy >= 28) continue;
      const dist = Math.hypot(fx - ix, fy - iy), v = Math.max(0, 1 - dist / 1.8);
      st.img[iy * 28 + ix] = Math.min(1, st.img[iy * 28 + ix] + v * 0.7);
    }
    st.need = true; api.render(); return true;
  };
  api.canvas.addEventListener('pointerdown', (e) => { if (paint(e) !== false) { painting = true; api.canvas.setPointerCapture?.(e.pointerId); } });
  api.canvas.addEventListener('pointermove', (e) => { if (painting) paint(e); });
  api.canvas.addEventListener('pointerup', (e) => { painting = false; try { api.canvas.releasePointerCapture?.(e.pointerId); } catch {} });
  api.canvas.addEventListener('pointerleave', () => { painting = false; });
}
</script>
