---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 300 } = Astro.props;
---
<figure class="viz kernelsmoother" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { np, withJax, drawJaxLoading } from './engine/jax.js';

// Nadaraya–Watson kernel regression. Real computation: ŷ(x) = Σ wₖ yₖ / Σ wₖ
// with Gaussian weights wₖ = exp(-(x-xₖ)²/2h²). Both the smoothed curve over the
// domain and the per-query prediction are computed live by jax-js, one vectorised
// (M+1)×N weight matrix, softmax-free normalised sum. Drag the chart to move query.
const N = 22, M = 200;
const PADL = 36, PADR = 14, PADT = 18, PADB = 30;

// jax-js Nadaraya–Watson. Returns { curve: Float64Array(M+1), w: Float64Array(N), yhat }.
// Fresh arrays each call, each read once → no .ref leak. xq appended as the last grid
// row so the per-query weights/prediction come out of the same vectorised solve.
const smooth = (xs, ys, xq, inv2hh) => {
  const Xq = new Float64Array(M + 2); for (let i = 0; i <= M; i++) Xq[i] = i / M; Xq[M + 1] = xq;
  const G = np.reshape(np.array(Xq), [M + 2, 1]);          // (M+2,1) query grid + xq
  const Xr = np.reshape(np.array(xs), [1, N]);             // (1,N) sample sites
  const d = np.subtract(G, Xr);                            // (M+2,N) pairwise gaps
  const Wm = np.exp(d.ref.mul(d).mul(-inv2hh));            // Gaussian weights
  const Y = np.reshape(np.array(ys), [1, N]);
  const num = np.sum(Wm.ref.mul(Y), 1);                    // Σ wₖ yₖ   (M+2,)
  const den = np.sum(Wm.ref, 1);                           // Σ wₖ
  const pred = num.div(den).js();                          // ŷ at every grid point + xq
  const wRow = Wm.js()[M + 1];                             // per-sample weights at the query row (consumes Wm)
  return { curve: pred.slice(0, M + 1), yhat: pred[M + 1], w: Float64Array.from(wRow) };
};

defineViz('kernelsmoother', {
  height: 300,
  controls: [
    { type: 'range', name: 'h', label: 'bandwidth h', min: -2, max: 0.4, step: 0.04, value: -0.8, reset: false, fmt: (v) => Math.pow(10, v).toFixed(2) },
    { type: 'readout', name: 'ro' },
  ],
  setup(api) {
    const rng = ((s) => () => { s = (s * 9301 + 49297) % 233280; return s / 233280; })(1337);
    const xs = new Float32Array(N), ys = new Float32Array(N);
    for (let i = 0; i < N; i++) { xs[i] = i / (N - 1); ys[i] = Math.sin(xs[i] * Math.PI * 2.2) * 0.55 + (rng() - 0.5) * 0.35; }
    api.state.xs = xs; api.state.ys = ys; api.state.queryX = 0.4;
    if (!api.canvas.dataset.ksDrag) {
      api.canvas.dataset.ksDrag = '1'; let dragging = false;
      const onP = (e) => { const r = api.canvas.getBoundingClientRect(); const plotW = api.size.W - PADL - PADR;
        api.state.queryX = Math.max(0, Math.min(1, ((e.clientX - r.left) - PADL) / plotW)); api.render(); };
      api.canvas.addEventListener('pointerdown', (e) => { dragging = true; api.canvas.setPointerCapture(e.pointerId); onP(e); });
      api.canvas.addEventListener('pointermove', (e) => { if (dragging) onP(e); });
      api.canvas.addEventListener('pointerup', (e) => { dragging = false; try { api.canvas.releasePointerCapture(e.pointerId); } catch {} });
    }
    withJax(api);
  },
  draw(api) {
    const { ctx, colors, size, state } = api; const W = size.W, H = size.H; if (W === 0) return;
    if (!state.jaxReady) return drawJaxLoading(api);
    const { accent, fg, muted, faint, border } = colors; const { xs, ys, queryX } = state;
    const plotW = W - PADL - PADR, plotH = H - PADT - PADB, yMin = -1.1, yMax = 1.1, yRange = yMax - yMin;
    const sx = (x) => PADL + x * plotW, sy = (y) => PADT + (yMax - y) / yRange * plotH;
    ctx.strokeStyle = border; ctx.lineWidth = 1; ctx.beginPath();
    for (let g = 0; g <= 4; g++) { const py = sy(yMin + (g / 4) * yRange); ctx.moveTo(PADL, py); ctx.lineTo(W - PADR, py); } ctx.stroke();
    ctx.fillStyle = faint; ctx.font = '10px ui-monospace, monospace'; ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
    for (let g = 0; g <= 4; g++) { const y = yMin + (g / 4) * yRange; ctx.fillText(y.toFixed(1), PADL - 4, sy(y)); }
    ctx.textAlign = 'center'; ctx.textBaseline = 'top';
    for (let g = 0; g <= 5; g++) ctx.fillText((g / 5).toFixed(1), sx(g / 5), H - PADB + 6);
    const h = Math.pow(10, api.get('h')); const inv2hh = 1 / (2 * h * h);
    const { curve, yhat, w } = smooth(xs, ys, queryX, inv2hh);
    // smoothed curve over the domain
    ctx.strokeStyle = muted; ctx.lineWidth = 1.5; ctx.beginPath();
    for (let i = 0; i <= M; i++) { const px = sx(i / M), py = sy(curve[i]); i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py); } ctx.stroke();
    const qPx = sx(queryX); ctx.strokeStyle = accent; ctx.lineWidth = 1; ctx.setLineDash([3, 4]); ctx.beginPath(); ctx.moveTo(qPx, PADT); ctx.lineTo(qPx, H - PADB); ctx.stroke(); ctx.setLineDash([]);
    // kernel bell at query
    ctx.strokeStyle = accent + '88'; ctx.lineWidth = 1.2; ctx.beginPath(); const kBase = sy(yMin) - 4, kAmp = 28;
    for (let i = 0; i <= M; i++) { const x = i / M, d = x - queryX, ww = Math.exp(-(d * d) * inv2hh); const px = sx(x), py = kBase - ww * kAmp; i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py); } ctx.stroke();
    // data points sized by weight (from jax)
    for (let k = 0; k < N; k++) { const ww = w[k];
      ctx.fillStyle = ww > 0.05 ? accent : faint; ctx.globalAlpha = 0.35 + 0.65 * ww; ctx.beginPath(); ctx.arc(sx(xs[k]), sy(ys[k]), 2 + ww * 5.5, 0, Math.PI * 2); ctx.fill(); }
    ctx.globalAlpha = 1;
    ctx.fillStyle = accent; ctx.beginPath(); ctx.arc(qPx, sy(yhat), 5, 0, Math.PI * 2); ctx.fill(); ctx.strokeStyle = fg; ctx.lineWidth = 1.5; ctx.stroke();
    api.readout('ro', `drag to move query · x ${queryX.toFixed(2)} · ŷ ${yhat.toFixed(2)} · live`);
  },
});
</script>
