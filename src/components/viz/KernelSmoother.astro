---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 300 } = Astro.props;
const id = `ks-${Math.random().toString(36).slice(2, 9)}`;
---
<figure class="viz">
  <div class="viz-controls">
    <label>
      bandwidth <em style="font-style:normal;color:var(--fg)">h</em>
      <input type="range" min="-2" max="0.4" step="0.04" value="-0.8" id={`${id}-h`} aria-label="kernel bandwidth" />
      <span class="readout" id={`${id}-readout`}>0.16</span>
    </label>
    <span class="faint">drag on the chart to move the query x</span>
  </div>
  <canvas id={`${id}-c`} height={height} aria-label="Nadaraya-Watson kernel smoother demonstration"></canvas>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script is:inline define:vars={{ id }}>
(() => {
  const setup = () => {
    const c = document.getElementById(id + '-c');
    if (!c || c.dataset.ready) return;
    c.dataset.ready = '1';
    const slider = document.getElementById(id + '-h');
    const readout = document.getElementById(id + '-readout');
    const ctx = c.getContext('2d');

    // Deterministic data: noisy sin
    const rng = (s => () => { s = (s * 9301 + 49297) % 233280; return s / 233280; })(1337);
    const N = 22;
    const xs = new Float32Array(N);
    const ys = new Float32Array(N);
    for (let i = 0; i < N; i++) {
      xs[i] = i / (N - 1);
      ys[i] = Math.sin(xs[i] * Math.PI * 2.2) * 0.55 + (rng() - 0.5) * 0.35;
    }

    const M = 200;
    const smoothY = new Float32Array(M + 1);
    let smoothH = -1;

    let queryX = 0.4;
    const state = { dpr: 1, w: 0, h: 0 };

    // Cache theme colors; refresh on theme toggle.
    let colors = readColors();
    function readColors() {
      const s = getComputedStyle(document.documentElement);
      const v = (n) => s.getPropertyValue(n).trim();
      return {
        accent: v('--accent') || '#b3661b',
        fg: v('--fg') || '#1a1a1a',
        muted: v('--fg-muted') || '#5a5f66',
        faint: v('--fg-faint') || '#8d8d8d',
        border: v('--border') || '#e4e1d6',
      };
    }
    const themeObs = new MutationObserver(() => { colors = readColors(); requestRedraw(); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    const fit = () => {
      const rect = c.getBoundingClientRect();
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      state.dpr = dpr;
      state.w = rect.width;
      state.h = rect.height;
      c.width = Math.round(rect.width * dpr);
      c.height = Math.round(rect.height * dpr);
    };

    const computeSmoothIfNeeded = (h) => {
      if (h === smoothH) return;
      smoothH = h;
      const inv2hh = 1 / (2 * h * h);
      for (let i = 0; i <= M; i++) {
        const x = i / M;
        let num = 0, den = 0;
        for (let k = 0; k < N; k++) {
          const d = x - xs[k];
          const w = Math.exp(-(d * d) * inv2hh);
          num += w * ys[k];
          den += w;
        }
        smoothY[i] = den > 0 ? num / den : 0;
      }
    };

    const draw = () => {
      const W = state.w, H = state.h;
      if (W === 0 || H === 0) return;
      ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);

      const { accent, fg, muted, faint, border } = colors;

      const padL = 36, padR = 14, padT = 18, padB = 30;
      const plotW = W - padL - padR;
      const plotH = H - padT - padB;
      const yMin = -1.1, yMax = 1.1;
      const yRange = yMax - yMin;
      const sx = (x) => padL + x * plotW;
      const sy = (y) => padT + (yMax - y) / yRange * plotH;

      ctx.strokeStyle = border;
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (let g = 0; g <= 4; g++) {
        const py = sy(yMin + (g / 4) * yRange);
        ctx.moveTo(padL, py); ctx.lineTo(W - padR, py);
      }
      ctx.stroke();

      ctx.fillStyle = faint;
      ctx.font = '10px ui-monospace, monospace';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      for (let g = 0; g <= 4; g++) {
        const y = yMin + (g / 4) * yRange;
        ctx.fillText(y.toFixed(1), padL - 4, sy(y));
      }
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      for (let g = 0; g <= 5; g++) ctx.fillText((g / 5).toFixed(1), sx(g / 5), H - padB + 6);

      const h = Math.pow(10, parseFloat(slider.value));
      readout.textContent = h.toFixed(2);
      computeSmoothIfNeeded(h);
      const inv2hh = 1 / (2 * h * h);

      // Cached smoothed curve.
      ctx.strokeStyle = muted;
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      for (let i = 0; i <= M; i++) {
        const px = sx(i / M), py = sy(smoothY[i]);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();

      // Query x
      const qPx = sx(queryX);
      ctx.strokeStyle = accent;
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 4]);
      ctx.beginPath(); ctx.moveTo(qPx, padT); ctx.lineTo(qPx, H - padB); ctx.stroke();
      ctx.setLineDash([]);

      // Kernel curve at query
      ctx.strokeStyle = accent + '88';
      ctx.lineWidth = 1.2;
      ctx.beginPath();
      const kBase = sy(yMin) - 4;
      const kAmp = 28;
      for (let i = 0; i <= M; i++) {
        const x = i / M;
        const d = x - queryX;
        const w = Math.exp(-(d * d) * inv2hh);
        const px = sx(x), py = kBase - w * kAmp;
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();

      // Data points sized by weight at query + accumulate prediction.
      let num = 0, den = 0;
      for (let k = 0; k < N; k++) {
        const d = queryX - xs[k];
        const w = Math.exp(-(d * d) * inv2hh);
        num += w * ys[k]; den += w;
        const px = sx(xs[k]), py = sy(ys[k]);
        const r = 2 + w * 5.5;
        ctx.fillStyle = w > 0.05 ? accent : faint;
        ctx.globalAlpha = 0.35 + 0.65 * w;
        ctx.beginPath(); ctx.arc(px, py, r, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;

      const yhat = den > 0 ? num / den : 0;
      ctx.fillStyle = accent;
      ctx.beginPath(); ctx.arc(qPx, sy(yhat), 5, 0, Math.PI * 2); ctx.fill();
      ctx.strokeStyle = fg;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    };

    let rafScheduled = false;
    let visible = false;
    const requestRedraw = () => {
      if (rafScheduled || !visible) return;
      rafScheduled = true;
      requestAnimationFrame(() => { rafScheduled = false; draw(); });
    };

    const onPointer = (e) => {
      const rect = c.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      queryX = Math.max(0, Math.min(1, x));
      requestRedraw();
    };

    let dragging = false;
    c.addEventListener('pointerdown', (e) => { dragging = true; c.setPointerCapture(e.pointerId); onPointer(e); });
    c.addEventListener('pointermove', (e) => { if (dragging) onPointer(e); });
    c.addEventListener('pointerup', (e) => { dragging = false; try { c.releasePointerCapture(e.pointerId); } catch {} });
    slider.addEventListener('input', requestRedraw);

    const ro = new ResizeObserver(() => { fit(); requestRedraw(); });
    ro.observe(c);

    const io = new IntersectionObserver((entries) => {
      const wasVisible = visible;
      visible = entries[0].isIntersecting;
      if (visible && !wasVisible) { fit(); draw(); }
    }, { rootMargin: '120px' });
    io.observe(c);
  };

  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:after-swap', setup);
})();
</script>
