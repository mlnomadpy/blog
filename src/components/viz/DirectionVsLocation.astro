---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 400 } = Astro.props;
---
<figure class="viz dirvsloc" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// Can you point at the weight? Both panels measure "similarity to the query q" over
// the same plane. On the left, similarity is the dot product q·x: a ramp that grows
// without bound, so the most-similar place is off the map entirely, in q's
// direction. A dot-product weight is a direction; you cannot put your finger on it.
// On the right, similarity is a kernel k(q, x): a bump that peaks AT q, so the
// most-similar place is q itself, a point sitting on the map among the data. Drag q
// and watch the two readings: a direction with no location, or a location you can
// point at. Computed live.
import { defineViz } from './engine/vizkit.js';

const DOM = 2.0, SIG = 0.6, HM = 80;
const hex = (h) => [parseInt(h.slice(1, 3), 16), parseInt(h.slice(3, 5), 16), parseInt(h.slice(5, 7), 16)];

defineViz('dirvsloc', {
  title: 'Similarity to a query, two ways: a ramp with no peak, or a bump that peaks at q',
  height: 400,
  controls: [{ type: 'readout', name: 'rd' }],

  setup(api) { api.state = { q: { x: 0.55, y: 0.4 }, drag: false }; bind(api); },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H; if (W === 0 || !st) return;
    ctx.clearRect(0, 0, W, H);
    const pad = 12, topH = 30, gap = 16;
    const side = Math.min((W - pad * 2 - gap) / 2, H - pad - topH - 16);
    const totalW = side * 2 + gap, x0 = (W - totalW) / 2, y0 = pad + topH;
    const panels = [{ x: x0, label: 'dot product   q·x', kind: 'dot' }, { x: x0 + side + gap, label: 'kernel   k(q, x)', kind: 'ker' }];
    st._g = { x0, y0, side, gap };

    ctx.fillStyle = colors.fg; ctx.font = 'bold 13px ui-sans-serif, system-ui'; ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillText('where is the input most similar to q? off the map in a direction, or right at a place', pad, pad + 13);

    const q = st.q; const acc = hex(colors.accent), bg = hex(colors.bg), cb = hex('#4a7fb3');
    for (const P of panels) {
      const sx = (wx) => P.x + (wx + DOM) / (2 * DOM) * side, sy = (wy) => y0 + (DOM - wy) / (2 * DOM) * side;
      const wxOf = (px) => (px - P.x) / side * 2 * DOM - DOM, wyOf = (py) => DOM - (py - y0) / side * 2 * DOM;
      P.sx = sx; P.sy = sy; P.wxOf = wxOf; P.wyOf = wyOf;
      const cell = side / HM;
      // field values
      let mn = Infinity, mx = -Infinity; const vals = new Float32Array(HM * HM);
      for (let r = 0; r < HM; r++) for (let cc = 0; cc < HM; cc++) {
        const X = wxOf(P.x + (cc + 0.5) * cell), Y = wyOf(y0 + (r + 0.5) * cell);
        const v = P.kind === 'dot' ? (X * q.x + Y * q.y) : Math.exp(-((X - q.x) ** 2 + (Y - q.y) ** 2) / (2 * SIG * SIG));
        vals[r * HM + cc] = v; if (v < mn) mn = v; if (v > mx) mx = v;
      }
      for (let r = 0; r < HM; r++) for (let cc = 0; cc < HM; cc++) {
        const v = vals[r * HM + cc]; const t = (v - mn) / (mx - mn || 1);
        // diverging for dot (blue low → accent high), sequential for kernel
        const lo = P.kind === 'dot' ? cb : bg; const a = P.kind === 'dot' ? 0.6 : 0.72 * t;
        const col = P.kind === 'dot' ? [bg[0] + (acc[0] - bg[0]) * t, bg[1] + (acc[1] - bg[1]) * t, bg[2] + (acc[2] - bg[2]) * t] : acc;
        ctx.fillStyle = P.kind === 'dot' ? `rgb(${col[0] | 0},${col[1] | 0},${col[2] | 0})` : `rgba(${acc[0]},${acc[1]},${acc[2]},${a})`;
        ctx.fillRect(P.x + cc * cell, y0 + r * cell, cell + 0.6, cell + 0.6);
      }
      ctx.strokeStyle = colors.border; ctx.lineWidth = 1; ctx.strokeRect(P.x + 0.5, y0 + 0.5, side - 1, side - 1);
      // panel label
      ctx.fillStyle = colors.muted; ctx.font = '11px ui-monospace, monospace'; ctx.textAlign = 'left'; ctx.textBaseline = 'top';
      ctx.fillText(P.label, P.x + 6, y0 + 6);

      if (P.kind === 'dot') {
        // arrow toward the unbounded max, running off the panel edge
        const n = Math.hypot(q.x, q.y) || 1; const ex = q.x / n, ey = q.y / n;
        arrowTo(ctx, sx(0), sy(0), sx(ex * DOM * 1.7), sy(ey * DOM * 1.7), colors.fg, 2.2);
        ctx.fillStyle = colors.fg; ctx.font = '10px ui-sans-serif, system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
        ctx.fillText('max is off the map ↗', sx(ex * 1.2), sy(ey * 1.2) - 4);
      } else {
        // the peak sits exactly at q
        ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.4; ctx.beginPath(); ctx.arc(sx(q.x), sy(q.y), 11, 0, 6.283); ctx.stroke();
        ctx.fillStyle = colors.fg; ctx.font = '10px ui-sans-serif, system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
        ctx.fillText('max is here, at q', sx(q.x), sy(q.y) - 14);
      }
      // the query handle (same world point on both panels)
      ctx.fillStyle = colors.accent; ctx.beginPath(); ctx.arc(sx(q.x), sy(q.y), 6, 0, 6.283); ctx.fill();
      ctx.lineWidth = 2; ctx.strokeStyle = colors.bg; ctx.stroke();
    }
    ctx.fillStyle = colors.faint; ctx.font = '10px ui-sans-serif, system-ui'; ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
    ctx.fillText('drag q', W / 2, y0 + side + 13);
    api.readout('rd', `the dot-product weight is a direction (no place on the map); the kernel weight is the point q itself`);
  },
});

function arrowTo(ctx, x0, y0, x1, y1, color, w = 2) {
  ctx.strokeStyle = color; ctx.lineWidth = w; ctx.beginPath(); ctx.moveTo(x0, y0); ctx.lineTo(x1, y1); ctx.stroke();
  const a = Math.atan2(y1 - y0, x1 - x0), h = 8;
  ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x1 - h * Math.cos(a - 0.4), y1 - h * Math.sin(a - 0.4));
  ctx.moveTo(x1, y1); ctx.lineTo(x1 - h * Math.cos(a + 0.4), y1 - h * Math.sin(a + 0.4)); ctx.stroke();
}
function bind(api) {
  if (api.canvas.dataset.dlBound) return; api.canvas.dataset.dlBound = '1'; api.canvas.style.cursor = 'grab';
  const at = (e) => { const rc = api.canvas.getBoundingClientRect(); return { px: (e.clientX - rc.left) * api.size.W / rc.width, py: (e.clientY - rc.top) * api.size.H / rc.height }; };
  const setQ = (px, py) => { const st = api.state, g = st && st._g; if (!g) return; // map from whichever panel the pointer is over
    let P = px < g.x0 + g.side + g.gap / 2 ? { x: g.x0 } : { x: g.x0 + g.side + g.gap };
    const wx = (px - P.x) / g.side * 2 * DOM - DOM, wy = DOM - (py - g.y0) / g.side * 2 * DOM;
    st.q.x = Math.max(-DOM, Math.min(DOM, wx)); st.q.y = Math.max(-DOM, Math.min(DOM, wy)); };
  api.canvas.addEventListener('pointerdown', (e) => { const { px, py } = at(e); api.state.drag = true; setQ(px, py); api.render(); });
  api.canvas.addEventListener('pointermove', (e) => { if (!api.state || !api.state.drag) return; const { px, py } = at(e); setQ(px, py); api.render(); });
  const up = () => { if (api.state) api.state.drag = false; };
  api.canvas.addEventListener('pointerup', up); api.canvas.addEventListener('pointercancel', up);
}
</script>
