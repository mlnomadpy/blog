---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 470 } = Astro.props;
---
<figure class="viz gravitymap" data-caption={caption} data-height={height} data-height-mobile="600" tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// The map of query space under both attention laws, computed live. Six keys
// sit in the plane as bodies; every pixel is a possible query, colored by the
// key that wins it (the row's top weight), shaded by how much of the row that
// winner takes. Drag a body and the borders re-carve; zoom out and the two
// force laws show their far fields.
import { defineViz } from './engine/vizkit.js';
import { T, dot, cross, fmt, axes, PALETTE } from './engine/draw.js';
import { drag } from './engine/pointer.js';
import { rows } from './geomattn.js';

const GRID = 72;
const KEYS0 = [
  [0.9, 0.85], [-1.05, 0.6], [0.15, -1.1],
  [1.35, -0.5], [-0.7, -0.75], [0.35, 0.3],
];

function hex2rgb(h) {
  return [parseInt(h.slice(1, 3), 16), parseInt(h.slice(3, 5), 16), parseInt(h.slice(5, 7), 16)];
}

defineViz('gravitymap', {
  title: 'Who owns the query? The same six bodies under two laws',
  height: 470,
  controls: [
    { type: 'range', name: 'zoom', label: 'zoom out', min: 1.6, max: 7, step: 0.1, value: 2, fmt: (v) => fmt(v, 1) + 'x' },
    { type: 'button', name: 'restore', label: 'Restore bodies' },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    const st = api.state;
    st.keys = KEYS0.map((k) => k.slice());
    st.dragKey = -1;
    st.dragBox = -1;
    const toWorld = (p, b, R) => [
      -R + (2 * R * (p.x - b.x)) / b.w,
      R - (2 * R * (p.y - b.y)) / b.h,
    ];
    drag(api.canvas, {
      cursor: 'grab',
      onStart(p) {
        const bs = st.boxes || [];
        const bi = bs.findIndex((b) => p.x >= b.x && p.x <= b.x + b.w && p.y >= b.y && p.y <= b.y + b.h);
        st.dragBox = bi;
        st.dragKey = -1;
        if (bi < 0) return;
        const R = api.get('zoom');
        const w = toWorld(p, bs[bi], R);
        let best = 0.14 * R * 2, idx = -1;
        st.keys.forEach((k, i) => {
          const d = Math.hypot(k[0] - w[0], k[1] - w[1]);
          if (d < best) { best = d; idx = i; }
        });
        st.dragKey = idx;
      },
      onMove(p) {
        if (st.dragKey < 0 || st.dragBox < 0) return;
        const b = st.boxes?.[st.dragBox];
        if (!b) return;
        st.keys[st.dragKey] = toWorld(p, b, api.get('zoom'));
        api.render();
      },
      onEnd() { st.dragKey = -1; },
    });
  },

  onAction(name, api) {
    if (name === 'restore') {
      api.state.keys = KEYS0.map((k) => k.slice());
      api.render();
    }
  },

  draw(api) {
    const { ctx, colors, size: { W, H } } = api, st = api.state;
    const R = api.get('zoom');
    const pad = 14, gapX = 18, top = 30, footer = 64;
    const half = (W - 2 * pad - gapX) / 2;
    const side = Math.min(half, H - top - footer);
    const boxes = [
      { x: pad + (half - side) / 2, y: top, w: side, h: side, name: 'softmax of q·k: weights by direction', law: 'soft' },
      { x: pad + half + gapX + (half - side) / 2, y: top, w: side, h: side, name: 'yat kernel: weights by place', law: 'ker' },
    ];
    st.boxes = boxes;
    const pal = PALETTE.map(hex2rgb);
    const counts = { soft: new Array(st.keys.length).fill(0), ker: new Array(st.keys.length).fill(0) };

    for (const b of boxes) {
      const off = document.createElement('canvas');
      off.width = GRID; off.height = GRID;
      const octx = off.getContext('2d'), img = octx.createImageData(GRID, GRID);
      for (let r = 0; r < GRID; r++) for (let c = 0; c < GRID; c++) {
        const q = [-R + (2 * R * c) / (GRID - 1), R - (2 * R * r) / (GRID - 1)];
        const rw = rows(q, st.keys);
        const win = b.law === 'soft' ? rw.winSoft : rw.winKer;
        const share = b.law === 'soft' ? rw.wSoft[win] : rw.wKer[win];
        counts[b.law][win]++;
        const ccol = pal[win % pal.length];
        // grip: how much of the row the winner takes (1/n = contested, 1 = owned)
        const n = st.keys.length;
        const grip = Math.max(0, (share - 1 / n) / (1 - 1 / n));
        const a = 0.16 + 0.74 * Math.pow(grip, 0.7);
        const i4 = (r * GRID + c) * 4;
        img.data[i4] = ccol[0]; img.data[i4 + 1] = ccol[1]; img.data[i4 + 2] = ccol[2];
        img.data[i4 + 3] = Math.round(255 * a);
      }
      octx.putImageData(img, 0, 0);
      ctx.imageSmoothingEnabled = true;
      ctx.fillStyle = colors.cellBg;
      ctx.fillRect(b.x, b.y, b.w, b.h);
      ctx.drawImage(off, b.x, b.y, b.w, b.h);
      axes(ctx, b, { xMin: -R, xMax: R, yMin: -R, yMax: R }, colors);
      T(ctx, colors, 'label');
      ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
      ctx.fillText(b.name, b.x, b.y - 8);
      // the origin, where every softmax border must pass
      const o = [b.x + b.w / 2, b.y + b.h / 2];
      cross(ctx, o[0], o[1], 5, colors.fg);
      // the bodies
      st.keys.forEach((k, i) => {
        const x = b.x + ((k[0] + R) / (2 * R)) * b.w;
        const y = b.y + (1 - (k[1] + R) / (2 * R)) * b.h;
        if (x < b.x - 8 || x > b.x + b.w + 8 || y < b.y - 8 || y > b.y + b.h + 8) return;
        dot(ctx, x, y, 6.5, PALETTE[i % PALETTE.length]);
        ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.6;
        ctx.beginPath(); ctx.arc(x, y, 6.5, 0, 2 * Math.PI); ctx.stroke();
      });
    }

    T(ctx, colors, 'small');
    ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
    ctx.fillText('each pixel is a query, colored by the key whose weight wins there; darker = the winner holds more of the row; + marks the origin', pad, H - 44);
    ctx.fillText('drag a body: the left map only re-aims wedges through the origin; the right map re-carves neighborhoods around the bodies', pad, H - 27);
    const total = GRID * GRID;
    const biggest = (law) => {
      const i = counts[law].indexOf(Math.max(...counts[law]));
      return `${fmt((100 * counts[law][i]) / total, 0)}%`;
    };
    api.readout('rd', `largest territory: softmax ${biggest('soft')} of view, kernel ${biggest('ker')}`);
  },
});
</script>
