---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 260 } = Astro.props;
const id = `sic-${Math.random().toString(36).slice(2, 9)}`;
---
<figure class="viz">
  <div class="viz-controls" style="justify-content:space-between">
    <span class="faint" id={`${id}-legend`}>
      <span style="color:var(--accent)">— cos θ</span>
      &nbsp; <span style="color:var(--fg-muted)">‒ ‒ cos² θ (shared info)</span>
      &nbsp; <span style="color:var(--fg)">···· 1 − cos² θ (independence)</span>
    </span>
    <span class="readout" id={`${id}-readout`}>θ = 90°</span>
  </div>
  <canvas id={`${id}-c`} height={height} aria-label="Cosine, cosine squared, and one minus cosine squared as functions of angle"></canvas>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script is:inline define:vars={{ id }}>
(() => {
  const readColors = () => {
    const s = getComputedStyle(document.documentElement);
    const v = (n) => s.getPropertyValue(n).trim();
    return {
      accent: v('--accent') || '#b3661b',
      muted: v('--fg-muted') || '#5a5f66',
      faint: v('--fg-faint') || '#8d8d8d',
      border: v('--border') || '#e4e1d6',
      fg: v('--fg') || '#1a1a1a',
    };
  };
  let colors = readColors();

  const setup = () => {
    const c = document.getElementById(id + '-c');
    if (!c || c.dataset.ready) return;
    c.dataset.ready = '1';
    const ctx = c.getContext('2d');
    const readout = document.getElementById(id + '-readout');

    let thetaDeg = 90;
    const state = { dpr: 1, w: 0, h: 0 };
    const baseH = +c.getAttribute('height') || 260;   // intended display height
    c.style.height = baseH + 'px';                     // pin it: with CSS width:100% and no CSS height the
                                                       // canvas would collapse to 0 via its intrinsic ratio

    const fit = () => {
      const rect = c.getBoundingClientRect();
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      state.dpr = dpr;
      state.w = rect.width;
      state.h = baseH;
      c.width = Math.round(rect.width * dpr);
      c.height = Math.round(baseH * dpr);
    };

    const themeObs = new MutationObserver(() => { colors = readColors(); requestRedraw(); });
    themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    let rafScheduled = false;
    let visible = false;
    const requestRedraw = () => {
      if (rafScheduled || !visible) return;
      rafScheduled = true;
      requestAnimationFrame(() => { rafScheduled = false; draw(); });
    };

    const draw = () => {
      const W = state.w, H = state.h;
      if (W === 0) return;
      ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
      ctx.clearRect(0, 0, W, H);
      const { accent, muted, faint, border, fg } = colors;

      const padL = 40, padR = 14, padT = 18, padB = 34;
      const plotW = W - padL - padR;
      const plotH = H - padT - padB;
      const xMin = 0, xMax = 360, yMin = -1.05, yMax = 1.1;
      const sx = (x) => padL + ((x - xMin) / (xMax - xMin)) * plotW;
      const sy = (y) => padT + ((yMax - y) / (yMax - yMin)) * plotH;

      // Horizontal gridlines
      ctx.strokeStyle = border;
      ctx.lineWidth = 1;
      ctx.beginPath();
      [-1, -0.5, 0, 0.5, 1].forEach((y) => { ctx.moveTo(padL, sy(y)); ctx.lineTo(W - padR, sy(y)); });
      ctx.stroke();

      // Axis labels
      ctx.fillStyle = faint;
      ctx.font = '10px ui-monospace, monospace';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      [-1, -0.5, 0, 0.5, 1].forEach((y) => { ctx.fillText(y.toString(), padL - 4, sy(y)); });
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      [0, 45, 90, 135, 180, 225, 270, 315, 360].forEach((x) => { ctx.fillText(x + '°', sx(x), H - padB + 6); });
      ctx.fillStyle = muted;
      ctx.fillText('angle θ', padL + plotW / 2, H - padB + 18);

      const M = 360;
      // cos²θ (dashed muted)
      ctx.strokeStyle = muted;
      ctx.lineWidth = 1.2;
      ctx.setLineDash([4, 4]);
      ctx.beginPath();
      for (let i = 0; i <= M; i++) {
        const x = (i / M) * 360;
        const t = (x * Math.PI) / 180;
        const y = Math.cos(t) ** 2;
        const px = sx(x), py = sy(y);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.setLineDash([]);

      // 1 - cos²θ (dotted fg)
      ctx.strokeStyle = fg;
      ctx.lineWidth = 1.4;
      ctx.setLineDash([1.5, 3.5]);
      ctx.beginPath();
      for (let i = 0; i <= M; i++) {
        const x = (i / M) * 360;
        const t = (x * Math.PI) / 180;
        const y = 1 - Math.cos(t) ** 2;
        const px = sx(x), py = sy(y);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.setLineDash([]);

      // cos θ (solid accent) on top
      ctx.strokeStyle = accent;
      ctx.lineWidth = 1.8;
      ctx.beginPath();
      for (let i = 0; i <= M; i++) {
        const x = (i / M) * 360;
        const t = (x * Math.PI) / 180;
        const y = Math.cos(t);
        const px = sx(x), py = sy(y);
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();

      // Vertical marker at thetaDeg
      ctx.strokeStyle = accent;
      ctx.lineWidth = 1;
      ctx.setLineDash([2, 3]);
      ctx.beginPath();
      ctx.moveTo(sx(thetaDeg), padT);
      ctx.lineTo(sx(thetaDeg), H - padB);
      ctx.stroke();
      ctx.setLineDash([]);

      // Dots at the three curve values at θ
      const t = (thetaDeg * Math.PI) / 180;
      const ct = Math.cos(t);
      const points = [
        { y: ct, color: accent, label: 'cos θ' },
        { y: ct * ct, color: muted, label: 'cos²θ' },
        { y: 1 - ct * ct, color: fg, label: '1−cos²θ' },
      ];
      points.forEach(({ y, color }) => {
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(sx(thetaDeg), sy(y), 3.5, 0, Math.PI * 2);
        ctx.fill();
      });

      // Highlight 90° tick differently
      if (Math.abs(thetaDeg - 90) < 0.5) {
        ctx.fillStyle = accent;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.font = 'bold 11px ui-monospace, monospace';
        ctx.fillText('orthogonality', sx(90), padT + 12);
      }

      readout.textContent = 'θ = ' + thetaDeg.toFixed(0) + '°  ·  cos θ = ' + ct.toFixed(3)
        + '  ·  cos²θ = ' + (ct * ct).toFixed(3)
        + '  ·  1−cos²θ = ' + (1 - ct * ct).toFixed(3);
    };

    const setFromPointer = (e) => {
      const rect = c.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const padL = 40;
      const plotW = rect.width - 40 - 14;
      let v = ((x - padL) / plotW) * 360;
      v = Math.max(0, Math.min(360, v));
      thetaDeg = v;
      requestRedraw();
    };

    let dragging = false;
    c.addEventListener('pointerdown', (e) => {
      dragging = true;
      c.setPointerCapture?.(e.pointerId);
      setFromPointer(e);
    });
    c.addEventListener('pointermove', (e) => { if (dragging) setFromPointer(e); });
    c.addEventListener('pointerup', (e) => {
      dragging = false;
      try { c.releasePointerCapture?.(e.pointerId); } catch {}
    });

    const ro = new ResizeObserver(() => { fit(); requestRedraw(); });
    ro.observe(c);

    const io = new IntersectionObserver((entries) => {
      const was = visible;
      visible = entries[0].isIntersecting;
      if (visible && !was) { fit(); draw(); }
    }, { rootMargin: '120px' });
    io.observe(c);
  };

  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:after-swap', setup);
})();
</script>
