---
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
const id = `ag-${Math.random().toString(36).slice(2, 9)}`;
const cells = [
  { id: `${id}-id`,  name: 'identity', kind: 'identity' },
  { id: `${id}-re`,  name: 'ReLU',     kind: 'relu' },
  { id: `${id}-lr`,  name: 'leaky ReLU', kind: 'leaky' },
  { id: `${id}-si`,  name: 'sigmoid',  kind: 'sigmoid' },
  { id: `${id}-th`,  name: 'tanh',     kind: 'tanh' },
  { id: `${id}-ge`,  name: 'GELU',     kind: 'gelu' },
];
---
<figure class="viz">
  <div class="viz-controls" style="justify-content:center">
    <span><span style="color:var(--accent)">— φ(z)</span> &nbsp; <span style="color:var(--fg-muted)">‒ ‒ φ′(z)</span></span>
  </div>
  <div class="viz-grid act-grid">
    {cells.map((c) => (
      <div class="viz-cell">
        <h4>{c.name}</h4>
        <canvas id={c.id} data-kind={c.kind} aria-label={`${c.name} activation and its derivative`}></canvas>
      </div>
    ))}
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .act-grid { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 640px) { .act-grid { grid-template-columns: repeat(2, 1fr); } }
  .viz-cell canvas { height: 110px; }
</style>

<script is:inline define:vars={{ ids: cells.map((c) => c.id) }}>
(() => {
  const ACT = {
    identity: (z) => z,
    relu: (z) => (z > 0 ? z : 0),
    leaky: (z) => (z > 0 ? z : 0.1 * z),
    sigmoid: (z) => 1 / (1 + Math.exp(-z)),
    tanh: (z) => Math.tanh(z),
    gelu: (z) => 0.5 * z * (1 + Math.tanh(Math.sqrt(2 / Math.PI) * (z + 0.044715 * z * z * z))),
  };
  const dAct = (kind, z) => {
    const h = 1e-3;
    return (ACT[kind](z + h) - ACT[kind](z - h)) / (2 * h);
  };

  const readColors = () => {
    const s = getComputedStyle(document.documentElement);
    const v = (n) => s.getPropertyValue(n).trim();
    return {
      accent: v('--accent') || '#b3661b',
      muted: v('--fg-muted') || '#5a5f66',
      faint: v('--fg-faint') || '#8d8d8d',
      border: v('--border') || '#e4e1d6',
    };
  };
  let colors = readColors();
  const refs = [];
  const themeObs = new MutationObserver(() => {
    colors = readColors();
    refs.forEach((r) => r.draw && r.draw());
  });
  themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  const setup = () => {
    ids.forEach((cid) => {
      const c = document.getElementById(cid);
      if (!c || c.dataset.ready) return;
      c.dataset.ready = '1';
      const kind = c.dataset.kind;
      const ctx = c.getContext('2d');
      const state = { dpr: 1, w: 0, h: 0 };

      const fit = () => {
        const rect = c.getBoundingClientRect();
        const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
        state.dpr = dpr;
        state.w = rect.width;
        state.h = rect.height;
        c.width = Math.round(rect.width * dpr);
        c.height = Math.round(rect.height * dpr);
      };

      const draw = () => {
        const W = state.w, H = state.h;
        if (W === 0 || H === 0) return;
        ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
        ctx.clearRect(0, 0, W, H);
        const { accent, muted, faint, border } = colors;

        const padL = 6, padR = 6, padT = 6, padB = 16;
        const plotW = W - padL - padR;
        const plotH = H - padT - padB;
        const xMin = -3, xMax = 3, yMin = -1.2, yMax = 1.8;
        const sx = (x) => padL + ((x - xMin) / (xMax - xMin)) * plotW;
        const sy = (y) => padT + ((yMax - y) / (yMax - yMin)) * plotH;

        ctx.strokeStyle = border;
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(padL, sy(0)); ctx.lineTo(W - padR, sy(0));
        ctx.moveTo(sx(0), padT); ctx.lineTo(sx(0), H - padB);
        ctx.stroke();

        const M = 120;
        // φ′(z) dashed muted
        ctx.strokeStyle = muted;
        ctx.lineWidth = 1.1;
        ctx.setLineDash([3, 4]);
        ctx.beginPath();
        for (let i = 0; i <= M; i++) {
          const x = xMin + (i / M) * (xMax - xMin);
          let y = dAct(kind, x);
          if (y > yMax) y = yMax;
          if (y < yMin) y = yMin;
          const px = sx(x), py = sy(y);
          if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
        }
        ctx.stroke();
        ctx.setLineDash([]);

        // φ(z) solid accent
        ctx.strokeStyle = accent;
        ctx.lineWidth = 1.7;
        ctx.beginPath();
        for (let i = 0; i <= M; i++) {
          const x = xMin + (i / M) * (xMax - xMin);
          let y = ACT[kind](x);
          if (y > yMax) y = yMax;
          if (y < yMin) y = yMin;
          const px = sx(x), py = sy(y);
          if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
        }
        ctx.stroke();

        // axis labels
        ctx.fillStyle = faint;
        ctx.font = '9px ui-monospace, monospace';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText('z', W - padR + 2, sy(0) - 3);
        ctx.textAlign = 'left';
        ctx.fillText('1', sx(0) + 3, sy(1) - 9);
      };

      const ref = { draw };
      refs.push(ref);

      const ro = new ResizeObserver(() => { fit(); draw(); });
      ro.observe(c);

      let drawn = false;
      const io = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !drawn) {
          drawn = true;
          fit();
          draw();
          io.disconnect();
        }
      }, { rootMargin: '120px' });
      io.observe(c);
      // On a view-transition swap this cell's canvas detaches; drop its per-cell
      // observers and remove it from the shared refs list (which the page-level
      // themeObs redraws) so stale detached cells do not accumulate.
      (window.__vizReg || (window.__vizReg = new Set())).add({ n: c, c: () => { ro.disconnect(); io.disconnect(); const i = refs.indexOf(ref); if (i >= 0) refs.splice(i, 1); } });
    });
  };

  setup();
  document.addEventListener('astro:page-load', setup);
  document.addEventListener('astro:after-swap', setup);
})();
</script>
