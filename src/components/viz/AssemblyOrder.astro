---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 460 } = Astro.props;
---
<figure class="viz assembly-order" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
// Assembly order: build the representer sum one point at a time. Press play
// and watch f_n(x) = Σᵢ₌₁ⁿ αᵢ k(xᵢ, x) accumulate. The first few points
// carve the boundary; the last ones barely shift it.
import { defineViz } from './engine/vizkit.js';
import { softPanel, roundRect, T, rgba, parseColor } from './engine/draw.js';

const DOM = 1.4, SIG = 0.55, HM = 80;
const BLUE = '#4a7fb3', ORANGE = '#b3661b';
const BLUE_RGB = parseColor(BLUE), ORANGE_RGB = parseColor(ORANGE);

function pts() {
  return [
    { x: -0.9, y: 0.55, c: 0, order: 0 },
    { x: -0.15, y: 0.9, c: 0, order: 1 },
    { x: 0.8, y: 0.6, c: 0, order: 2 },
    { x: -0.7, y: -0.65, c: 1, order: 3 },
    { x: 0.2, y: -0.95, c: 1, order: 4 },
    { x: 0.95, y: -0.45, c: 1, order: 5 },
  ];
}

const kern = (ax, ay, bx, by) => Math.exp(-((ax - bx) ** 2 + (ay - by) ** 2) / (2 * SIG * SIG));

function solve(P, lam) {
  const n = P.length;
  const A = [];
  for (let i = 0; i < n; i++) {
    A.push([]);
    for (let j = 0; j < n; j++) A[i].push(kern(P[i].x, P[i].y, P[j].x, P[j].y) + (i === j ? lam : 0));
    A[i].push(P[i].c ? -1 : 1);
  }
  for (let col = 0; col < n; col++) {
    let piv = col;
    for (let r = col + 1; r < n; r++) if (Math.abs(A[r][col]) > Math.abs(A[piv][col])) piv = r;
    [A[col], A[piv]] = [A[piv], A[col]];
    const d = A[col][col] || 1e-9;
    for (let j = col; j <= n; j++) A[col][j] /= d;
    for (let r = 0; r < n; r++) if (r !== col) { const f = A[r][col]; for (let j = col; j <= n; j++) A[r][j] -= f * A[col][j]; }
  }
  return A.map((row) => row[n]);
}

defineViz('assembly-order', {
  title: 'Build the boundary one prototype at a time',
  height: 460,
  autoplay: false,
  controls: [
    { type: 'play' },
    { type: 'step', label: 'add one point' },
    { type: 'reset' },
    { type: 'range', name: 'lam', label: 'λ', min: -2, max: 1.5, step: 0.1, value: -0.8, fmt: (v) => (10 ** v).toFixed(2) },
    { type: 'readout', name: 'rd' },
  ],

  setup(api) {
    const P = pts();
    const lam = 10 ** api.get('lam');
    const al = solve(P, lam);
    P.forEach((p, i) => { p.a = al[i]; });
    // sort by |α| descending (most important first)
    const indices = P.map((_, i) => i).sort((a, b) => Math.abs(P[b].a) - Math.abs(P[a].a));
    indices.forEach((idx, rank) => { P[idx].order = rank; });
    api.state = { P, shown: 0, animT: 0 };
  },

  step(api) {
    const st = api.state; if (!st) return;
    if (st.shown < st.P.length) st.shown++;
  },

  draw(api) {
    const { ctx, colors, size, state: st } = api;
    const W = size.W, H = size.H;
    if (W === 0 || !st) return;
    ctx.clearRect(0, 0, W, H);
    const pad = 14, topH = 34;
    const side = Math.min(W - pad * 2, H - pad - topH - 14);
    const x0 = (W - side) / 2, y0 = pad + topH;
    const sx = (wx) => x0 + (wx + DOM) / (2 * DOM) * side;
    const sy = (wy) => y0 + (DOM - wy) / (2 * DOM) * side;
    const wxOf = (px) => (px - x0) / side * 2 * DOM - DOM;
    const wyOf = (py) => DOM - (py - y0) / side * 2 * DOM;

    T(ctx, colors, 'label');
    ctx.fillText(`${st.shown} of ${st.P.length} prototypes placed; the boundary is f_n(x) = Σᵢ₌₁ⁿ αᵢ k(xᵢ, x)`, pad, pad + 13);

    // build from the first `shown` points (in order of importance)
    const active = st.P.filter((p) => p.order < st.shown);

    // signed field from active points only
    const f = (X, Y) => { let s = 0; for (const p of active) s += p.a * kern(p.x, p.y, X, Y); return s; };
    let maxa = 1e-6;
    for (let r = 0; r < HM; r++) for (let c = 0; c < HM; c++) {
      const X = wxOf(x0 + (c + 0.5) * side / HM), Y = wyOf(y0 + (r + 0.5) * side / HM);
      maxa = Math.max(maxa, Math.abs(f(X, Y)));
    }
    const cb = BLUE_RGB, co = ORANGE_RGB, cell = side / HM;
    for (let r = 0; r < HM; r++) for (let c = 0; c < HM; c++) {
      const X = wxOf(x0 + (c + 0.5) * cell), Y = wyOf(y0 + (r + 0.5) * cell);
      const v = f(X, Y) / maxa;
      const col = v >= 0 ? co : cb;
      const a = 0.5 * Math.min(1, Math.abs(v));
      ctx.fillStyle = `rgba(${col[0]},${col[1]},${col[2]},${a})`;
      ctx.fillRect(x0 + c * cell, y0 + r * cell, cell + 0.6, cell + 0.6);
    }

    // zero contour
    ctx.strokeStyle = colors.fg; ctx.lineWidth = 1.4; ctx.globalAlpha = 0.7;
    const NB = 140;
    for (let r = 0; r < NB; r++) for (let c = 0; c < NB; c++) {
      const X = wxOf(x0 + (c + 0.5) * side / NB), Y = wyOf(y0 + (r + 0.5) * side / NB);
      const v = f(X, Y);
      const vr = f(wxOf(x0 + (c + 1.5) * side / NB), Y);
      const vd = f(X, wyOf(y0 + (r + 1.5) * side / NB));
      if ((v > 0) !== (vr > 0) || (v > 0) !== (vd > 0)) {
        ctx.fillStyle = colors.fg;
        ctx.fillRect(x0 + (c + 0.5) * side / NB, y0 + (r + 0.5) * side / NB, 1.4, 1.4);
      }
    }
    ctx.globalAlpha = 1;

    ctx.strokeStyle = colors.border; ctx.lineWidth = 1;
    ctx.strokeRect(x0 + 0.5, y0 + 0.5, side - 1, side - 1);

    // all points: dim if not yet placed, bright + ring if placed
    for (const p of st.P) {
      const X = sx(p.x), Y = sy(p.y);
      const placed = p.order < st.shown;
      const R = placed ? 7 : 4;
      ctx.globalAlpha = placed ? 0.9 : 0.25;
      ctx.fillStyle = p.a >= 0 ? ORANGE : BLUE;
      ctx.beginPath(); ctx.arc(X, Y, R, 0, 6.283); ctx.fill();
      if (placed) {
        ctx.globalAlpha = 1;
        ctx.lineWidth = 2.4; ctx.strokeStyle = p.c ? BLUE : ORANGE;
        ctx.beginPath(); ctx.arc(X, Y, R + 2.5, 0, 6.283); ctx.stroke();
        // order label
        ctx.fillStyle = colors.fg; ctx.font = 'bold 9px ui-monospace, monospace';
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText(`#${p.order + 1}`, X, Y);
      }
      ctx.globalAlpha = 1;
    }

    const nz = active.filter((p) => Math.abs(p.a) > 0.05).length;
    api.readout('rd', `${active.length} points · ${nz} support vectors · boundary from the most important ${active.length} prototypes`);
  },
});
</script>
