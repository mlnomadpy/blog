---
interface Props {
  caption?: string;
  height?: number;
}
const { caption, height = 320 } = Astro.props;
---
<figure class="viz frameraces" data-caption={caption} data-height={height} tabindex="0">
  <div class="viz-cell"></div>
</figure>

<script>
import { defineViz } from './engine/vizkit.js';
import { panel, text, PALETTE } from './engine/draw.js';

// Benedetto & Fickus (2003): the frame potential has no bad local minima. Here
// six independent random starts descend it at once. Their energy curves all dive
// to the same floor (C²/d − C) — whoever you start as, you reach the optimum.
const K = 6, D = 3;
function randUnit() { let x, y, z, n; do { x = 2 * Math.random() - 1; y = 2 * Math.random() - 1; z = 2 * Math.random() - 1; n = x * x + y * y + z * z; } while (n > 1 || n < 1e-6); n = Math.sqrt(n); return [x / n, y / n, z / n]; }
function fp(P) { let s = 0; for (let i = 0; i < P.length; i++) for (let j = 0; j < P.length; j++) { if (i === j) continue; const c = P[i][0] * P[j][0] + P[i][1] * P[j][1] + P[i][2] * P[j][2]; s += c * c; } return s; }

defineViz('frameraces', {
  title: 'Every random start reaches the same minimum',
  height: 320, stepsPerFrame: 1, maxStep: 110, loop: true,
  controls: [
    { type: 'play' }, { type: 'button', name: 'reroll', label: 're-roll', reset: true }, { type: 'speed' },
    { type: 'newrow' },
    { type: 'range', name: 'C', label: 'vectors C', min: 4, max: 10, step: 1, value: 7, int: true, reset: true, fmt: v => v },
    { type: 'readout', name: 'rd' },
  ],
  setup(api) {
    const C = api.get('C'); const sys = [];
    for (let k = 0; k < K; k++) { const P = []; for (let i = 0; i < C; i++) P.push(randUnit()); sys.push({ P, hist: [fp(P)] }); }
    api.state.sys = sys; api.state.C = C;
  },
  step(api) {
    const C = api.state.C, lr = 0.22 / C;
    for (const sysk of api.state.sys) {
      const P = sysk.P, G = P.map(() => [0, 0, 0]);
      for (let i = 0; i < C; i++) for (let j = 0; j < C; j++) { if (i === j) continue; const c = P[i][0] * P[j][0] + P[i][1] * P[j][1] + P[i][2] * P[j][2], w = 2 * c; G[i][0] += w * P[j][0]; G[i][1] += w * P[j][1]; G[i][2] += w * P[j][2]; }
      for (let i = 0; i < C; i++) { const gu = G[i][0] * P[i][0] + G[i][1] * P[i][1] + G[i][2] * P[i][2]; let x = P[i][0] - lr * (G[i][0] - gu * P[i][0]), y = P[i][1] - lr * (G[i][1] - gu * P[i][1]), z = P[i][2] - lr * (G[i][2] - gu * P[i][2]); const n = Math.hypot(x, y, z) + 1e-12; P[i] = [x / n, y / n, z / n]; }
      sysk.hist.push(fp(P));
    }
  },
  draw(api) {
    const { ctx, colors, size, state } = api;
    const box = { x: 6, y: 4, w: size.W - 12, h: size.H - 8 };
    const m = panel(ctx, box, colors, { header: 22 });
    const C = state.C, floor = C * C / D - C;
    const pad = { l: 44, r: 14, t: 28, b: 26 };
    const px = box.x + pad.l, py = box.y + pad.t, pw = box.w - pad.l - pad.r, ph = box.h - pad.t - pad.b;
    // y-range
    let ymax = floor; for (const s of state.sys) ymax = Math.max(ymax, s.hist[0]); ymax *= 1.05;
    const ymin = Math.max(0, floor - 0.15 * ymax);
    const sx = (i, n) => px + (n <= 1 ? 0 : i / (n - 1)) * pw;
    const sy = (v) => py + ph - ((v - ymin) / (ymax - ymin)) * ph;
    // floor line
    ctx.strokeStyle = colors.green; ctx.setLineDash([5, 4]); ctx.lineWidth = 1.6; ctx.beginPath(); ctx.moveTo(px, sy(floor)); ctx.lineTo(px + pw, sy(floor)); ctx.stroke(); ctx.setLineDash([]);
    text(ctx, `Welch floor  C²/d − C = ${floor.toFixed(1)}`, px + pw - 4, sy(floor) - 4, colors, { align: 'right', baseline: 'bottom', size: 10, color: colors.green });
    // axis labels
    text(ctx, 'frame potential', box.x + 8, box.y + 4, colors, { size: 11.5, color: colors.fg });
    text(ctx, 'gradient-descent steps →', px + pw / 2, box.y + box.h - 14, colors, { align: 'center', size: 10, color: colors.muted });
    // traces
    state.sys.forEach((s, k) => {
      ctx.strokeStyle = PALETTE[k % PALETTE.length]; ctx.lineWidth = 1.6; ctx.globalAlpha = 0.85; ctx.beginPath();
      const n = s.hist.length; for (let i = 0; i < n; i++) { const x = sx(i, Math.max(n, api.iter + 1)), y = sy(s.hist[i]); i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); }
      ctx.stroke(); ctx.globalAlpha = 1;
    });
    api.readout('rd', `${K} random starts · C=${C}, d=${D}`);
  },
});
</script>
