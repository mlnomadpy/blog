---
interface RelatedPost {
  slug: string;
  title: string;
  description?: string;
  pubDate: Date;
}
interface Props {
  posts: RelatedPost[];
}
const { posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
{posts.length > 0 && (
  <aside class="related" aria-labelledby="related-heading">
    <h2 id="related-heading">Related posts</h2>
    <ul>
      {posts.map((p) => (
        <li>
          <a href={`${base}/${p.slug}/`}>
            <span class="related-title">{p.title}</span>
            {p.description && <span class="related-desc">{p.description}</span>}
            <span class="related-meta">
              <time datetime={p.pubDate.toISOString()}>{dateFmt.format(p.pubDate)}</time>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
.related {
  margin: 3.5rem 0 2rem;
  padding-top: 1.75rem;
  border-top: 1px solid var(--border);
}
.related h2 {
  font-family: var(--mono);
  font-size: 0.78rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--fg-faint);
  font-weight: 500;
  margin: 0 0 1rem;
}
.related ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: 0;
}
.related li {
  border-bottom: 1px dashed var(--border);
}
.related li:last-child { border-bottom: 0; }
.related a {
  display: block;
  padding: 0.85rem 0;
  text-decoration: none;
  color: inherit;
  transition: color var(--transition-fast);
}
.related-title {
  display: block;
  font-family: var(--serif);
  font-weight: 600;
  font-size: 1.05rem;
  line-height: 1.4;
  color: var(--fg);
  margin-bottom: 0.25rem;
}
.related-desc {
  display: block;
  font-size: 0.88rem;
  color: var(--fg-muted);
  line-height: 1.5;
  margin-bottom: 0.35rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.related-meta {
  display: block;
  font-family: var(--mono);
  font-size: 0.74rem;
  color: var(--fg-faint);
  letter-spacing: 0.04em;
}
.related a:hover .related-title { color: var(--accent); }
</style>
