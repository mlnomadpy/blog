---
// One archive row: date + title (+ series chip, draft badge), with the post's
// JAX companion nested underneath on a pipe rail. Used by the home "Latest"
// strip, the /archive page, and the standalone section.
interface RowPost {
  id: string;
  data: { title: string; pubDate: Date; draft?: boolean };
}
interface Props {
  post: RowPost;
  companion?: RowPost;
  chip?: { label: string; part: number };
}
const { post, companion, chip } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: '2-digit' });
const stripId = (s: string) => s.replace(/\.(md|mdx)$/, '');
---
<li class={companion ? 'has-companion' : undefined}>
  <a class="row" href={`${base}/${post.id}/`} data-slug={stripId(post.id)}>
    <time class="row-date" datetime={post.data.pubDate.toISOString()}>
      {fmt.format(post.data.pubDate)}
    </time>
    <span class="row-title">
      {post.data.draft && <span class="draft-badge">draft</span>}
      {post.data.title}
      {chip && <span class="series-chip">{chip.label} · {chip.part}</span>}
    </span>
  </a>
  {companion && (
    <a class="companion-row" href={`${base}/${companion.id}/`} data-slug={stripId(companion.id)} aria-label={`JAX companion: ${companion.data.title}`}>
      <span class="companion-rail" aria-hidden="true"></span>
      <span class="companion-tag">JAX companion</span>
      <span class="companion-title">
        {companion.data.draft && <span class="draft-badge">draft</span>}
        {companion.data.title}
      </span>
    </a>
  )}
</li>

<style>
  li { border-bottom: 1px dashed var(--border); }
  li:last-child { border-bottom: 0; }
  li.has-companion { padding-bottom: 0.35rem; }

  .row {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
    padding: 0.6rem 0;
    text-decoration: none;
    color: inherit;
  }
  .has-companion .row { padding-bottom: 0.3rem; }

  /* nested JAX-companion link under its explainer */
  .companion-row {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-left: calc(72px + 1rem);
    padding: 0.1rem 0 0.45rem;
    text-decoration: none;
    color: inherit;
  }
  .companion-rail {
    position: absolute;
    left: -14px;
    top: -0.35em;
    width: 10px;
    height: 0.95em;
    border-left: 1.5px solid var(--border);
    border-bottom: 1.5px solid var(--border);
    border-bottom-left-radius: 6px;
  }
  .companion-tag {
    flex: none;
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.07rem 0.4rem;
    white-space: nowrap;
  }
  .companion-title {
    font-family: var(--serif);
    font-size: 0.92rem;
    line-height: 1.4;
    color: var(--fg-muted);
    transition: color var(--transition-fast);
  }
  .companion-row:hover .companion-title { color: var(--accent); }
  .companion-row:hover .companion-tag { background: color-mix(in srgb, var(--accent) 12%, transparent); }
  .row-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--fg-faint);
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .row-title {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.4;
    color: var(--fg);
    transition: color var(--transition-fast);
  }
  .row:hover .row-title { color: var(--accent); }
  .series-chip {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.64rem;
    letter-spacing: 0.06em;
    color: var(--fg-faint);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.4rem;
    margin-left: 0.55rem;
    white-space: nowrap;
    vertical-align: 0.12em;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .row:hover .series-chip { color: var(--fg-muted); border-color: var(--border-strong); }
  .draft-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.05rem 0.35rem;
    margin-right: 0.5rem;
    vertical-align: 0.12em;
  }

  /* read-state dot, added by ReadMarks.astro (progressive enhancement) */
  :global(a.is-read) .row-date::after,
  :global(a.is-read) .companion-tag::after {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    margin-left: 0.35rem;
    vertical-align: 0.15em;
  }

  @media (max-width: 720px) {
    .row {
      grid-template-columns: 56px 1fr;
      gap: 0.75rem;
      padding: 0.7rem 0;
    }
  }
</style>
