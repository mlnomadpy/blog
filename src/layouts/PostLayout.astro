---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import CodeCopy from '../components/CodeCopy.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import PostNav from '../components/PostNav.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import CompanionCallout from '../components/CompanionCallout.astro';
import SeriesNav from '../components/SeriesNav.astro';
import References from '../components/References.astro';
import Colophon from '../components/Colophon.astro';
import PostAnalytics from '../components/PostAnalytics.astro';

interface NavItem { slug: string; title: string; label?: string }
interface RelatedPost { slug: string; title: string; description?: string; pubDate: Date }
interface Pair { role: 'explainer' | 'companion'; slug: string; title: string }
interface SeriesItem { slug: string; title: string; current: boolean; explainerOfCurrent: boolean }
interface Series { title: string; part: number; total: number; items: SeriesItem[] }
interface Reference { key?: string; authors: string; year: number | string; title: string; venue?: string; url?: string; arxiv?: string; doi?: string }
interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  draft?: boolean;
  pair?: Pair;
  series?: Series;
  references?: Reference[];
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  keywords?: string[];
  heroImage?: string;
  readingTimeText?: string;
  wordCount?: number;
  prev?: NavItem;
  next?: NavItem;
  related?: RelatedPost[];
}
const {
  title,
  seoTitle,
  description,
  draft,
  pair,
  series,
  references = [],
  pubDate,
  updatedDate,
  tags = [],
  keywords,
  heroImage,
  readingTimeText,
  wordCount,
  prev,
  next,
  related = [],
} = Astro.props;
const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const postPath = Astro.url.pathname;
const postSlug = base && postPath.startsWith(`${base}/`)
  ? postPath.slice(base.length).replace(/^\/+|\/+$/g, '')
  : postPath.replace(/^\/+|\/+$/g, '');
// Read-state record for the listing pages' "continue reading" pill and the
// read dots (see ReadMarks.astro). Series posts only; standalone posts still
// get a read dot but never become the continue target.
const lastRead = series
  ? { slug: postSlug, title, series: series.title, part: series.part, total: series.total }
  : null;
---
<BaseLayout
  title={title}
  seoTitle={seoTitle}
  description={description}
  image={heroImage}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
  keywords={keywords}
  wordCount={wordCount}
>
  <ReadingProgress />
  <article
    data-blog-post
    data-pagefind-body
    data-pagefind-meta={`date:${pubDate.toISOString().slice(0, 10)}`}
  >
    <header class="post-header">
      {draft && <p class="draft-banner">Draft — visible locally, excluded from the published site</p>}
      <h1 data-pagefind-meta="title">{title}</h1>
      <p class="meta">
        <time datetime={pubDate.toISOString()}>{dateFmt.format(pubDate)}</time>
        {updatedDate && <> · updated <time datetime={updatedDate.toISOString()}>{dateFmt.format(updatedDate)}</time></>}
        {readingTimeText && <> · {readingTimeText}</>}
      </p>
      {tags.length > 0 && (
        <p style="margin-top:0.65rem" data-pagefind-meta={`tags:${tags.join(',')}`}>
          {tags.map((t) => (
            <a class="tag" href={`${base}/tag/${t}/`}>#{t}</a>
          ))}
        </p>
      )}
    </header>
    {series && <SeriesNav series={series} />}
    {pair && <CompanionCallout pair={pair} />}
    <slot />
    <References items={references} />
    <Colophon />
  </article>
  <PostAnalytics
    title={title}
    slug={postSlug}
    path={postPath}
    tags={tags}
    wordCount={wordCount}
    readingTimeText={readingTimeText}
    draft={draft}
  />
  <RelatedPosts posts={related} />
  <PostNav prev={prev} next={next} />
  <script is:inline data-astro-rerun define:vars={{ postSlug, lastRead }}>
    try {
      const raw = JSON.parse(localStorage.getItem('read-posts') || '[]');
      const read = (Array.isArray(raw) ? raw : []).filter((s) => s !== postSlug);
      read.push(postSlug);
      while (read.length > 200) read.shift();
      localStorage.setItem('read-posts', JSON.stringify(read));
      if (lastRead) localStorage.setItem('last-read', JSON.stringify(lastRead));
    } catch {}
  </script>
  <Giscus />
  <CodeCopy />
</BaseLayout>
