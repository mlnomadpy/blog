---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

interface BlogPostRef { url: string; title: string; description?: string; pubDate: Date }

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  keywords?: string[];
  wordCount?: number;
  author?: string;
  noindex?: boolean;
  blogPosts?: BlogPostRef[];
  profile?: { bio?: string; knowsAbout?: string[] };
}
const props = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead {...props} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />

    <script is:inline>
      // Inject a fullscreen toggle button onto every .viz figure on the page.
      (() => {
        const ENTER_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10V4h6"/><path d="M20 10V4h-6"/><path d="M4 14v6h6"/><path d="M20 14v6h-6"/></svg>';
        const EXIT_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 4H4v6"/><path d="M14 4h6v6"/><path d="M10 20H4v-6"/><path d="M14 20h6v-6"/></svg>';
        const inFs = () => document.fullscreenElement || document.webkitFullscreenElement;
        const enhance = () => {
          document.querySelectorAll('.viz').forEach((fig) => {
            if (fig.dataset.fsReady) return;
            fig.dataset.fsReady = '1';
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'viz-fs-btn';
            btn.setAttribute('aria-label', 'Toggle fullscreen');
            btn.innerHTML = ENTER_SVG + '<span>fullscreen</span>';
            btn.addEventListener('click', async (e) => {
              e.preventDefault();
              try {
                if (inFs() === fig) {
                  await (document.exitFullscreen ? document.exitFullscreen() : document.webkitExitFullscreen?.());
                } else if (fig.requestFullscreen) {
                  await fig.requestFullscreen();
                } else if (fig.webkitRequestFullscreen) {
                  await fig.webkitRequestFullscreen();
                }
              } catch (_) {}
            });
            fig.appendChild(btn);
          });
          const sync = () => {
            document.querySelectorAll('.viz-fs-btn').forEach((b) => {
              const fig = b.parentElement;
              const open = inFs() === fig;
              b.innerHTML = (open ? EXIT_SVG : ENTER_SVG) + '<span>' + (open ? 'exit' : 'fullscreen') + '</span>';
            });
          };
          document.addEventListener('fullscreenchange', sync);
          document.addEventListener('webkitfullscreenchange', sync);
        };
        enhance();
        document.addEventListener('astro:page-load', enhance);
        document.addEventListener('astro:after-swap', enhance);
      })();
    </script>
  </body>
</html>
