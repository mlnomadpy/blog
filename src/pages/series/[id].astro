---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadMarks from '../../components/ReadMarks.astro';
import { getCollection } from 'astro:content';
import { postFilter, buildPairs } from '../../utils/posts';
import { SERIES } from '../../data/series';

export async function getStaticPaths() {
  const posts = await getCollection('blog', postFilter);
  const { companionOf } = buildPairs(posts);
  const stripId = (s: string) => s.replace(/\.(md|mdx)$/, '');
  const byId = new Map(posts.map((p) => [stripId(p.id), p]));

  return SERIES.flatMap((def) => {
    // Part numbers count only visible (draft-filtered) explainers, matching
    // the numbering used by SeriesNav and the archive chips.
    const parts = def.slugs
      .filter((s) => byId.has(s))
      .map((s) => ({ post: byId.get(s)!, companion: companionOf.get(s) }));
    if (parts.length === 0) return [];
    return [{ params: { id: def.id }, props: { def, parts } }];
  });
}

const { def, parts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
const stripId = (s: string) => s.replace(/\.(md|mdx)$/, '');
const first = parts[0];
---
<BaseLayout
  title={def.title}
  description={def.description}
>
  <section class="series-hero">
    <p class="eyebrow">
      series · {parts.length} {parts.length === 1 ? 'part' : 'parts'}
      {def.status === 'ongoing' && <span class="ongoing">· in progress</span>}
    </p>
    <h1>{def.title}</h1>
    <p class="series-lead">{def.description}</p>
    <a class="start-pill" href={`${base}/${first.post.id}/`}>
      Start reading → <span class="start-title">{first.post.data.title}</span>
    </a>
  </section>

  <ol class="series-parts">
    {parts.map(({ post, companion }, i) => (
      <li class={companion ? 'has-companion' : undefined}>
        <a class="part" href={`${base}/${post.id}/`} data-slug={stripId(post.id)}>
          <span class="part-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="part-body">
            <span class="part-title">
              {post.data.draft && <span class="draft-badge">draft</span>}
              {post.data.title}
            </span>
            {post.data.description && (
              <span class="part-desc">{post.data.description}</span>
            )}
            <time class="part-date" datetime={post.data.pubDate.toISOString()}>
              {fmt.format(post.data.pubDate)}
            </time>
          </span>
        </a>
        {companion && (
          <a class="companion-row" href={`${base}/${companion.id}/`} data-slug={stripId(companion.id)} aria-label={`JAX companion: ${companion.data.title}`}>
            <span class="companion-rail" aria-hidden="true"></span>
            <span class="companion-tag">JAX companion</span>
            <span class="companion-title">
              {companion.data.draft && <span class="draft-badge">draft</span>}
              {companion.data.title}
            </span>
          </a>
        )}
      </li>
    ))}
  </ol>

  {def.status === 'ongoing' && (
    <p class="ongoing-note">
      This series is still being written. New parts land in the
      <a href={`${base}/archive/`}> archive</a> and the
      <a href={`${base}/rss.xml`}> RSS feed</a> as they publish.
    </p>
  )}
  <ReadMarks />
</BaseLayout>

<style>
  .series-hero { margin-bottom: 2rem; }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    margin: 0 0 0.6rem;
  }
  .eyebrow .ongoing { color: var(--accent); }
  .series-hero h1 { margin: 0 0 0.6rem; }
  .series-lead {
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--fg-muted);
    max-width: 60ch;
    margin: 0 0 1.1rem;
  }
  .start-pill {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 0.45rem 0.85rem;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .start-pill:hover { background: var(--accent-soft); }
  .start-title { font-family: var(--serif); font-size: 0.92rem; color: var(--fg); }

  .series-parts { list-style: none; padding: 0; margin: 0; counter-reset: none; }
  .series-parts li { border-bottom: 1px dashed var(--border); }
  .series-parts li:last-child { border-bottom: 0; }
  .series-parts li.has-companion { padding-bottom: 0.4rem; }

  .part {
    display: grid;
    grid-template-columns: 2.4rem minmax(0, 1fr);
    gap: 0.85rem;
    padding: 0.85rem 0;
    text-decoration: none;
    color: inherit;
  }
  .part-num {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
    text-align: right;
    padding-top: 0.2rem;
    transition: color var(--transition-fast);
  }
  .part:hover .part-num { color: var(--accent); }
  .part-body { display: block; min-width: 0; }
  .part-title {
    display: block;
    font-family: var(--serif);
    font-size: 1.08rem;
    line-height: 1.4;
    color: var(--fg);
    transition: color var(--transition-fast);
  }
  .part:hover .part-title { color: var(--accent); }
  .part-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.25rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--fg-muted);
  }
  .part-date {
    display: block;
    margin-top: 0.3rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
  }

  .companion-row {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-left: calc(2.4rem + 0.85rem);
    padding: 0 0 0.5rem;
    text-decoration: none;
    color: inherit;
  }
  .companion-rail {
    position: absolute;
    left: -14px;
    top: -0.35em;
    width: 10px;
    height: 0.95em;
    border-left: 1.5px solid var(--border);
    border-bottom: 1.5px solid var(--border);
    border-bottom-left-radius: 6px;
  }
  .companion-tag {
    flex: none;
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.07rem 0.4rem;
    white-space: nowrap;
  }
  .companion-title {
    font-family: var(--serif);
    font-size: 0.92rem;
    line-height: 1.4;
    color: var(--fg-muted);
    transition: color var(--transition-fast);
  }
  .companion-row:hover .companion-title { color: var(--accent); }
  .companion-row:hover .companion-tag { background: color-mix(in srgb, var(--accent) 12%, transparent); }

  .draft-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.05rem 0.35rem;
    margin-right: 0.5rem;
    vertical-align: 0.12em;
  }

  .ongoing-note {
    margin-top: 1.75rem;
    font-size: 0.9rem;
    color: var(--fg-muted);
  }

  /* read-state dot (class added by ReadMarks) */
  :global(a.is-read) .part-num::after {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    margin-left: 0.3rem;
    vertical-align: 0.15em;
  }

  @media (max-width: 720px) {
    .part { grid-template-columns: 1.9rem 1fr; gap: 0.65rem; }
    .companion-row { margin-left: calc(1.9rem + 0.65rem); }
  }
</style>
