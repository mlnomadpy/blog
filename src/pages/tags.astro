---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { postFilter } from '../utils/posts';

const posts = await getCollection('blog', postFilter);
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Tags" description="Browse posts by tag.">
  <h1>Tags</h1>
  <p class="lead">Browse posts by topic.</p>

  {tags.length === 0 ? (
    <p class="muted">No tags yet.</p>
  ) : (
    <div class="tag-cloud">
      {tags.map(([tag, count]) => (
        <a class="tag-link" href={`${base}/tag/${tag}/`}>
          #{tag}<span class="count">{count}</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
