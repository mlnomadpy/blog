---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { postFilter } from '../../utils/posts';
import { tagMeta } from '../../utils/tags';

export async function getStaticPaths() {
  const posts = await getCollection('blog', postFilter);
  const tags = new Set<string>();
  for (const post of posts) for (const t of post.data.tags) tags.add(t);
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const meta = tagMeta(tag, posts.length);

// Absolute URLs for the CollectionPage / ItemList structured data on this topic page.
const abs = (p: string) => new URL(p, Astro.site).toString();
const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${abs(`${base}/tag/${tag}/`)}#collection`,
  name: meta.title,
  description: meta.description,
  url: abs(`${base}/tag/${tag}/`),
  isPartOf: { '@type': 'WebSite', '@id': `${abs(`${base}/`)}#website` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: posts.length,
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: abs(`${base}/${post.id}/`),
      name: post.data.title,
    })),
  },
};
---
<BaseLayout title={meta.title} description={meta.description}>
  <p class="meta"><a href={`${base}/tags`}>← all tags</a></p>
  <h1>{meta.name}</h1>
  <p class="lead">{meta.description}</p>
  <p class="meta">{posts.length} post{posts.length === 1 ? '' : 's'} tagged <code>#{tag}</code>.</p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a class="post-link" href={`${base}/${post.id}/`}>
          <p class="meta">
            <time datetime={post.data.pubDate.toISOString()}>{dateFmt.format(post.data.pubDate)}</time>
          </p>
          <h3>{post.data.title}</h3>
          {post.data.description && <p class="excerpt">{post.data.description}</p>}
        </a>
      </li>
    ))}
  </ul>

  <script type="application/ld+json" set:html={JSON.stringify(collectionLd)} />
</BaseLayout>
