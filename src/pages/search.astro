---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Search" description="Full-text search across all posts.">
  <h1>Search</h1>
  <p class="muted">Full-text search powered by <a href="https://pagefind.app" target="_blank" rel="noopener noreferrer">Pagefind</a>. Indexed at build time.</p>

  <div id="search" style="margin-top:1.5rem"></div>

  <link rel="stylesheet" href={`${base}/pagefind/pagefind-ui.css`} />
  <script is:inline define:vars={{ base }}>
    window.addEventListener('DOMContentLoaded', async () => {
      const { PagefindUI } = await import(`${base}/pagefind/pagefind-ui.js`);
      new PagefindUI({
        element: '#search',
        showImages: false,
        showSubResults: true,
        resetStyles: false,
      });
    });
  </script>

  <style is:global>
    .pagefind-ui {
      --pagefind-ui-primary: var(--accent);
      --pagefind-ui-text: var(--fg);
      --pagefind-ui-background: var(--bg);
      --pagefind-ui-border: var(--border);
      --pagefind-ui-tag: var(--bg-elev);
      --pagefind-ui-border-radius: 6px;
      --pagefind-ui-font: var(--sans);
    }
    .pagefind-ui__result-title a { color: var(--link); }
  </style>
</BaseLayout>
