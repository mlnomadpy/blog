---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const indexUrl = `${base}/search.json`;
---
<BaseLayout title="Search" description="Full-text search across all posts.">
  <h1>Search</h1>
  <p class="muted" style="font-family:var(--serif);font-style:italic;margin-top:-0.5rem">
    Type to filter posts by title, description, body, or <code>#tag</code>.
  </p>

  <div class="search-box">
    <input
      type="search"
      id="search-input"
      placeholder="Search posts…"
      autocomplete="off"
      spellcheck="false"
      autofocus
    />
    <span class="search-count" id="search-count" aria-live="polite"></span>
  </div>

  <ul id="search-results" class="search-results"></ul>

  <p id="search-empty" class="muted" hidden>No posts match.</p>
  <p id="search-loading" class="muted">Loading index…</p>

  <script is:inline define:vars={{ indexUrl, base }}>
    (() => {
      const setup = () => {
        const input = document.getElementById('search-input');
        if (!input || input.dataset.ready) return;
        input.dataset.ready = '1';
        const results = document.getElementById('search-results');
        const empty = document.getElementById('search-empty');
        const loading = document.getElementById('search-loading');
        const count = document.getElementById('search-count');

        let index = null;
        let pending = null;

        const render = (rows, q) => {
          results.innerHTML = '';
          if (!index) return;
          if (!rows.length) {
            empty.hidden = q.length === 0;
            count.textContent = q ? '0 results' : '';
            if (!q) {
              // show all when query is empty
              empty.hidden = true;
              for (const e of index) results.appendChild(renderRow(e, ''));
              count.textContent = index.length + ' posts';
            }
            return;
          }
          empty.hidden = true;
          count.textContent = rows.length + ' result' + (rows.length === 1 ? '' : 's');
          for (const r of rows) results.appendChild(renderRow(r.entry, q));
        };

        const renderRow = (e, q) => {
          const li = document.createElement('li');
          li.className = 'search-row';
          const a = document.createElement('a');
          a.className = 'search-link';
          a.href = base + '/' + e.id + '/';

          const title = document.createElement('h3');
          title.className = 'search-title';
          title.appendChild(highlight(e.title, q));
          a.appendChild(title);

          const meta = document.createElement('p');
          meta.className = 'search-meta';
          const d = new Date(e.pubDate);
          meta.textContent = d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
          if (e.tags && e.tags.length) {
            const sep = document.createElement('span');
            sep.textContent = ' · ';
            meta.appendChild(sep);
            const tags = document.createElement('span');
            tags.textContent = e.tags.map((t) => '#' + t).join(' ');
            meta.appendChild(tags);
          }
          a.appendChild(meta);

          if (q && e.body) {
            const snip = snippet(e.body, q);
            if (snip) {
              const p = document.createElement('p');
              p.className = 'search-snippet';
              p.appendChild(snip);
              a.appendChild(p);
            }
          } else if (e.description) {
            const p = document.createElement('p');
            p.className = 'search-snippet';
            p.textContent = e.description;
            a.appendChild(p);
          }
          li.appendChild(a);
          return li;
        };

        const escapeRe = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

        const highlight = (text, q) => {
          const frag = document.createDocumentFragment();
          if (!q) { frag.appendChild(document.createTextNode(text)); return frag; }
          const tokens = q.split(/\s+/).filter(Boolean).map(escapeRe);
          if (!tokens.length) { frag.appendChild(document.createTextNode(text)); return frag; }
          const re = new RegExp('(' + tokens.join('|') + ')', 'gi');
          let last = 0;
          text.replace(re, (m, _g, off) => {
            if (off > last) frag.appendChild(document.createTextNode(text.slice(last, off)));
            const mark = document.createElement('mark');
            mark.textContent = m;
            frag.appendChild(mark);
            last = off + m.length;
            return m;
          });
          if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
          return frag;
        };

        const snippet = (body, q) => {
          const tokens = q.split(/\s+/).filter(Boolean);
          if (!tokens.length) return null;
          const lower = body.toLowerCase();
          let pos = -1;
          for (const t of tokens) {
            const i = lower.indexOf(t.toLowerCase());
            if (i >= 0 && (pos === -1 || i < pos)) pos = i;
          }
          if (pos === -1) return null;
          const start = Math.max(0, pos - 60);
          const end = Math.min(body.length, pos + 140);
          let txt = body.slice(start, end);
          if (start > 0) txt = '…' + txt;
          if (end < body.length) txt = txt + '…';
          return highlight(txt, q);
        };

        const score = (e, tokens) => {
          let total = 0;
          const t = e.title.toLowerCase();
          const d = (e.description || '').toLowerCase();
          const b = (e.body || '').toLowerCase();
          const tags = (e.tags || []).map((x) => x.toLowerCase());
          for (const tok of tokens) {
            const isTag = tok.startsWith('#');
            const term = isTag ? tok.slice(1) : tok;
            if (!term) return 0;
            let hit = 0;
            if (isTag) {
              if (tags.includes(term)) hit += 200;
              else if (tags.some((g) => g.includes(term))) hit += 80;
            } else {
              if (t.includes(term)) hit += 100;
              if (tags.some((g) => g.includes(term))) hit += 60;
              if (d.includes(term)) hit += 30;
              if (b.includes(term)) hit += 10;
            }
            if (hit === 0) return 0;
            total += hit;
          }
          return total;
        };

        const run = () => {
          if (!index) return;
          const q = input.value.trim();
          if (!q) { render([], ''); return; }
          const tokens = q.toLowerCase().split(/\s+/).filter(Boolean);
          const rows = [];
          for (const e of index) {
            const s = score(e, tokens);
            if (s > 0) rows.push({ s, entry: e });
          }
          rows.sort((a, b) => b.s - a.s);
          render(rows, q);
        };

        const schedule = () => {
          if (pending) cancelAnimationFrame(pending);
          pending = requestAnimationFrame(() => { pending = null; run(); });
        };

        input.addEventListener('input', schedule);

        fetch(indexUrl)
          .then((r) => r.json())
          .then((data) => {
            index = data;
            loading.hidden = true;
            const params = new URLSearchParams(window.location.search);
            const q = params.get('q') || '';
            if (q) { input.value = q; }
            run();
          })
          .catch((err) => {
            loading.textContent = 'Failed to load search index.';
            console.error(err);
          });
      };

      setup();
      document.addEventListener('astro:page-load', setup);
      document.addEventListener('astro:after-swap', setup);
    })();
  </script>
</BaseLayout>

<style>
  .search-box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.25rem 0 0.5rem;
  }
  .search-box input {
    flex: 1;
    background: var(--bg-elev);
    color: var(--fg);
    border: 1px solid var(--border);
    padding: 0.7rem 0.9rem;
    border-radius: var(--radius);
    font-family: var(--sans);
    font-size: 1rem;
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .search-box input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .search-count {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .search-results {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }
  .search-row {
    border-bottom: 1px dashed var(--border);
  }
  .search-row:last-child { border-bottom: 0; }
  .search-link {
    display: block;
    padding: 0.85rem 0;
    text-decoration: none;
    color: inherit;
  }
  .search-link:hover .search-title { color: var(--accent); }
  .search-title {
    font-family: var(--serif);
    font-size: 1.1rem;
    margin: 0 0 0.2rem;
    line-height: 1.35;
    color: var(--fg);
    transition: color var(--transition-fast);
  }
  .search-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-faint);
    margin: 0 0 0.3rem;
  }
  .search-snippet {
    font-family: var(--serif);
    font-size: 0.96rem;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.55;
  }
  .search-snippet mark,
  .search-title mark {
    background: var(--accent-soft);
    color: inherit;
    border-radius: 2px;
    padding: 0 0.15em;
  }
</style>
