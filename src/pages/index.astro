---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_TAGLINE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const byYear = posts.reduce<Record<number, typeof posts>>((acc, p) => {
  const y = p.data.pubDate.getFullYear();
  (acc[y] ??= []).push(p);
  return acc;
}, {});
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: '2-digit' });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteBase = (Astro.site?.toString() ?? '').replace(/\/+$/, '') + base + '/';

// Blog schema for home page: top 10 most recent posts as blogPost array.
const blogPosts = posts.slice(0, 10).map((p) => ({
  url: `${siteBase}${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
}));
---
<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  blogPosts={blogPosts}
>
  <section class="intro">
    <h1>{SITE_TITLE}</h1>
    <p class="lead">{SITE_TAGLINE}</p>
    <p class="intro-blurb">
      Long-form pieces on <strong>machine learning interpretability</strong>,
      <strong>kernel methods</strong>, <strong>contrastive learning</strong>,
      and the <strong>geometry of neural network representations</strong>.
      Most posts ship with interactive visualisations you can play with in the
      browser.
    </p>
  </section>

  <section class="archive">
    {years.map((year) => (
      <div class="archive-year">
        <h2>{year}</h2>
        <ul>
          {byYear[year].map((post) => (
            <li>
              <a class="row" href={`${base}/${post.id}/`}>
                <time class="row-date" datetime={post.data.pubDate.toISOString()}>
                  {fmt.format(post.data.pubDate)}
                </time>
                <span class="row-title">{post.data.title}</span>
                {post.data.tags.length > 0 && (
                  <span class="row-tags">
                    {post.data.tags.map((t) => <span class="tag-mini">#{t}</span>)}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .intro-blurb {
    margin: 0.85rem 0 0.5rem;
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 56ch;
  }
  .intro-blurb strong { color: var(--fg); font-weight: 600; }
  .archive { margin-top: 1.5rem; }
  .archive-year { margin-bottom: 1.75rem; }
  .archive-year h2 {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    font-weight: 500;
    margin: 0 0 0.4rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--border);
  }
  .archive-year ul { list-style: none; padding: 0; margin: 0; }
  .archive-year li { border-bottom: 1px dashed var(--border); }
  .archive-year li:last-child { border-bottom: 0; }

  .row {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: baseline;
    padding: 0.55rem 0;
    text-decoration: none;
    color: inherit;
  }
  .row-date {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--fg-faint);
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .row-title {
    font-family: var(--serif);
    font-size: 1.02rem;
    line-height: 1.4;
    color: var(--fg);
    transition: color var(--transition-fast);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .row:hover .row-title { color: var(--accent); }
  .row-tags {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }
  .tag-mini { margin-left: 0.45rem; }
  .row:hover .tag-mini { color: var(--fg-muted); }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 60px 1fr;
      gap: 0.75rem;
      row-gap: 0.15rem;
    }
    .row-tags { grid-column: 2; font-size: 0.7rem; }
    .tag-mini { margin: 0 0.45rem 0 0; }
  }
</style>
