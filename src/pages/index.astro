---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostRow from '../components/PostRow.astro';
import SeriesCard from '../components/SeriesCard.astro';
import ReadMarks from '../components/ReadMarks.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_TAGLINE } from '../consts';
import { postFilter, buildPairs } from '../utils/posts';
import { SERIES, seriesForSlug } from '../data/series';

const posts = (await getCollection('blog', postFilter))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Pair explainers with their JAX companions. Companions are not listed on their
// own row; they appear nested under their explainer.
const { companionOf, mainOf } = buildPairs(posts);
const stripId = (s: string) => s.replace(/\.(md|mdx)$/, '');
const topLevel = posts.filter((p) => !mainOf.has(stripId(p.id)));

// Series chip: part number counts only visible (draft-filtered) explainers.
const visibleSlugs = new Set(posts.map((p) => stripId(p.id)));
const seriesChip = (post: (typeof posts)[number]) => {
  const id = stripId(post.id);
  const def = seriesForSlug(id);
  if (!def) return undefined;
  const part = def.slugs.filter((s) => visibleSlugs.has(s)).indexOf(id) + 1;
  return part > 0 ? { label: def.short, part } : undefined;
};

// The three most recent top-level posts, for returning readers.
const latest = topLevel.slice(0, 3);

// Arcs in narrative order, restricted to what is actually published.
const byId = new Map(posts.map((p) => [stripId(p.id), p]));
const arcs = SERIES.map((def) => ({
  def,
  parts: def.slugs
    .filter((s) => byId.has(s))
    .map((s) => ({ id: byId.get(s)!.id, title: byId.get(s)!.data.title })),
})).filter((a) => a.parts.length > 0);

// Top-level posts that belong to no series.
const standalone = topLevel.filter((p) => !seriesForSlug(stripId(p.id)));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteBase = (Astro.site?.toString() ?? '').replace(/\/+$/, '') + base + '/';

// Blog schema for home page: top 10 most recent posts as blogPost array.
const blogPosts = posts.slice(0, 10).map((p) => ({
  url: `${siteBase}${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
}));
---
<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  blogPosts={blogPosts}
>
  <section class="intro">
    <h1>{SITE_TITLE}</h1>
    <p class="lead">{SITE_TAGLINE}</p>
    <p class="intro-blurb">
      Long-form pieces on <strong>machine learning interpretability</strong>,
      <strong>kernel methods</strong>, <strong>contrastive learning</strong>,
      and the <strong>geometry of neural network representations</strong>.
      Most posts ship with interactive visualisations you can play with in the
      browser. The posts run in series that build on each other; see
      <a href={`${base}/map/`}>the map</a> for how they connect.
    </p>
  </section>

  <div class="continue" data-continue data-base={base} hidden>
    <a href={`${base}/`}>
      <span class="continue-eyebrow">Continue reading · <span data-continue-label></span></span>
      <span class="continue-title" data-continue-title></span>
    </a>
  </div>

  <section class="home-section">
    <h2 class="section-eyebrow">Latest</h2>
    <ul class="latest-list">
      {latest.map((post) => (
        <PostRow
          post={post}
          companion={companionOf.get(stripId(post.id))}
          chip={seriesChip(post)}
        />
      ))}
    </ul>
    <a class="section-more" href={`${base}/archive/`}>Full archive by date →</a>
  </section>

  <section class="home-section">
    <h2 class="section-eyebrow">Series, in reading order</h2>
    <p class="section-note">Each series is a narrative: start at part 1.</p>
    <div class="series-stack">
      {arcs.map(({ def, parts }) => <SeriesCard def={def} parts={parts} />)}
    </div>
  </section>

  {standalone.length > 0 && (
    <section class="home-section">
      <h2 class="section-eyebrow">More posts</h2>
      <ul class="latest-list">
        {standalone.map((post) => (
          <PostRow post={post} companion={companionOf.get(stripId(post.id))} />
        ))}
      </ul>
    </section>
  )}
  <ReadMarks />
</BaseLayout>

<style>
  .intro-blurb {
    margin: 0.85rem 0 0.5rem;
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 56ch;
  }
  .intro-blurb strong { color: var(--fg); font-weight: 600; }
  .intro-blurb a { color: var(--accent); }

  .continue { margin-top: 1.25rem; }
  .continue a {
    display: block;
    background: var(--bg-sunken);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.7rem 0.95rem;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast);
  }
  .continue a:hover { border-color: var(--border-strong); }
  .continue-eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }
  .continue-title {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--fg);
  }

  .home-section { margin-top: 2rem; }
  .section-eyebrow {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-faint);
    font-weight: 500;
    margin: 0 0 0.4rem;
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--border);
  }
  .section-note {
    margin: 0.5rem 0 0.75rem;
    font-size: 0.88rem;
    color: var(--fg-muted);
  }
  .latest-list { list-style: none; padding: 0; margin: 0; }
  .section-more {
    display: inline-block;
    margin-top: 0.6rem;
    font-family: var(--mono);
    font-size: 0.74rem;
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .section-more:hover { color: var(--accent); }
  .series-stack { margin-top: 0.85rem; display: grid; gap: 1rem; }
</style>
