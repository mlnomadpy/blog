---
import { getCollection, render } from 'astro:content';
import readingTime from 'reading-time';
import PostLayout from '../layouts/PostLayout.astro';
import { postFilter, buildPairs, pairFor } from '../utils/posts';
import { seriesForSlug } from '../data/series';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', postFilter))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const pairs = buildPairs(posts);

  // Series navigation. Series are declared over explainer slugs; a companion
  // inherits its explainer's spot. Only visible (draft-filtered) posts count,
  // so part numbers always match what is actually published.
  const stripId = (s: string) => s.replace(/\.(md|mdx)$/, '');
  const bySlug = new Map(posts.map((p) => [stripId(p.id), p]));
  const seriesFor = (post: (typeof posts)[number]) => {
    const id = stripId(post.id);
    const pr = pairFor(post, pairs);
    // Anchor = the explainer whose series position this page occupies.
    const anchor = seriesForSlug(id) ? id
      : pr?.role === 'companion' ? stripId(pr.other.id)
      : undefined;
    const def = anchor ? seriesForSlug(anchor) : undefined;
    if (!def || !anchor) return undefined;
    const visible = def.slugs.filter((s) => bySlug.has(s));
    const part = visible.indexOf(anchor) + 1;
    if (part === 0) return undefined;
    return {
      title: def.title,
      part,
      total: visible.length,
      items: visible.map((s) => ({
        slug: bySlug.get(s)!.id,
        title: bySlug.get(s)!.data.title,
        current: s === id,
        explainerOfCurrent: s !== id && s === anchor,
      })),
    };
  };

  return posts.map((post, i) => {
    // Score every other post by tag overlap with this one, then prefer the
    // most-recent at the same score. Top 3 surface as Related posts.
    const myTags = new Set((post.data.tags ?? []).map((t) => t.toLowerCase()));
    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => ({
        post: p,
        score: (p.data.tags ?? []).reduce((n, t) => n + (myTags.has(t.toLowerCase()) ? 1 : 0), 0),
      }))
      .filter((x) => x.score > 0)
      .sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
      })
      .slice(0, 3)
      .map((x) => ({
        slug: x.post.id,
        title: x.post.data.title,
        description: x.post.data.description,
        pubDate: x.post.data.pubDate,
      }));

    const pr = pairFor(post, pairs);
    const pair = pr
      ? { role: pr.role, slug: pr.other.id, title: pr.other.data.title }
      : undefined;

    return {
      params: { slug: post.id },
      props: {
        post,
        // sorted desc → i+1 is older (previous in time), i-1 is newer (next in time)
        next: i > 0 ? { slug: posts[i - 1].id, title: posts[i - 1].data.title } : undefined,
        prev: i < posts.length - 1 ? { slug: posts[i + 1].id, title: posts[i + 1].data.title } : undefined,
        related,
        pair,
        series: seriesFor(post),
      },
    };
  });
}

const { post, prev, next, related, pair, series } = Astro.props;
const { Content } = await render(post);
const stats = readingTime(post.body ?? '');
---
<PostLayout
  title={post.data.title}
  seoTitle={post.data.seoTitle}
  description={post.data.seoDescription ?? post.data.description}
  draft={post.data.draft}
  pair={pair}
  series={series}
  references={post.data.references}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  keywords={post.data.keywords}
  heroImage={post.data.heroImage}
  readingTimeText={stats.text}
  wordCount={stats.words}
  prev={prev}
  next={next}
  related={related}
>
  <Content />
</PostLayout>
